{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Gateway": {
    "ApiKey": "vnuf-gateway-key-2026",
    "JwtSecret": "VNUFLearning_SuperSecret_JWT_Key_2026_MinLength32Chars!",
    "JwtIssuer": "VNUFLearning",
    "JwtAudience": "VNUFLearning",
    "AllowedOrigins": [
      "http://localhost:5153",
      "http://localhost:7000"
    ],
    "RoleProtectedPaths": {
      "/admin": [ "Admin" ],
      "/teacher": [ "GiangVien" ],
      "/student": [ "SinhVien" ]
    },
    "UnauthenticatedPaths": [
      "/",
      "/home",
      "/account/login",
      "/account/logout",
      "/account/register",
      "/account/forgot-password",
      "/api/auth/login",
      "/api/auth/refresh-token",
      "/api/auth/healthcheck",
      "/css",
      "/js",
      "/lib",
      "/images",
      "/templates",
      "/favicon.ico"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 120
      },
      {
        "Endpoint": "*:/account/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*:/api/auth/login",
        "Period": "1m",
        "Limit": 10
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "account-route": {
        "ClusterId": "vnuf-cluster",
        "Match": { "Path": "/Account/{**catch-all}" }
      },
      "admin-route": {
        "ClusterId": "vnuf-cluster",
        "Match": { "Path": "/Admin/{**catch-all}" }
      },
      "teacher-route": {
        "ClusterId": "vnuf-cluster",
        "Match": { "Path": "/Teacher/{**catch-all}" }
      },
      "student-route": {
        "ClusterId": "vnuf-cluster",
        "Match": { "Path": "/Student/{**catch-all}" }
      },
      "home-route": {
        "ClusterId": "vnuf-cluster",
        "Match": { "Path": "/Home/{**catch-all}" }
      },
      "blog-route": {
        "ClusterId": "vnuf-cluster",
        "Match": { "Path": "/Blog/{**catch-all}" }
      },
      "blogmoderation-route": {
        "ClusterId": "vnuf-cluster",
        "Match": { "Path": "/BlogModeration/{**catch-all}" }
      },
      "document-route": {
        "ClusterId": "vnuf-cluster",
        "Match": { "Path": "/Document/{**catch-all}" }
      },
      "api-route": {
        "ClusterId": "vnuf-cluster",
        "Match": { "Path": "/api/{**catch-all}" }
      },
      "static-route": {
        "ClusterId": "vnuf-cluster",
        "Match": {
          "Path": "/{**catch-all}",
          "Methods": [ "GET", "HEAD" ]
        }
      }
    },
    "Clusters": {
      "vnuf-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "primary": { "Address": "http://localhost:5153/" }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:01:00"
        }
      }
    }
  }
}
