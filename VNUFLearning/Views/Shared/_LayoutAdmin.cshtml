@{
    var path = Context.Request.Path.Value?.ToLower() ?? "";
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Admin";
    var initials = string.Join("", fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).TakeLast(2).Select(x => x[0])).ToUpper();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin VNUF</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>


<body>
    <div class="vnuf-app">
        <aside class="vnuf-sidebar">
            <a href="/Admin/Dashboard" class="sidebar-brand">
                <div class="brand-logo">
                    <i class="fa-solid fa-leaf"></i>
                </div>
                <div class="brand-text">
                    Admin<br />
                    <span>VNUF</span>
                </div>
            </a>

            <div class="menu-section">
                <div class="menu-title">Hệ thống</div>

                <a href="/Admin/Dashboard" class="menu-link @(path.Contains("/admin/dashboard") ? "active" : "")">
                    <i class="fa-solid fa-chart-pie"></i>
                    <span>Dashboard</span>
                </a>

                <a href="/Admin/Users" class="menu-link @(path.Contains("/admin/users") ? "active" : "")">
                    <i class="fa-solid fa-users"></i>
                    <span>Quản lý người dùng</span>
                </a>
            </div>

            <div class="menu-section">
                <div class="menu-title">Học tập & Thi cử</div>

                <a href="/Admin/Subjects" class="menu-link @(path.Contains("/admin/subjects") ? "active" : "")">
                    <i class="fa-solid fa-book-open"></i>
                    <span>Quản lý môn học</span>
                </a>

                <a href="/Admin/Questions" class="menu-link @(path.Contains("/admin/questions") ? "active" : "")">
                    <i class="fa-solid fa-database"></i>
                    <span>Ngân hàng câu hỏi</span>
                </a>

                <a href="/Admin/Documents" class="menu-link @(path.Contains("/admin/documents") ? "active" : "")">
                    <i class="fa-solid fa-folder-open"></i>
                    <span>Quản lý học liệu</span>
                </a>
            </div>

            <div class="menu-section">
                <div class="menu-title">Báo cáo</div>

                <a href="/Admin/Statistics" class="menu-link @(path.Contains("/admin/statistics") ? "active" : "")">
                    <i class="fa-solid fa-chart-column"></i>
                    <span>Thống kê</span>
                </a>
            </div>
        </aside>

        <main class="vnuf-main">
            <header class="vnuf-topbar">
                <h4 class="topbar-title">@ViewData["Title"]</h4>

                <div class="topbar-user">
                    <div class="topbar-user-info">
                        <div class="topbar-user-name">@fullName</div>
                        <div class="topbar-user-role">Quản trị viên</div>
                    </div>

                    <div class="topbar-avatar">@initials</div>

                    <a href="/Account/Logout" class="btn btn-outline-danger rounded-4 fw-bold">
                        <i class="fa-solid fa-right-from-bracket me-1"></i> Đăng xuất
                    </a>
                </div>
            </header>

            <div class="vnuf-page">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>