@{
    var path = Context?.Request?.Path.Value?.ToLower() ?? "";
    var displayName = User?.Identity?.Name ?? "Admin";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin VNUF</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>

<body>
    <div class="d-flex">
        <nav class="vnuf-sidebar">
            <a href="/Admin/Dashboard" class="sidebar-brand">
                <div class="brand-icon">
                    <i class="fa-solid fa-leaf"></i>
                </div>
                <span>Admin <span style="color:#7cf3b0;">VNUF</span></span>
            </a>

            <div class="sidebar-menu">
                <div class="menu-title">Hệ thống</div>

                <a class="menu-link @(path.Contains("/admin/dashboard") ? "active" : "")" href="/Admin/Dashboard">
                    <i class="fa-solid fa-chart-pie"></i>
                    <span>Dashboard</span>
                </a>

                <a class="menu-link @(path.Contains("/admin/users") ? "active" : "")" href="/Admin/Users">
                    <i class="fa-solid fa-users"></i>
                    <span>Quản lý người dùng</span>
                </a>

                <div class="menu-title">Học tập & Thi cử</div>

                <a class="menu-link @(path.Contains("/admin/subjects") ? "active" : "")" href="/Admin/Subjects">
                    <i class="fa-solid fa-book-open"></i>
                    <span>Quản lý môn học</span>
                </a>

                <a class="menu-link @(path.Contains("/admin/questions") ? "active" : "")" href="/Admin/Questions">
                    <i class="fa-solid fa-database"></i>
                    <span>Ngân hàng câu hỏi</span>
                </a>

                <a class="menu-link @(path.Contains("/admin/documents") ? "active" : "")" href="/Admin/Documents">
                    <i class="fa-solid fa-folder-open"></i>
                    <span>Quản lý học liệu</span>
                </a>

                <div class="menu-title">Báo cáo</div>

                <a class="menu-link @(path.Contains("/admin/statistics") ? "active" : "")" href="/Admin/Statistics">
                    <i class="fa-solid fa-chart-column"></i>
                    <span>Thống kê</span>
                </a>
            </div>
        </nav>

        <div class="main-content">
            <header class="top-header">
                <h4>@ViewData["Title"]</h4>

                <div class="top-user-box">
                    <div class="top-user-meta">
                        <div class="top-user-name">@displayName</div>
                        <div class="top-user-role">Quản trị viên</div>
                    </div>

                    <img src="https://ui-avatars.com/api/?name=@displayName&background=005b33&color=fff"
                         class="top-avatar"
                         alt="Avatar" />

                    <a href="/Account/Logout" class="btn btn-outline-danger logout-btn">
                        <i class="fa fa-right-from-bracket me-1"></i> Đăng xuất
                    </a>
                </div>
            </header>

            <main class="flex-grow-1 p-4 p-md-5">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>