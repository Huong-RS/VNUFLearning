@{
    var path = Context.Request.Path.Value?.ToLower() ?? "";
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Sinh viên";
    var initials = string.Join("", fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).TakeLast(2).Select(x => x[0])).ToUpper();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sinh viên VNUF</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>


<body>
    <div class="vnuf-app">
        <aside class="vnuf-sidebar">
            <a href="/Student/Dashboard" class="sidebar-brand">
                <div class="brand-logo">
                    <i class="fa-solid fa-leaf"></i>
                </div>
                <div class="brand-text">
                    Student<br />
                    <span>VNUF</span>
                </div>
            </a>

            <div class="menu-section">
                <div class="menu-title">Hệ thống</div>

                <a href="/Student/Dashboard" class="menu-link @(path.Contains("/student/dashboard") ? "active" : "")">
                    <i class="fa-solid fa-chart-pie"></i>
                    <span>Dashboard</span>
                </a>

                <a href="/Student/Profile" class="menu-link @(path.Contains("/student/profile") ? "active" : "")">
                    <i class="fa-solid fa-user"></i>
                    <span>Profile</span>
                </a>
            </div>

            <div class="menu-section">
                <div class="menu-title">Học tập</div>

                <a href="/Student/Practice" class="menu-link @(path.Contains("/student/practice") ? "active" : "")">
                    <i class="fa-solid fa-list-check"></i>
                    <span>Luyện thi</span>
                </a>

                <a href="/Student/Documents" class="menu-link @(path.Contains("/student/documents") ? "active" : "")">
                    <i class="fa-solid fa-folder"></i>
                    <span>Material Library</span>
                </a>

                <a href="/Student/History" class="menu-link @(path.Contains("/student/history") ? "active" : "")">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    <span>Study History</span>
                </a>
            </div>

            <div class="menu-section">
                <div class="menu-title">Cộng đồng</div>

                <a href="/Student/Blog" class="menu-link @(path.Contains("/student/blog") ? "active" : "")">
                    <i class="fa-solid fa-file-lines"></i>
                    <span>Blog</span>
                </a>
            </div>
        </aside>

        <main class="vnuf-main">
            <header class="vnuf-topbar">
                <h4 class="topbar-title">@ViewData["Title"]</h4>

                <div class="topbar-user">
                    <div class="topbar-user-info">
                        <div class="topbar-user-name">@fullName</div>
                        <div class="topbar-user-role">Sinh viên</div>
                    </div>

                    <div class="topbar-avatar">@initials</div>

                    <a href="/Account/Logout" class="btn btn-outline-danger rounded-4 fw-bold">
                        <i class="fa-solid fa-right-from-bracket me-1"></i> Đăng xuất
                    </a>
                </div>
            </header>

            <div class="vnuf-page">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>