@{
    var path = Context?.Request?.Path.Value?.ToLower() ?? "";
    var displayName = User?.FindFirst("FullName")?.Value
                      ?? User?.Identity?.Name
                      ?? "Giảng viên";

    var avatar = User?.FindFirst("AvatarUrl")?.Value;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Giảng viên VNUF</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>

<body>
    <div class="d-flex">
        <nav class="vnuf-sidebar">
            <a href="/Teacher/Dashboard" class="sidebar-brand">
                <div class="brand-icon">
                    <i class="fa-solid fa-chalkboard-user"></i>
                </div>
                <span>Teacher <span style="color:#7cf3b0;">VNUF</span></span>
            </a>

            <div class="sidebar-menu">
                <div class="menu-title">Hệ thống</div>

                <a class="menu-link @(path.Contains("/teacher/dashboard") ? "active" : "")"
                   href="/Teacher/Dashboard">
                    <i class="fa-solid fa-chart-pie"></i>
                    <span>Dashboard</span>
                </a>

                <div class="menu-title">Giảng dạy</div>

                <a class="menu-link @(path.Contains("/teacher/subjects") ? "active" : "")"
                   href="/Teacher/Subjects">
                    <i class="fa-solid fa-book-open"></i>
                    <span>Môn học phụ trách</span>
                </a>

                <a class="menu-link @(path.Contains("/teacher/questions") ? "active" : "")"
                   href="/Teacher/Questions">
                    <i class="fa-solid fa-database"></i>
                    <span>Ngân hàng câu hỏi</span>
                </a>

                <a class="menu-link @(path.Contains("/teacher/documents") ? "active" : "")"
                   href="/Teacher/Documents">
                    <i class="fa-solid fa-folder-open"></i>
                    <span>Tài liệu học tập</span>
                </a>

                <div class="menu-title">Thi cử</div>

                <a class="menu-link @(path.Contains("/teacher/exams") ? "active" : "")"
                   href="/Teacher/Exams">
                    <i class="fa-solid fa-file-circle-plus"></i>
                    <span>Quản lý đề thi</span>
                </a>

                <a class="menu-link @(path.Contains("/teacher/results") ? "active" : "")"
                   href="/Teacher/Results">
                    <i class="fa-solid fa-award"></i>
                    <span>Kết quả sinh viên</span>
                </a>

                <div class="menu-title">Cộng đồng</div>

                <a class="menu-link @(path.Contains("/teacher/blog") ? "active" : "")"
                   href="/Teacher/Blog">
                    <i class="fa-solid fa-comments"></i>
                    <span>Blog</span>
                </a>
            </div>
        </nav>

        <div class="main-content">
            <header class="top-header">
                <h4>@ViewData["Title"]</h4>

                <div class="top-user-box">
                    <div class="top-user-meta">
                        <div class="top-user-name">@displayName</div>
                        <div class="top-user-role">Giảng viên</div>
                    </div>

                    <img src="@(string.IsNullOrWhiteSpace(avatar)
                                 ? $"https://ui-avatars.com/api/?name={displayName}&background=005b33&color=fff"
                                 : avatar)"
                         class="top-avatar"
                         alt="Avatar" />

                    <a href="/Account/Logout" class="btn btn-outline-danger logout-btn">
                        <i class="fa fa-right-from-bracket me-1"></i> Đăng xuất
                    </a>
                </div>
            </header>

            <main class="flex-grow-1 p-4 p-md-5">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>