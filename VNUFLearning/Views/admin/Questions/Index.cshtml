@model IEnumerable<VNUFLearning.Models.Question>

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Ngân hàng câu hỏi";

    var selectedQuestionType = ViewBag.QuestionType as int?;
    var selectedLevel = ViewBag.Level as int?;
    var keyword = ViewBag.Keyword as string;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
    int? selectedSubjectId = ViewBag.SubjectId as int?;
}

<div class="container-fluid mt-2">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-1" style="color:#005b33;">
                <i class="fa fa-database me-2"></i>Quản lý Ngân hàng câu hỏi
            </h3>
            <p class="text-muted mb-0">
                Quản lý kho dữ liệu câu hỏi của toàn bộ môn học trong hệ thống.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a id="btnExport" class="btn btn-light border fw-bold px-4 rounded-4" style="cursor:pointer;">
                <i class="fa fa-file-export me-2 text-secondary"></i> Xuất Excel
            </a>

            <button class="btn btn-light border fw-bold px-4 rounded-4 text-primary"
                    data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="fa fa-file-import me-2"></i> Import Excel
            </button>

            <a href="/Admin/Questions/Create" class="btn btn-success fw-bold px-4 rounded-4" style="background-color:#16a34a; border:none;">
                <i class="fa fa-plus me-2"></i> Thêm câu hỏi
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 shadow-sm border-0">
            <i class="fa fa-circle-check me-2"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 shadow-sm border-0">
            <i class="fa fa-triangle-exclamation me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" action="/Admin/Questions" class="row g-3 align-items-end">
                <input type="hidden" name="pageSize" value="@pageSize" />

                <div class="col-md-3">
                    <label class="form-label fw-semibold text-muted small">Lọc theo Môn học</label>
                    <select id="subjectId" name="subjectId" asp-items="ViewBag.SubjectList" class="form-select rounded-4">
                        <option value="">Tất cả môn học</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold text-muted small">Loại câu hỏi</label>
                    <select name="questionType" class="form-select rounded-4">
                        <option value="">Tất cả loại</option>
                        <option value="1" selected="@(selectedQuestionType == 1)">Trắc nghiệm</option>
                        <option value="2" selected="@(selectedQuestionType == 2)">Tự luận</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold text-muted small">Mức độ</label>
                    <select name="level" class="form-select rounded-4">
                        <option value="">Tất cả mức</option>
                        <option value="1" selected="@(selectedLevel == 1)">Dễ</option>
                        <option value="2" selected="@(selectedLevel == 2)">Trung bình</option>
                        <option value="3" selected="@(selectedLevel == 3)">Khó</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold text-muted small">Tìm kiếm</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 rounded-start-4">
                            <i class="fa fa-search text-muted"></i>
                        </span>
                        <input type="text"
                               name="keyword"
                               value="@keyword"
                               class="form-control border-start-0 rounded-end-4"
                               placeholder="Nhập ID, nội dung câu hỏi..." />
                    </div>
                </div>

                <div class="col-12 d-flex flex-wrap gap-2 pt-1">
                    <button type="submit" class="btn btn-success rounded-4 px-4 fw-bold" style="background-color:#005b33;">
                        <i class="fa fa-filter me-1"></i> Lọc dữ liệu
                    </button>
                    <a href="/Admin/Questions" class="btn btn-outline-secondary rounded-4 px-4 fw-bold">
                        <i class="fa fa-rotate-right me-1"></i> Làm mới
                    </a>

                    <div class="ms-auto">
                        <select id="pageSizeSelect" class="form-select rounded-4">
                            <option value="10" selected="@(pageSize == 10)">10 / trang</option>
                            <option value="20" selected="@(pageSize == 20)">20 / trang</option>
                            <option value="50" selected="@(pageSize == 50)">50 / trang</option>
                        </select>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead style="background-color:#f8fafc;">
                    <tr class="text-uppercase text-muted small">
                        <th class="ps-4" style="width:80px;">ID</th>
                        <th style="min-width:180px;">Môn học</th>
                        <th style="min-width:420px;">Nội dung câu hỏi</th>
                        <th style="width:130px;">Loại</th>
                        <th style="width:110px;">Mức độ</th>
                        <th style="width:140px;">Đáp án</th>
                        <th style="min-width:170px;">Người tạo</th>
                        <th style="width:130px;">Ngày tạo</th>
                        <th class="text-end pe-4" style="width:130px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted">
                                Chưa có câu hỏi nào phù hợp.
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-secondary">#Q@item.QuestionId</td>

                            <td>
                                <span class="badge rounded-pill px-3 py-2"
                                      style="background:#eef6ff; color:#2563eb; border:1px solid #bfdbfe;">
                                    @item.Subject.SubjectName
                                </span>
                            </td>

                            <td>
                                <div class="fw-semibold text-dark" style="max-width:520px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"
                                     title="@item.Content">
                                    @item.Content
                                </div>
                            </td>

                            <td>
                                @if (item.QuestionType == 1)
                                {
                                    <span class="badge rounded-pill px-3 py-2"
                                          style="background:#f3f4f6; color:#6b7280; border:1px solid #e5e7eb;">
                                        <i class="fa fa-circle-check me-1"></i> Trắc nghiệm
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill px-3 py-2"
                                          style="background:#fff7ed; color:#c2410c; border:1px solid #fdba74;">
                                        <i class="fa fa-briefcase me-1"></i> Tự luận
                                    </span>
                                }
                            </td>

                            <td>
                                @{
                                    var levelText = item.Level switch
                                    {
                                        1 => "Dễ",
                                        2 => "TB",
                                        3 => "Khó",
                                        _ => "-"
                                    };

                                    var levelStyle = item.Level switch
                                    {
                                        1 => "background:#ecfdf5;color:#059669;border:1px solid #a7f3d0;",
                                        2 => "background:#eff6ff;color:#2563eb;border:1px solid #bfdbfe;",
                                        3 => "background:#fef2f2;color:#dc2626;border:1px solid #fecaca;",
                                        _ => "background:#f3f4f6;color:#6b7280;border:1px solid #e5e7eb;"
                                    };
                                }
                                <span class="badge rounded-pill px-3 py-2" style="@levelStyle">
                                    @levelText
                                </span>
                            </td>

                            <td class="fw-semibold text-success">
                                @(string.IsNullOrWhiteSpace(item.CorrectAnswer) ? "-" : item.CorrectAnswer)
                            </td>

                            <td class="text-muted">
                                @(item.CreatedByUser?.FullName ?? "Chưa rõ")
                            </td>

                            <td class="text-muted">
                                @(item.CreatedAt?.ToString("dd/MM/yyyy") ?? "-")
                            </td>

                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a href="/Admin/Questions/Edit/@item.QuestionId"
                                       class="btn btn-sm btn-outline-warning"
                                       title="Chỉnh sửa">
                                        <i class="fa fa-pen"></i>
                                    </a>

                                    <a href="/Admin/Questions/Delete/@item.QuestionId"
                                       class="btn btn-sm btn-outline-danger"
                                       title="Xóa">
                                        <i class="fa fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 px-4 py-3 border-top bg-white">
            <div class="text-muted">
                Hiển thị
                <strong>@((currentPage - 1) * pageSize + (Model.Any() ? 1 : 0))</strong>
                đến
                <strong>@((currentPage - 1) * pageSize + Model.Count())</strong>
                trong số
                <strong>@totalItems</strong> câu hỏi
            </div>

            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new {
                               page = currentPage - 1,
                               pageSize = pageSize,
                               keyword = keyword,
                               subjectId = selectedSubjectId,
                               questionType = selectedQuestionType,
                               level = selectedLevel
                           })">«</a>
                    </li>

                    @{
                        int startPage = Math.Max(1, currentPage - 2);
                        int endPage = Math.Min(totalPages, currentPage + 2);
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new {
                                   page = i,
                                   pageSize = pageSize,
                                   keyword = keyword,
                                   subjectId = selectedSubjectId,
                                   questionType = selectedQuestionType,
                                   level = selectedLevel
                               })">@i</a>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages || totalPages == 0 ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new {
                               page = currentPage + 1,
                               pageSize = pageSize,
                               keyword = keyword,
                               subjectId = selectedSubjectId,
                               questionType = selectedQuestionType,
                               level = selectedLevel
                           })">»</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <form action="/Admin/Questions/Import" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="modal-header text-white" style="background-color: #005b33; border-radius: 1rem 1rem 0 0;">
                    <h5 class="modal-title fw-bold">
                        <i class="fa fa-file-excel me-2"></i> Import ngân hàng câu hỏi
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Chọn môn học</label>
                        <select name="subjectId" asp-items="ViewBag.SubjectList" class="form-select bg-light" required>
                            <option value="">-- Chọn môn học --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Chọn tệp tin Excel (.xlsx)</label>
                        <input type="file" name="fileExcel" class="form-control bg-light" accept=".xlsx" required />
                    </div>

                    <div class="alert alert-light border mt-3 small mb-0">
                        <strong>Cấu trúc cột:</strong><br />
                        1.Nội dung | 2.Loại (1=TN, 2=TL)<br />
                        3.Đáp án A | 4.Đáp án B | 5.Đáp án C | 6.Đáp án D<br />
                        7.Đáp án đúng / Gợi ý đáp án
                        <hr class="my-2" />
                        <strong>Lưu ý:</strong><br />
                        - Không cần cột môn học trong file Excel.<br />
                        - Môn học sẽ lấy theo lựa chọn ở phía trên.<br />
                        - Câu trắc nghiệm: đáp án đúng chỉ nhập A/B/C/D.<br />
                        - Câu tự luận: để trống các cột A-D, nhập gợi ý đáp án ở cột 7.
                    </div>
                </div>

                <div class="modal-footer d-flex justify-content-between bg-light border-top-0 rounded-bottom-4">
                    <a href="/Admin/Questions/DownloadTemplate" class="btn btn-outline-success fw-bold">
                        <i class="fa fa-download"></i> Tải file mẫu
                    </a>
                    <div>
                        <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success fw-bold" style="background-color: #005b33;">
                            Xác nhận Import
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("btnExport").addEventListener("click", function () {
            const subjectId = document.getElementById("subjectId")?.value || "";
            const keyword = document.querySelector('input[name="keyword"]')?.value || "";
            const questionType = document.querySelector('select[name="questionType"]')?.value || "";
            const level = document.querySelector('select[name="level"]')?.value || "";

            let url = "/Admin/Questions/Export?";
            const params = new URLSearchParams();

            if (subjectId) params.append("subjectId", subjectId);
            if (keyword) params.append("keyword", keyword);
            if (questionType) params.append("questionType", questionType);
            if (level) params.append("level", level);

            window.location.href = url + params.toString();
        });

        document.getElementById("pageSizeSelect").addEventListener("change", function () {
            const params = new URLSearchParams(window.location.search);
            params.set("pageSize", this.value);
            params.set("page", "1");
            window.location.href = "/Admin/Questions?" + params.toString();
        });
    </script>
}