@model IEnumerable<VNUFLearning.Models.Question>

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Ngân hàng câu hỏi";

    var selectedQuestionType = ViewBag.QuestionType as int?;
    var selectedLevel = ViewBag.Level as int?;
    var keyword = ViewBag.Keyword as string;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
    int? selectedSubjectId = ViewBag.SubjectId as int?;
}

<div class="container-fluid mt-2">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-1" style="color:#005b33;">
                <i class="fa fa-database me-2"></i>Quản lý Ngân hàng câu hỏi
            </h3>
            <p class="text-muted mb-0">
                Quản lý kho dữ liệu câu hỏi của toàn bộ môn học trong hệ thống.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a id="btnExport" class="btn btn-light border fw-bold px-4 rounded-4" style="cursor:pointer;">
                <i class="fa fa-file-export me-2 text-secondary"></i> Xuất Excel
            </a>

            <button class="btn btn-light border fw-bold px-4 rounded-4 text-primary"
                    data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="fa fa-file-import me-2"></i> Import Excel
            </button>

            <a href="/Admin/Questions/Create" class="btn btn-success fw-bold px-4 rounded-4" style="background-color:#16a34a; border:none;">
                <i class="fa fa-plus me-2"></i> Thêm câu hỏi
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 shadow-sm border-0">
            <i class="fa fa-circle-check me-2"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 shadow-sm border-0">
            <i class="fa fa-triangle-exclamation me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" action="/Admin/Questions" class="row g-3 align-items-end">
                <input type="hidden" name="pageSize" value="@pageSize" />

                <div class="col-md-3">
                    <label class="form-label fw-semibold text-muted small">Lọc theo Môn học</label>
                    <select id="subjectId" name="subjectId" asp-items="ViewBag.SubjectList" class="form-select rounded-4">
                        <option value="">Tất cả môn học</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold text-muted small">Loại câu hỏi</label>
                    <select name="questionType" class="form-select rounded-4">
                        <option value="">Tất cả loại</option>
                        <option value="1" selected="@(selectedQuestionType == 1)">Trắc nghiệm</option>
                        <option value="2" selected="@(selectedQuestionType == 2)">Tự luận</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold text-muted small">Mức độ</label>
                    <select name="level" class="form-select rounded-4">
                        <option value="">Tất cả mức</option>
                        <option value="1" selected="@(selectedLevel == 1)">Dễ</option>
                        <option value="2" selected="@(selectedLevel == 2)">Trung bình</option>
                        <option value="3" selected="@(selectedLevel == 3)">Khó</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold text-muted small">Tìm kiếm</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 rounded-start-4">
                            <i class="fa fa-search text-muted"></i>
                        </span>
                        <input type="text"
                               name="keyword"
                               value="@keyword"
                               class="form-control border-start-0 rounded-end-4"
                               placeholder="Nhập ID, nội dung câu hỏi..." />
                    </div>
                </div>

                <div class="col-12 d-flex flex-wrap gap-2 pt-1">
                    <button type="submit" class="btn btn-success rounded-4 px-4 fw-bold" style="background-color:#005b33;">
                        <i class="fa fa-filter me-1"></i> Lọc dữ liệu
                    </button>
                    <a href="/Admin/Questions" class="btn btn-outline-secondary rounded-4 px-4 fw-bold">
                        <i class="fa fa-rotate-right me-1"></i> Làm mới
                    </a>

                    <div class="ms-auto">
                        <select id="pageSizeSelect" class="form-select rounded-4">
                            <option value="10" selected="@(pageSize == 10)">10 / trang</option>
                            <option value="20" selected="@(pageSize == 20)">20 / trang</option>
                            <option value="50" selected="@(pageSize == 50)">50 / trang</option>
                        </select>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead style="background-color:#f8fafc;">
                    <tr class="text-uppercase text-muted small">
                        <th class="ps-4" style="width:80px;">ID</th>
                        <th style="min-width:180px;">Môn học</th>
                        <th style="min-width:300px; width:32%;">Nội dung câu hỏi</th>
                        <th style="width:130px;">Loại</th>
                        <th style="width:110px;">Mức độ</th>
                        <th style="min-width:260px; width:22%;">Đáp án</th>
                        <th style="min-width:170px;">Người tạo</th>
                        <th style="width:130px;">Ngày tạo</th>
                        <th class="text-end pe-4" style="width:170px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted">
                                Chưa có câu hỏi nào phù hợp.
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-secondary">#Q@item.QuestionId</td>

                            <td>
                                <span class="badge rounded-pill px-3 py-2"
                                      style="background:#eef6ff; color:#2563eb; border:1px solid #bfdbfe;">
                                    @item.Subject.SubjectName
                                </span>
                            </td>

                            <td>
                                <div class="fw-semibold text-dark" style="max-width:380px; white-space:normal; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;"
                                     title="@item.Content">
                                    @item.Content
                                </div>
                            </td>

                            <td>
                                @if (item.QuestionType == 1)
                                {
                                    <span class="badge rounded-pill px-3 py-2"
                                          style="background:#f3f4f6; color:#6b7280; border:1px solid #e5e7eb;">
                                        <i class="fa fa-circle-check me-1"></i> Trắc nghiệm
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill px-3 py-2"
                                          style="background:#fff7ed; color:#c2410c; border:1px solid #fdba74;">
                                        <i class="fa fa-briefcase me-1"></i> Tự luận
                                    </span>
                                }
                            </td>

                            <td>
                                @{
                                    var levelText = item.Level switch
                                    {
                                        1 => "Dễ",
                                        2 => "TB",
                                        3 => "Khó",
                                        _ => "-"
                                    };

                                    var levelStyle = item.Level switch
                                    {
                                        1 => "background:#ecfdf5;color:#059669;border:1px solid #a7f3d0;",
                                        2 => "background:#eff6ff;color:#2563eb;border:1px solid #bfdbfe;",
                                        3 => "background:#fef2f2;color:#dc2626;border:1px solid #fecaca;",
                                        _ => "background:#f3f4f6;color:#6b7280;border:1px solid #e5e7eb;"
                                    };
                                }
                                <span class="badge rounded-pill px-3 py-2" style="@levelStyle">
                                    @levelText
                                </span>
                            </td>

                            <td class="fw-semibold text-success" style="min-width:260px;">
                                <div style="max-width:320px; white-space:normal; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;"
                                     title="@item.CorrectAnswer">
                                    @(string.IsNullOrWhiteSpace(item.CorrectAnswer) ? "-" : item.CorrectAnswer)
                                </div>
                            </td>

                            <td class="text-muted">
                                @(item.CreatedByUser?.FullName ?? "Chưa rõ")
                            </td>

                            <td class="text-muted">
                                @(item.CreatedAt?.ToString("dd/MM/yyyy") ?? "-")
                            </td>

                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-info"
                                            title="Xem chi tiết"
                                            data-bs-toggle="modal"
                                            data-bs-target="#detailQuestionModal-@item.QuestionId">
                                        <i class="fa fa-eye"></i>
                                    </button>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-warning"
                                            title="Chỉnh sửa"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editQuestionModal-@item.QuestionId">
                                        <i class="fa fa-pen"></i>
                                    </button>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            title="Xóa"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteQuestionModal-@item.QuestionId">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>

                        <div class="modal fade" id="detailQuestionModal-@item.QuestionId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                                <div class="modal-content border-0 rounded-4 shadow">
                                    <div class="modal-header bg-light">
                                        <div>
                                            <h5 class="modal-title fw-bold">Chi tiết câu hỏi #Q@item.QuestionId</h5>
                                            <div class="text-muted small">@item.Subject.SubjectName</div>
                                        </div>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <dl class="row mb-0">
                                            <dt class="col-sm-3">Nội dung</dt>
                                            <dd class="col-sm-9">@item.Content</dd>

                                            <dt class="col-sm-3">Loại câu hỏi</dt>
                                            <dd class="col-sm-9">@(item.QuestionType == 1 ? "Trắc nghiệm" : "Tự luận")</dd>

                                            <dt class="col-sm-3">Mức độ</dt>
                                            <dd class="col-sm-9">@levelText</dd>

                                            <dt class="col-sm-3">Chương / Chủ đề</dt>
                                            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(item.Chapter) ? "-" : item.Chapter)</dd>

                                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                            {
                                                <dt class="col-sm-3">Ảnh minh họa</dt>
                                                <dd class="col-sm-9">
                                                    <a href="@item.ImageUrl" target="_blank" rel="noopener">Mở ảnh</a>
                                                </dd>
                                            }

                                            @if (item.QuestionType == 1)
                                            {
                                                <dt class="col-sm-3">Đáp án A</dt>
                                                <dd class="col-sm-9">@item.OptionA</dd>
                                                <dt class="col-sm-3">Đáp án B</dt>
                                                <dd class="col-sm-9">@item.OptionB</dd>
                                                <dt class="col-sm-3">Đáp án C</dt>
                                                <dd class="col-sm-9">@item.OptionC</dd>
                                                <dt class="col-sm-3">Đáp án D</dt>
                                                <dd class="col-sm-9">@item.OptionD</dd>
                                            }

                                            <dt class="col-sm-3">Đáp án đúng / mẫu</dt>
                                            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(item.CorrectAnswer) ? "-" : item.CorrectAnswer)</dd>

                                            <dt class="col-sm-3">Giải thích</dt>
                                            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(item.Explaination) ? "-" : item.Explaination)</dd>

                                            <dt class="col-sm-3">Người tạo</dt>
                                            <dd class="col-sm-9">@(item.CreatedByUser?.FullName ?? "Chưa rõ")</dd>

                                            <dt class="col-sm-3">Ngày tạo</dt>
                                            <dd class="col-sm-9">@(item.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
                                        </dl>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-outline-secondary rounded-4" data-bs-dismiss="modal">Đóng</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="modal fade" id="editQuestionModal-@item.QuestionId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                                <div class="modal-content border-0 rounded-4 shadow">
                                    <form action="/Admin/Questions/Edit/@item.QuestionId" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="QuestionId" value="@item.QuestionId" />
                                        <input type="hidden" name="CreatedByUserId" value="@item.CreatedByUserId" />
                                        <input type="hidden" name="CreatedAt" value="@item.CreatedAt?.ToString("O")" />
                                        <input type="hidden" name="IsActive" value="@item.IsActive.ToString()" />

                                        <div class="modal-header text-white" style="background:#005b33;">
                                            <h5 class="modal-title fw-bold">
                                                <i class="fa fa-pen me-2"></i>Chỉnh sửa câu hỏi #Q@item.QuestionId
                                            </h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>

                                        <div class="modal-body p-4">
                                            <div class="row g-4">
                                                <div class="col-md-8">
                                                    <label class="form-label fw-bold">Nội dung câu hỏi</label>
                                                    <textarea name="Content" class="form-control" rows="4" required>@item.Content</textarea>
                                                </div>

                                                <div class="col-md-4">
                                                    <label class="form-label fw-bold">Môn học</label>
                                                    <select name="SubjectId" class="form-select" required>
                                                        @foreach (Microsoft.AspNetCore.Mvc.Rendering.SelectListItem subject in ViewBag.SubjectList)
                                                        {
                                                            <option value="@subject.Value" selected="@(subject.Value == item.SubjectId.ToString())">@subject.Text</option>
                                                        }
                                                    </select>
                                                </div>

                                                <div class="col-md-4">
                                                    <label class="form-label fw-bold">Loại câu hỏi</label>
                                                    <select name="QuestionType" class="form-select question-type-select" data-target="#adminOptions-@item.QuestionId">
                                                        <option value="1" selected="@(item.QuestionType == 1)">Trắc nghiệm</option>
                                                        <option value="2" selected="@(item.QuestionType == 2)">Tự luận</option>
                                                    </select>
                                                </div>

                                                <div class="col-md-4">
                                                    <label class="form-label fw-bold">Mức độ</label>
                                                    <select name="Level" class="form-select">
                                                        <option value="1" selected="@(item.Level == 1)">Dễ</option>
                                                        <option value="2" selected="@(item.Level == 2)">Trung bình</option>
                                                        <option value="3" selected="@(item.Level == 3)">Khó</option>
                                                    </select>
                                                </div>

                                                <div class="col-md-4">
                                                    <label class="form-label fw-bold">Chương / Chủ đề</label>
                                                    <input name="Chapter" class="form-control" value="@item.Chapter" />
                                                </div>

                                                <div class="col-md-12">
                                                    <label class="form-label fw-bold">Ảnh minh họa URL</label>
                                                    <input name="ImageUrl" class="form-control" value="@item.ImageUrl" />
                                                </div>

                                                <div id="adminOptions-@item.QuestionId" class="row g-4 question-options">
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-bold">Đáp án A</label>
                                                        <input name="OptionA" class="form-control" value="@item.OptionA" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-bold">Đáp án B</label>
                                                        <input name="OptionB" class="form-control" value="@item.OptionB" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-bold">Đáp án C</label>
                                                        <input name="OptionC" class="form-control" value="@item.OptionC" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-bold">Đáp án D</label>
                                                        <input name="OptionD" class="form-control" value="@item.OptionD" />
                                                    </div>
                                                </div>

                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Đáp án đúng / Gợi ý đáp án</label>
                                                    <input name="CorrectAnswer" class="form-control" value="@item.CorrectAnswer" />
                                                </div>

                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Giải thích</label>
                                                    <input name="Explaination" class="form-control" value="@item.Explaination" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="modal-footer bg-light">
                                            <button type="button" class="btn btn-outline-secondary rounded-4" data-bs-dismiss="modal">Hủy</button>
                                            <button type="submit" class="btn btn-success rounded-4 fw-bold">
                                                <i class="fa fa-save me-1"></i>Lưu thay đổi
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="modal fade" id="deleteQuestionModal-@item.QuestionId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-0 rounded-4 shadow">
                                    <div class="modal-header bg-danger text-white">
                                        <h5 class="modal-title fw-bold">
                                            <i class="fa fa-triangle-exclamation me-2"></i>Xác nhận xóa câu hỏi
                                        </h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p class="mb-2">Bạn có chắc chắn muốn xóa câu hỏi <strong>#Q@item.QuestionId</strong>?</p>
                                        <div class="p-3 rounded-3 bg-light text-muted small" style="max-height:120px; overflow:auto;">
                                            @item.Content
                                        </div>
                                    </div>
                                    <div class="modal-footer bg-light">
                                        <button type="button" class="btn btn-outline-secondary rounded-4" data-bs-dismiss="modal">Hủy</button>
                                        <form action="/Admin/Questions/Delete/@item.QuestionId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger rounded-4 fw-bold">
                                                <i class="fa fa-trash me-1"></i>Xóa câu hỏi
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 px-4 py-3 border-top bg-white">
            <div class="text-muted">
                Hiển thị
                <strong>@((currentPage - 1) * pageSize + (Model.Any() ? 1 : 0))</strong>
                đến
                <strong>@((currentPage - 1) * pageSize + Model.Count())</strong>
                trong số
                <strong>@totalItems</strong> câu hỏi
            </div>

            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new {
                               page = currentPage - 1,
                               pageSize = pageSize,
                               keyword = keyword,
                               subjectId = selectedSubjectId,
                               questionType = selectedQuestionType,
                               level = selectedLevel
                           })">«</a>
                    </li>

                    @{
                        int startPage = Math.Max(1, currentPage - 2);
                        int endPage = Math.Min(totalPages, currentPage + 2);
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new {
                                   page = i,
                                   pageSize = pageSize,
                                   keyword = keyword,
                                   subjectId = selectedSubjectId,
                                   questionType = selectedQuestionType,
                                   level = selectedLevel
                               })">@i</a>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages || totalPages == 0 ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new {
                               page = currentPage + 1,
                               pageSize = pageSize,
                               keyword = keyword,
                               subjectId = selectedSubjectId,
                               questionType = selectedQuestionType,
                               level = selectedLevel
                           })">»</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <form action="/Admin/Questions/Import" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="modal-header text-white" style="background-color: #005b33; border-radius: 1rem 1rem 0 0;">
                    <h5 class="modal-title fw-bold">
                        <i class="fa fa-file-excel me-2"></i> Import ngân hàng câu hỏi
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Chọn môn học</label>
                        <select name="subjectId" asp-items="ViewBag.SubjectList" class="form-select bg-light" required>
                            <option value="">-- Chọn môn học --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Chọn tệp tin Excel (.xlsx)</label>
                        <input type="file" name="fileExcel" class="form-control bg-light" accept=".xlsx" required />
                    </div>

                    <div class="alert alert-light border mt-3 small mb-0">
                        <strong>Cấu trúc cột:</strong><br />
                        1.Nội dung | 2.Loại (1=TN, 2=TL)<br />
                        3.Đáp án A | 4.Đáp án B | 5.Đáp án C | 6.Đáp án D<br />
                        7.Đáp án đúng / Gợi ý đáp án
                        <hr class="my-2" />
                        <strong>Lưu ý:</strong><br />
                        - Không cần cột môn học trong file Excel.<br />
                        - Môn học sẽ lấy theo lựa chọn ở phía trên.<br />
                        - Câu trắc nghiệm: đáp án đúng chỉ nhập A/B/C/D.<br />
                        - Câu tự luận: để trống các cột A-D, nhập gợi ý đáp án ở cột 7.
                    </div>
                </div>

                <div class="modal-footer d-flex justify-content-between bg-light border-top-0 rounded-bottom-4">
                    <a href="/Admin/Questions/DownloadTemplate" class="btn btn-outline-success fw-bold">
                        <i class="fa fa-download"></i> Tải file mẫu
                    </a>
                    <div>
                        <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success fw-bold" style="background-color: #005b33;">
                            Xác nhận Import
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("btnExport").addEventListener("click", function () {
            const subjectId = document.getElementById("subjectId")?.value || "";
            const keyword = document.querySelector('input[name="keyword"]')?.value || "";
            const questionType = document.querySelector('select[name="questionType"]')?.value || "";
            const level = document.querySelector('select[name="level"]')?.value || "";

            let url = "/Admin/Questions/Export?";
            const params = new URLSearchParams();

            if (subjectId) params.append("subjectId", subjectId);
            if (keyword) params.append("keyword", keyword);
            if (questionType) params.append("questionType", questionType);
            if (level) params.append("level", level);

            window.location.href = url + params.toString();
        });

        document.getElementById("pageSizeSelect").addEventListener("change", function () {
            const params = new URLSearchParams(window.location.search);
            params.set("pageSize", this.value);
            params.set("page", "1");
            window.location.href = "/Admin/Questions?" + params.toString();
        });

        function toggleQuestionOptions(select) {
            const target = document.querySelector(select.dataset.target);
            if (!target) return;

            target.style.display = select.value === "1" ? "flex" : "none";
        }

        document.querySelectorAll(".question-type-select").forEach(select => {
            toggleQuestionOptions(select);
            select.addEventListener("change", () => toggleQuestionOptions(select));
        });
    </script>
}
