@model VNUFLearning.Models.Question

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Xóa câu hỏi";
}

<div class="container-fluid mt-2">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="alert alert-danger rounded-4">
                <h4 class="fw-bold">
                    <i class="fa fa-triangle-exclamation me-2"></i> Xác nhận xóa câu hỏi
                </h4>
                <p class="mb-0">
                    Bạn có chắc chắn muốn xóa câu hỏi này khỏi môn
                    <strong>@Model.Subject.SubjectName</strong>?
                </p>
            </div>

            <div class="border rounded-4 p-4 bg-light">
                <h5 class="fw-bold mb-3">@Model.Content</h5>
                <p class="text-muted mb-0">
                    Loại: @(Model.QuestionType == 1 ? "Trắc nghiệm" : "Tự luận")
                </p>
            </div>

            <form action="/Admin/Questions/Delete/@Model.QuestionId" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <input asp-for="QuestionId" type="hidden" />

                <button type="submit" class="btn btn-danger px-4">
                    <i class="fa fa-trash me-1"></i> Xóa ngay
                </button>

                <a href="/Admin/Questions" class="btn btn-outline-secondary px-4">
                    <i class="fa fa-arrow-left me-1"></i> Hủy bỏ
                </a>
            </form>
        </div>
    </div>
</div>