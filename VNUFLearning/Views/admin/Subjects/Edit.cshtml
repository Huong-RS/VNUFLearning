@model VNUFLearning.Models.Subject

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Chỉnh sửa môn học";
}

<div class="container-fluid mt-2">
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">
            <i class="fa fa-pen text-success me-2"></i> Chỉnh sửa môn học
        </h3>
        <p class="text-muted small">Cập nhật thông tin học phần.</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <form asp-action="Edit" asp-route-id="@Model.SubjectId" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input asp-for="SubjectId" type="hidden" />
                <input asp-for="CoverImageUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label asp-for="SubjectCode" class="form-label fw-bold">Mã học phần</label>
                        <input asp-for="SubjectCode" class="form-control" />
                        <span asp-validation-for="SubjectCode" class="text-danger small"></span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="SubjectName" class="form-label fw-bold">Tên môn học</label>
                        <input asp-for="SubjectName" class="form-control" />
                        <span asp-validation-for="SubjectName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Credits" class="form-label fw-bold">Số tín chỉ</label>
                        <input asp-for="Credits" type="number" min="1" max="10" class="form-control" />
                        <span asp-validation-for="Credits" class="text-danger small"></span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="DepartmentName" class="form-label fw-bold">Khoa / Viện quản lý</label>
                        <input asp-for="DepartmentName" class="form-control" />
                        <span asp-validation-for="DepartmentName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Ảnh bìa hiện tại</label>
                        <div class="mb-2">
                            <img src="@(string.IsNullOrWhiteSpace(Model.CoverImageUrl) ? "/images/default-subject.jpg" : Model.CoverImageUrl)"
                                 style="width:220px;height:120px;object-fit:cover;"
                                 class="rounded-3 border" />
                        </div>

                        <input type="file" name="coverImage" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                        <div class="form-text">Chọn ảnh mới nếu muốn thay đổi ảnh bìa.</div>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label fw-bold">
                                Môn học đang hoạt động
                            </label>
                        </div>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="fa fa-save me-1"></i> Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="fa fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}