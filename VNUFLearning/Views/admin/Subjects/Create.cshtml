@model VNUFLearning.Models.Subject

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Thêm môn học";
}

<div class="container-fluid mt-2">
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">
            <i class="fa fa-book-medical text-success me-2"></i> Thêm môn học mới
        </h3>
        <p class="text-muted small">Tạo mới học phần, cấu hình mã môn, tín chỉ, khoa/viện và ảnh bìa.</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label asp-for="SubjectCode" class="form-label fw-bold">Mã học phần</label>
                        <input asp-for="SubjectCode" class="form-control" placeholder="Ví dụ: IT3020" />
                        <span asp-validation-for="SubjectCode" class="text-danger small"></span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="SubjectName" class="form-label fw-bold">Tên môn học</label>
                        <input asp-for="SubjectName" class="form-control" placeholder="Ví dụ: Lập trình Web" />
                        <span asp-validation-for="SubjectName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Credits" class="form-label fw-bold">Số tín chỉ</label>
                        <input asp-for="Credits" type="number" min="1" max="10" class="form-control" placeholder="Ví dụ: 3" />
                        <span asp-validation-for="Credits" class="text-danger small"></span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="DepartmentName" class="form-label fw-bold">Khoa / Viện quản lý</label>
                        <input asp-for="DepartmentName" class="form-control" placeholder="Ví dụ: Khoa CNTT" />
                        <span asp-validation-for="DepartmentName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Giảng viên phụ trách</label>

                        <div class="border rounded-4 p-3 bg-light" style="max-height: 220px; overflow-y: auto;">
                            @if (ViewBag.Teachers != null)
                            {
                                foreach (var teacher in ViewBag.Teachers)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="selectedTeacherIds"
                                               value="@teacher.UserId"
                                               id="teacher_@teacher.UserId" />

                                        <label class="form-check-label" for="teacher_@teacher.UserId">
                                            <span class="fw-bold">@teacher.FullName</span>
                                            <span class="text-muted">(@teacher.StudentCode)</span>
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted">Chưa có giảng viên nào trong hệ thống.</div>
                            }
                        </div>

                        <div class="form-text">
                            Có thể chọn một hoặc nhiều giảng viên phụ trách môn học.
                        </div>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Ảnh bìa môn học</label>
                        <input type="file" name="coverImage" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                        <div class="form-text">Có thể bỏ trống, hệ thống sẽ dùng ảnh mặc định.</div>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Nhập mô tả ngắn cho môn học..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="fa fa-save me-1"></i> Lưu lại
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="fa fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}