@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Dashboard Admin";
}

<style>
    .admin-hero {
        border-radius: 28px;
        padding: 42px;
        color: white;
        background: linear-gradient(135deg,#046c3a 0%, #10b981 100%);
        position: relative;
        overflow: hidden;
        box-shadow: 0 12px 30px rgba(0,0,0,.08);
    }

        .admin-hero:before {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            right: -60px;
            bottom: -120px;
            background: rgba(255,255,255,.08);
        }

        .admin-hero:after {
            content: "";
            position: absolute;
            width: 140px;
            height: 140px;
            border-radius: 24px;
            right: 60px;
            bottom: -20px;
            background: rgba(255,255,255,.07);
        }

        .admin-hero h2 {
            font-size: 46px;
            font-weight: 800;
            margin-bottom: 16px;
            position: relative;
            z-index: 2;
        }

        .admin-hero p {
            font-size: 25px;
            max-width: 900px;
            margin: 0;
            position: relative;
            z-index: 2;
            opacity: .95;
        }

    .dash-card {
        border: 0;
        border-radius: 28px;
        background: #fff;
        box-shadow: 0 8px 24px rgba(0,0,0,.06);
        padding: 28px;
        height: 100%;
        transition: .25s;
    }

        .dash-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(0,0,0,.08);
        }

    .dash-label {
        font-size: 15px;
        font-weight: 700;
        color: #94a3b8;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .dash-value {
        font-size: 58px;
        font-weight: 800;
        line-height: 1;
        color: #0f172a;
        margin-bottom: 18px;
    }

    .dash-mini {
        font-size: 18px;
        color: #64748b;
    }

    .dash-icon {
        width: 78px;
        height: 78px;
        border-radius: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
    }

    .soft-blue {
        background: #dbeafe;
        color: #2563eb;
    }

    .soft-green {
        background: #dcfce7;
        color: #16a34a;
    }

    .soft-yellow {
        background: #fef3c7;
        color: #d97706;
    }

    .soft-red {
        background: #fee2e2;
        color: #dc2626;
    }

    .panel-card {
        border: 0;
        border-radius: 28px;
        background: #fff;
        box-shadow: 0 8px 24px rgba(0,0,0,.06);
        overflow: hidden;
        height: 100%;
    }

    .panel-head {
        padding: 28px 32px;
        border-bottom: 1px solid #edf2f7;
        font-size: 30px;
        font-weight: 800;
        color: #0f172a;
    }

    .quick-btn {
        display: block;
        text-decoration: none;
        padding: 18px 20px;
        border-radius: 18px;
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 14px;
        transition: .2s;
    }

        .quick-btn:hover {
            transform: translateX(5px);
        }

    .btn-soft-green {
        background: #ecfdf5;
        color: #059669;
    }

    .btn-soft-blue {
        background: #eff6ff;
        color: #2563eb;
    }

    .btn-soft-yellow {
        background: #fffbeb;
        color: #d97706;
    }

    .btn-soft-red {
        background: #fef2f2;
        color: #dc2626;
    }

    .activity-table th {
        color: #64748b;
        font-weight: 700;
        font-size: 15px;
        border-bottom: 1px solid #e2e8f0;
        padding: 18px;
    }

    .activity-table td {
        padding: 20px 18px;
        vertical-align: middle;
        font-size: 16px;
    }

    .badge-soft {
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .bg-soft-green {
        background: #dcfce7;
        color: #15803d;
    }

    .bg-soft-blue {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .bg-soft-yellow {
        background: #fef3c7;
        color: #b45309;
    }
</style>

<div class="container-fluid py-3">

    <!-- Banner -->
    <div class="admin-hero mb-4">
        <h2>Chào mừng Quản trị viên trở lại! 👋</h2>
        <p>
            Hệ thống hiện đang hoạt động ổn định.
            Dưới đây là tóm tắt dữ liệu và các luồng nghiệp vụ mới nhất trong ngày hôm nay.
        </p>
    </div>

    <!-- Stats -->
    <div class="row g-4 mb-4">

        <div class="col-md-6 col-xl-3">
            <div class="dash-card">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="dash-label">Tổng sinh viên</div>
                        <div class="dash-value">@ViewBag.TotalStudents</div>
                        <div class="dash-mini text-success fw-bold">
                            <i class="fa fa-arrow-trend-up"></i>
                            +@ViewBag.NewUsersThisWeek sinh viên mới
                        </div>
                    </div>
                    <div class="dash-icon soft-blue">
                        <i class="fa fa-user-graduate"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="dash-card">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="dash-label">Kho câu hỏi</div>
                        <div class="dash-value">@ViewBag.TotalQuestions</div>
                        <div class="dash-mini text-success fw-bold">
                            <i class="fa fa-plus"></i>
                            +@ViewBag.NewQuestionsThisWeek gần đây
                        </div>
                    </div>
                    <div class="dash-icon soft-green">
                        <i class="fa fa-database"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="dash-card">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="dash-label">Tài liệu học tập</div>
                        <div class="dash-value">@ViewBag.TotalDocuments</div>
                        <div class="dash-mini text-success fw-bold">
                            <i class="fa fa-upload"></i>
                            +@ViewBag.NewDocumentsThisWeek tuần này
                        </div>
                    </div>
                    <div class="dash-icon soft-yellow">
                        <i class="fa fa-folder-open"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="dash-card">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="dash-label">Tài khoản bị khóa</div>
                        <div class="dash-value text-danger">@ViewBag.LockedUsers</div>
                        <div class="dash-mini text-muted fw-bold">
                            Tổng tài khoản: @ViewBag.TotalUsers
                        </div>
                    </div>
                    <div class="dash-icon soft-red">
                        <i class="fa fa-user-lock"></i>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Panels -->
    <div class="row g-4">

        <!-- Activity -->
        <div class="col-xl-8">
            <div class="panel-card">
                <div class="panel-head">
                    <i class="fa fa-list-check text-success me-2"></i>
                    Hoạt động gần đây
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0 activity-table">
                        <thead>
                            <tr>
                                <th>Thời gian</th>
                                <th>Người dùng</th>
                                <th>Hành động</th>
                                <th>Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>10 phút trước</td>
                                <td class="fw-bold">Giảng viên</td>
                                <td>
                                    <span class="badge-soft bg-soft-green">Thêm mới</span>
                                </td>
                                <td>Upload tài liệu môn học</td>
                            </tr>

                            <tr>
                                <td>35 phút trước</td>
                                <td class="fw-bold">Sinh viên</td>
                                <td>
                                    <span class="badge-soft bg-soft-blue">Làm bài</span>
                                </td>
                                <td>Nộp bài thi trực tuyến</td>
                            </tr>

                            <tr>
                                <td>2 giờ trước</td>
                                <td class="fw-bold">Admin</td>
                                <td>
                                    <span class="badge-soft bg-soft-yellow">Import</span>
                                </td>
                                <td>Import ngân hàng câu hỏi</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Quick actions -->
        <div class="col-xl-4">
            <div class="panel-card">
                <div class="panel-head">
                    <i class="fa fa-bolt text-warning me-2"></i>
                    Thao tác nhanh
                </div>

                <div class="p-4">

                    <a href="/Admin/Users/Create" class="quick-btn btn-soft-green">
                        <i class="fa fa-user-plus me-2"></i>
                        Cấp tài khoản mới
                    </a>

                    <a href="/Admin/Subjects" class="quick-btn btn-soft-blue">
                        <i class="fa fa-book me-2"></i>
                        Quản lý môn học
                    </a>

                    <a href="/Admin/Questions" class="quick-btn btn-soft-yellow">
                        <i class="fa fa-circle-question me-2"></i>
                        Ngân hàng câu hỏi
                    </a>

                    <a href="/Admin/Documents" class="quick-btn btn-soft-red">
                        <i class="fa fa-folder me-2"></i>
                        Quản lý học liệu
                    </a>

                </div>
            </div>
        </div>

    </div>

</div>