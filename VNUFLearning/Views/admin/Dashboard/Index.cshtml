@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Dashboard Admin";
}
<!-- Custom CSS cho Dashboard -->
<style>
    .stat-card {
        border: none;
        border-radius: 1rem;
        transition: all 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 91, 51, 0.15) !important;
        }

    .icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
</style>

<div class="container-fluid">

    <!-- Lời chào -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="bg-white p-4 rounded-4 shadow-sm border-start border-5 border-success">
                <h4 class="fw-bold text-dark mb-1">Chào mừng Quản trị viên trở lại! 👋</h4>
                <p class="text-muted mb-0">Hôm nay hệ thống hoạt động ổn định. Dưới đây là tóm tắt tình hình dữ liệu.</p>
            </div>
        </div>
    </div>

    <!-- 4 Thẻ Thống kê chính -->
    <div class="row g-4 mb-5">
        <!-- Thẻ 1: Tổng Sinh viên -->
        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card shadow-sm h-100 bg-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted fw-bold mb-1">TỔNG SINH VIÊN</p>
                            <h3 class="fw-bolder text-dark mb-0">1,245</h3>
                        </div>
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="fa fa-user-graduate"></i>
                        </div>
                    </div>
                    <div class="mt-3 text-sm">
                        <span class="text-success fw-bold"><i class="fa fa-arrow-up"></i> 12</span>
                        <span class="text-muted"> sinh viên mới tuần này</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Thẻ 2: Ngân hàng câu hỏi -->
        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card shadow-sm h-100 bg-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted fw-bold mb-1">CÂU HỎI TRONG KHO</p>
                            <h3 class="fw-bolder text-dark mb-0">8,432</h3>
                        </div>
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="fa fa-database"></i>
                        </div>
                    </div>
                    <div class="mt-3 text-sm">
                        <span class="text-success fw-bold"><i class="fa fa-arrow-up"></i> 150</span>
                        <span class="text-muted"> câu được thêm gần đây</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Thẻ 3: Lượt làm bài thi -->
        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card shadow-sm h-100 bg-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted fw-bold mb-1">LƯỢT LÀM BÀI</p>
                            <h3 class="fw-bolder text-dark mb-0">5,021</h3>
                        </div>
                        <div class="icon-circle bg-warning bg-opacity-10 text-warning">
                            <i class="fa fa-laptop-code"></i>
                        </div>
                    </div>
                    <div class="mt-3 text-sm">
                        <span class="text-warning fw-bold"><i class="fa fa-clock"></i> 45</span>
                        <span class="text-muted"> bài thi đang diễn ra</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Thẻ 4: AI Status -->
        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card shadow-sm h-100 bg-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted fw-bold mb-1">TRẠNG THÁI AI GEMINI</p>
                            <h3 class="fw-bolder text-dark mb-0">Online</h3>
                        </div>
                        <div class="icon-circle bg-info bg-opacity-10 text-info">
                            <i class="fa fa-robot"></i>
                        </div>
                    </div>
                    <div class="mt-3 text-sm">
                        <span class="text-success fw-bold"><i class="fa fa-check-circle"></i> Đã kết nối</span>
                        <span class="text-muted"> API hoạt động tốt</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Phân vùng Hoạt động và Cảnh báo -->
    <div class="row g-4">
        <!-- Nhật ký hoạt động gần đây -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="fw-bold text-dark"><i class="fa fa-list-ul text-success me-2"></i>Hoạt động gần đây</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light text-muted">
                                <tr>
                                    <th>Thời gian</th>
                                    <th>Người dùng</th>
                                    <th>Hành động</th>
                                    <th>Chi tiết</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-muted small">10 phút trước</td>
                                    <td class="fw-bold">Giảng viên A</td>
                                    <td><span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Thêm mới</span></td>
                                    <td>Import 50 câu hỏi môn CSDL</td>
                                </tr>
                                <tr>
                                    <td class="text-muted small">35 phút trước</td>
                                    <td class="fw-bold">Sinh viên K67</td>
                                    <td><span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">Làm bài</span></td>
                                    <td>Nộp bài thi Lập trình mạng (9.5đ)</td>
                                </tr>
                                <tr>
                                    <td class="text-muted small">2 giờ trước</td>
                                    <td class="fw-bold">Hệ thống AI</td>
                                    <td><span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">Chấm tự luận</span></td>
                                    <td>Hoàn thành chấm 12 bài thi ảnh chụp</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Logs / Lối tắt -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="fw-bold text-dark"><i class="fa fa-bolt text-warning me-2"></i>Thao tác nhanh</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-3">
                        <a href="/Admin/Users/Create" class="btn btn-outline-success text-start p-3 fw-bold rounded-3">
                            <i class="fa fa-user-plus fs-5 me-2 w-20px"></i> Cấp tài khoản mới
                        </a>
                        <a href="/Admin/Subjects" class="btn btn-outline-primary text-start p-3 fw-bold rounded-3">
                            <i class="fa fa-book fs-5 me-2 w-20px"></i> Quản lý Môn học
                        </a>
                        <a href="/Admin/Questions" class="btn btn-outline-warning text-start p-3 fw-bold rounded-3 text-dark">
                            <i class="fa fa-database fs-5 me-2 w-20px"></i> Kiểm tra Kho câu hỏi
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>