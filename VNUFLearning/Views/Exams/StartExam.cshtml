@model List<VNUFLearning.Models.Question>
@{
    Layout = null;
    var subjectName = ViewBag.SubjectName as string;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Làm bài thi - @subjectName</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }

        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        /* Tùy chỉnh màu xanh VNUF cho Tailwind */
        .text-vnuf {
            color: #005b33;
        }

        .bg-vnuf {
            background-color: #005b33;
        }

        .border-vnuf {
            border-color: #005b33;
        }
    </style>
</head>
<body class="flex h-screen overflow-hidden text-slate-800">

    <main class="flex-1 flex flex-col h-screen relative">
        <!-- HEADER DÍNH -->
        <header class="bg-white shadow-sm z-10">
            <div class="px-6 py-4 flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-slate-800">Bài thi: @subjectName</h2>
                    <p class="text-sm text-slate-500 mt-1"><i class="fas fa-university me-1 text-vnuf"></i> Trường Đại học Lâm Nghiệp</p>
                </div>

                <div class="flex items-center gap-4 bg-slate-50 px-5 py-2 rounded-lg border border-slate-200 shadow-inner">
                    <div class="text-right">
                        <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Thời gian còn lại</p>
                        <p class="text-2xl font-bold text-red-600 tabular-nums" id="timerDisplay">15:00</p>
                    </div>
                    <i class="fas fa-stopwatch text-3xl text-slate-300"></i>
                </div>
            </div>

            <div class="w-full bg-slate-200 h-2">
                <div class="bg-vnuf h-2 transition-all duration-300" id="progressBar" style="width: 0%"></div>
            </div>
            <div class="px-6 py-2 bg-slate-50 border-b border-slate-200 flex justify-between items-center text-sm font-medium text-slate-600">
                <span>Tiến độ hoàn thành: <span id="progressText" class="text-vnuf font-bold">0/@Model.Count</span> câu</span>

                <!-- Nút nộp bài gọi hàm JS để tính thời gian -->
                <button type="button" onclick="processSubmission();" class="bg-vnuf hover:bg-green-800 text-white px-6 py-1.5 rounded-md font-semibold transition-colors shadow-sm">
                    <i class="fas fa-paper-plane me-1"></i> Nộp bài ngay
                </button>
            </div>
        </header>

        <!-- DANH SÁCH CÂU HỎI -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 pb-32 no-scrollbar">

            <form asp-action="SubmitExam" method="post" id="examForm" class="max-w-4xl mx-auto space-y-6">
                <!-- THẺ ẨN LƯU THỜI GIAN LÀM BÀI -->
                <input type="hidden" id="timeTaken" name="timeTaken" value="0" />

                @for (int i = 0; i < Model.Count; i++)
                {
                    var q = Model[i];
                    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 question-card">
                        <div class="flex gap-4 mb-5">
                            <div class="flex-shrink-0">
                                <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-green-100 text-green-800 font-bold text-lg">@(i + 1)</span>
                            </div>
                            <h3 class="text-lg font-semibold text-slate-800 pt-1">@q.Content</h3>
                        </div>

                        <input type="hidden" name="questions[@i].QuestionId" value="@q.QuestionId" />

                        <div class="space-y-3 pl-14">
                            @if (!string.IsNullOrEmpty(q.OptionA))
                            {
                                <label class="block relative cursor-pointer group">
                                    <input type="radio" name="answers[@q.QuestionId]" value="A" class="peer sr-only option-radio" onchange="updateProgress()">
                                    <div class="p-4 rounded-lg border-2 border-slate-200 hover:border-green-300 peer-checked:border-green-600 peer-checked:bg-green-50 transition-all">
                                        <span class="font-bold text-slate-500 mr-2 peer-checked:text-green-700">A.</span><span>@q.OptionA</span>
                                    </div>
                                </label>
                            }
                            @if (!string.IsNullOrEmpty(q.OptionB))
                            {
                                <label class="block relative cursor-pointer group">
                                    <input type="radio" name="answers[@q.QuestionId]" value="B" class="peer sr-only option-radio" onchange="updateProgress()">
                                    <div class="p-4 rounded-lg border-2 border-slate-200 hover:border-green-300 peer-checked:border-green-600 peer-checked:bg-green-50 transition-all">
                                        <span class="font-bold text-slate-500 mr-2 peer-checked:text-green-700">B.</span><span>@q.OptionB</span>
                                    </div>
                                </label>
                            }
                            @if (!string.IsNullOrEmpty(q.OptionC))
                            {
                                <label class="block relative cursor-pointer group">
                                    <input type="radio" name="answers[@q.QuestionId]" value="C" class="peer sr-only option-radio" onchange="updateProgress()">
                                    <div class="p-4 rounded-lg border-2 border-slate-200 hover:border-green-300 peer-checked:border-green-600 peer-checked:bg-green-50 transition-all">
                                        <span class="font-bold text-slate-500 mr-2 peer-checked:text-green-700">C.</span><span>@q.OptionC</span>
                                    </div>
                                </label>
                            }
                            @if (!string.IsNullOrEmpty(q.OptionD))
                            {
                                <label class="block relative cursor-pointer group">
                                    <input type="radio" name="answers[@q.QuestionId]" value="D" class="peer sr-only option-radio" onchange="updateProgress()">
                                    <div class="p-4 rounded-lg border-2 border-slate-200 hover:border-green-300 peer-checked:border-green-600 peer-checked:bg-green-50 transition-all">
                                        <span class="font-bold text-slate-500 mr-2 peer-checked:text-green-700">D.</span><span>@q.OptionD</span>
                                    </div>
                                </label>
                            }
                        </div>
                    </div>
                }
            </form>
        </div>
    </main>

    <script>
        // Sử dụng @Model.Count an toàn vì Controller đã kiểm tra Model null trước khi return View
        const totalQuestions = @Model.Count;
        const totalTimeInSeconds = 900; // 15 phút
        let timeInSeconds = totalTimeInSeconds;
        const timerDisplay = document.getElementById('timerDisplay');

        function updateProgress() {
            const groups = new Set();
            document.querySelectorAll('.option-radio:checked').forEach(input => {
                groups.add(input.name);
            });
            const answered = groups.size;

            if (totalQuestions > 0) {
                const percent = (answered / totalQuestions) * 100;
                document.getElementById('progressBar').style.width = percent + '%';
                document.getElementById('progressText').innerText = answered + '/' + totalQuestions;
            }
        }

        // HÀM XỬ LÝ TRƯỚC KHI NỘP BÀI ĐỂ GHI NHẬN THỜI GIAN
        function processSubmission() {
            const timeTaken = totalTimeInSeconds - timeInSeconds;
            document.getElementById('timeTaken').value = timeTaken;
            document.getElementById('examForm').submit();
        }

        const timer = setInterval(() => {
            if (timeInSeconds <= 0) {
                clearInterval(timer);
                processSubmission(); // Hết giờ tự nộp
                return;
            }
            timeInSeconds--;

            let m = Math.floor(timeInSeconds / 60);
            let s = timeInSeconds % 60;

            m = m < 10 ? '0' + m : m;
            s = s < 10 ? '0' + s : s;

            timerDisplay.innerText = `${m}:${s}`;

            if (timeInSeconds < 60) {
                timerDisplay.classList.add('animate-pulse');
            }
        }, 1000);
    </script>
</body>
</html>