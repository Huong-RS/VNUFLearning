@model IEnumerable<VNUFLearning.Models.Subject>
@{
    ViewData["Title"] = "Khu vực Luyện thi";
    // Bỏ dòng Layout = null đi để nó dùng chung Menu xanh lá
}

<div class="container-fluid mt-2">
    <div class="mb-4">
        <h2 class="fw-bolder" style="color: #005b33;">Khu vực Luyện thi</h2>
        <p class="text-muted">Vui lòng chọn một học phần dưới đây để bắt đầu bài kiểm tra 10 câu ngẫu nhiên.</p>
    </div>

    <div class="row g-4">
        <!-- VÒNG LẶP RENDER MÔN HỌC TỪ DATABASE -->
        @foreach (var subject in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden" style="transition: transform 0.3s;">
                    <!-- Nền xanh lá cho header thẻ -->
                    <div class="p-4 position-relative" style="background: linear-gradient(135deg, #005b33 0%, #008a4e 100%); height: 120px;">
                        <i class="fa fa-laptop-code position-absolute text-white opacity-25" style="font-size: 5rem; right: -10px; bottom: -10px;"></i>
                        <h4 class="fw-bold text-white position-relative z-1 mb-0">@subject.SubjectName</h4>
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <p class="text-muted small mb-4 flex-grow-1">@subject.Description</p>

                        <div class="d-flex justify-content-between mb-4">
                            <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-3 border border-success border-opacity-25">
                                <i class="fa fa-layer-group me-1"></i> 10 câu hỏi
                            </span>
                            <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-3 border border-success border-opacity-25">
                                <i class="fa fa-stopwatch me-1"></i> 15 phút
                            </span>
                        </div>

                        <a asp-action="StartExam" asp-route-subjectId="@subject.SubjectId" class="btn w-100 fw-bold py-2 rounded-3" style="background-color: #e8f5e9; color: #005b33; border: 1px solid #c8e6c9;">
                            Bắt đầu thi <i class="fa fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,91,51,.15) !important;
    }

        .card:hover .btn {
            background-color: #005b33 !important;
            color: white !important;
        }
</style>