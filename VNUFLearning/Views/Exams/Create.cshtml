@{
    // Tự động nhận diện Layout của Admin hoặc Teacher
    Layout = User.IsInRole("Admin") ? "~/Views/Shared/_LayoutAdmin.cshtml" : "~/Views/Shared/_LayoutTeacher.cshtml";
    ViewData["Title"] = "Tạo đề thi mới";
}

<div class="container-fluid mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1" style="color: #005b33;"><i class="fa fa-wand-magic-sparkles me-2"></i>Tạo Đề Thi Trắc Nghiệm</h3>
            <p class="text-muted small">Hệ thống sẽ tự động bốc ngẫu nhiên câu hỏi từ ngân hàng để cấu thành đề thi.</p>
        </div>
        <a href="javascript:history.back()" class="btn btn-outline-secondary fw-bold rounded-pill px-4 shadow-sm">
            <i class="fa fa-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm rounded-3 border-0 bg-danger bg-opacity-10 text-danger fw-bold">
            <i class="fa fa-triangle-exclamation me-2"></i> @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm rounded-3 border-0 bg-success bg-opacity-10 text-success fw-bold">
            <i class="fa fa-check-circle me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="row">
        <div class="col-xl-8 col-lg-10 mx-auto">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header text-white p-3" style="background-color: #005b33;">
                    <h5 class="mb-0 fw-bold"><i class="fa fa-sliders me-2"></i> Cấu hình tham số đề thi</h5>
                </div>
                <div class="card-body p-4 p-md-5 bg-white">
                    
                    <form asp-action="Create" method="post">
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Tên đề thi / Tiêu đề <span class="text-danger">*</span></label>
                            <input type="text" name="examName" class="form-control form-control-lg bg-light" placeholder="VD: Đề thi Giữa kỳ Lập trình Web - Đề số 1" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Lựa chọn Môn học <span class="text-danger">*</span></label>
                            <select name="subjectId" asp-items="ViewBag.SubjectList" class="form-select form-select-lg bg-light" required>
                                <option value="">-- Chọn môn học cần tạo đề --</option>
                            </select>
                            <div class="form-text mt-2 text-muted"><i class="fa fa-info-circle"></i> Đảm bảo môn học này đã có sẵn câu hỏi trong kho.</div>
                        </div>

                        <div class="row g-4 mb-5">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-dark">Thời gian làm bài (Phút) <span class="text-danger">*</span></label>
                                <div class="input-group input-group-lg">
                                    <input type="number" name="duration" class="form-control bg-light" placeholder="VD: 45" min="5" max="180" required>
                                    <span class="input-group-text bg-light text-muted"><i class="fa fa-clock"></i></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-dark">Số lượng câu hỏi (Câu) <span class="text-danger">*</span></label>
                                <div class="input-group input-group-lg">
                                    <input type="number" name="numberOfQuestions" class="form-control bg-light" placeholder="VD: 50" min="1" required>
                                    <span class="input-group-text bg-light text-muted"><i class="fa fa-list-ol"></i></span>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted opacity-25 mb-4">
                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-success btn-lg fw-bold px-5 rounded-pill shadow" style="background-color: #005b33;">
                                <i class="fa fa-cogs me-2"></i> Bắt đầu tự động Sinh đề
                            </button>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>