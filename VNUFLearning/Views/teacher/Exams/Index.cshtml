@model IEnumerable<VNUFLearning.Models.Exam>

@{
    Layout = "~/Views/Shared/_LayoutTeacher.cshtml";
    ViewData["Title"] = "Quản lý đề thi";

    string keyword = ViewBag.Keyword ?? "";
    string status = ViewBag.Status ?? "";
}

<div class="container-fluid py-3">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-2">
                <i class="fa fa-file-lines text-success me-2"></i> Quản lý Đề thi
            </h1>
            <p class="text-muted fs-5 mb-0">
                Thiết lập cấu hình đề thi, theo dõi trạng thái và kiểm soát ngân hàng đề.
            </p>
        </div>

        <div class="d-flex gap-3">
            <button type="button"
                    class="btn btn-light border fw-bold px-4 py-3 rounded-4 shadow-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#importExcelModal">
                <i class="fa fa-file-excel text-success me-2"></i> Import từ Excel
            </button>

            <a href="/Teacher/Exams/Create"
               class="btn btn-success fw-bold px-4 py-3 rounded-4 shadow-sm">
                <i class="fa fa-shuffle me-2"></i> Tạo đề Random
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 fw-bold">
            <i class="fa fa-check-circle me-2"></i>@TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 fw-bold">
            <i class="fa fa-triangle-exclamation me-2"></i>@TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" action="/Teacher/Exams">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label fw-bold text-muted">Tìm kiếm</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white">
                                <i class="fa fa-search text-muted"></i>
                            </span>
                            <input name="keyword"
                                   value="@keyword"
                                   class="form-control"
                                   placeholder="Tìm theo tên đề thi..." />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted">Môn học</label>
                        <select name="subjectId" asp-items="ViewBag.SubjectList" class="form-select">
                            <option value="">Tất cả môn học</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted">Trạng thái</label>
                        <select name="status" class="form-select">
                            <option value="">Tất cả</option>
                            <option value="published" selected="@(status == "published")">Đã công khai</option>
                            <option value="draft" selected="@(status == "draft")">Bản nháp</option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex gap-2">
                        <button class="btn btn-success fw-bold w-100">
                            <i class="fa fa-filter me-1"></i> Lọc
                        </button>
                        <a href="/Teacher/Exams" class="btn btn-outline-secondary fw-bold">
                            <i class="fa fa-rotate-right"></i>
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4 p-5 text-center text-muted">
                    <i class="fa fa-folder-open mb-3" style="font-size:52px;"></i>
                    <h4 class="fw-bold">Chưa có đề thi nào</h4>
                    <p>Hãy tạo đề random hoặc import đề từ Excel để bắt đầu.</p>
                </div>
            </div>
        }

        @foreach (var item in Model)
        {
            var questionCount = item.ExamQuestions?.Count ?? 0;
            var isEmpty = questionCount == 0;

            var examTypeText = item.ExamType == 1
                ? "Chỉ Trắc nghiệm"
                : item.ExamType == 2
                    ? "Chỉ Tự luận"
                    : "Trắc nghiệm + Tự luận AI";

            var headerBg = item.IsPublished
                ? "linear-gradient(135deg,#047857,#10b981)"
                : "linear-gradient(135deg,#334155,#475569)";

            <div class="col-md-6 col-xl-4">
                <div class="exam-card card border-0 shadow-sm rounded-4 h-100 overflow-hidden @(isEmpty ? "border border-danger" : "")">

                    <div class="p-4 text-white position-relative" style="background:@headerBg;">
                        <div class="dropdown position-absolute top-0 end-0 m-3">
                            <button class="btn btn-sm text-white"
                                    type="button"
                                    data-bs-toggle="dropdown">
                                <i class="fa fa-ellipsis-vertical fs-5"></i>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                <li>
                                    <a class="dropdown-item" href="/Teacher/Exams/ManageQuestions/@item.ExamId">
                                        <i class="fa fa-list-check me-2"></i> Quản lý câu hỏi
                                    </a>
                                </li>

                                <li>
                                    <form method="post"
                                          action="/Teacher/Exams/Delete/@item.ExamId"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa đề thi này? Dữ liệu điểm liên quan có thể bị ảnh hưởng.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fa fa-trash me-2"></i> Xóa đề thi
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>

                        <span class="badge bg-white text-success rounded-pill px-3 py-2 mb-3">
                            @item.Subject.SubjectName
                        </span>

                        <h3 class="fw-bold mb-3">@item.Title</h3>

                        <div class="fw-bold">
                            <i class="fa fa-layer-group me-2"></i> @examTypeText
                        </div>
                    </div>

                    <div class="card-body p-4">
                        <div class="row text-center bg-light rounded-4 p-3 mb-4">
                            <div class="col border-end">
                                <div class="fs-2 fw-bold @(isEmpty ? "text-danger" : "text-dark")">@questionCount</div>
                                <div class="small text-muted fw-bold">CÂU HỎI</div>
                            </div>

                            <div class="col border-end">
                                <div class="fs-2 fw-bold">@item.DurationMinutes</div>
                                <div class="small text-muted fw-bold">PHÚT</div>
                            </div>

                            <div class="col">
                                <div class="fs-2 fw-bold">@item.CreatedAt?.ToString("dd/MM")</div>
                                <div class="small text-muted fw-bold">NGÀY TẠO</div>
                            </div>
                        </div>

                        @if (isEmpty)
                        {
                            <div class="alert alert-danger rounded-4 fw-bold">
                                <i class="fa fa-triangle-exclamation me-2"></i>
                                Đề thi trống. Vui lòng vào Quản lý câu hỏi để thêm nội dung.
                            </div>
                        }

                        <div class="mb-3">
                            @if (item.IsPublished)
                            {
                                <span class="text-success fw-bold">
                                    <i class="fa fa-globe me-1"></i> Đang công khai
                                </span>
                            }
                            else
                            {
                                <span class="text-secondary fw-bold">
                                    <i class="fa fa-file-pen me-1"></i> Đang lưu Nháp
                                </span>
                            }
                        </div>

                        <div class="d-flex gap-2">
                            @if (item.IsPublished)
                            {
                                <a href="/Teacher/Results?examId=@item.ExamId"
                                   class="btn btn-primary flex-fill fw-bold rounded-4">
                                    <i class="fa fa-chart-column me-1"></i> Bảng điểm
                                </a>

                                <form method="post" action="/Teacher/Exams/Unpublish/@item.ExamId">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-secondary fw-bold rounded-4" title="Đóng đề thi">
                                        <i class="fa fa-lock"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a href="/Teacher/Exams/ManageQuestions/@item.ExamId"
                                   class="btn btn-outline-dark flex-fill fw-bold rounded-4">
                                    <i class="fa fa-list-check me-1"></i> Quản lý câu hỏi
                                </a>

                                <form method="post" action="/Teacher/Exams/Publish/@item.ExamId">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-success fw-bold rounded-4"
                                            title="Công khai đề"
                                            @(isEmpty ? "disabled" : "")>
                                        <i class="fa fa-globe"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="importExcelModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">

            <div class="modal-header bg-success text-white rounded-top-4 border-0 px-4 py-3">
                <h5 class="modal-title fw-bold">
                    <i class="fa fa-file-import me-2"></i> Import Đề thi từ file Excel
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form action="/Teacher/Exams/Import" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="modal-body p-4 bg-light">
                    <div class="alert alert-info border-0 rounded-3 small mb-4 shadow-sm">
                        <i class="fa fa-info-circle me-1"></i>
                        Tải lên danh sách câu hỏi đã soạn sẵn trong file Excel. Đề thi sẽ được tạo ngay lập tức.
                    </div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Tên đề thi <span class="text-danger">*</span></label>
                            <input name="title" class="form-control" required />
                        </div>

                        <div class="col-md-8">
                            <label class="form-label fw-bold">Môn học <span class="text-danger">*</span></label>
                            <select name="subjectId" asp-items="ViewBag.SubjectList" class="form-select" required>
                                <option value="">-- Chọn môn học --</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Thời gian <span class="text-danger">*</span></label>
                            <input name="durationMinutes" type="number" class="form-control" value="60" min="1" required />
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">Loại đề</label>
                            <select name="examType" class="form-select">
                                <option value="1">Chỉ trắc nghiệm</option>
                                <option value="2">Chỉ tự luận</option>
                                <option value="3" selected>Hỗn hợp trắc nghiệm + tự luận</option>
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">File Excel (.xlsx)</label>
                            <input type="file" name="file" accept=".xlsx" class="form-control" required />

                            <div class="mt-2 text-end">
                                <a href="/Teacher/Exams/DownloadTemplate" class="text-success fw-bold text-decoration-none">
                                    <i class="fa fa-download me-1"></i> Tải file Excel mẫu
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer bg-white border-0 rounded-bottom-4 px-4 py-3">
                    <button type="button" class="btn btn-light fw-bold border" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-success fw-bold px-4">
                        <i class="fa fa-cloud-arrow-up me-1"></i> Tải lên & Tạo đề
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .exam-card {
        transition: .25s;
    }

    .exam-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 14px 28px rgba(0,0,0,.1) !important;
    }
</style>