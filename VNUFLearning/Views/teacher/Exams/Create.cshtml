@model VNUFLearning.Models.Exam

@{
    Layout = "~/Views/Shared/_LayoutTeacher.cshtml";
    ViewData["Title"] = "Tạo đề thi";
}

<div class="container-fluid">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">
            <i class="fa fa-file-circle-plus text-success me-2"></i> Tạo đề thi Random
        </h2>
        <p class="text-muted mb-0">
            Hệ thống tự động chọn câu hỏi từ ngân hàng câu hỏi theo môn học, loại đề, mức độ và chương.
        </p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 fw-bold">
            <i class="fa fa-triangle-exclamation me-2"></i>@TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <form method="post" action="/Teacher/Exams/Create">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-md-8">
                        <label class="form-label fw-bold">Tên đề thi</label>
                        <input asp-for="Title" class="form-control" placeholder="Ví dụ: Kiểm tra giữa kỳ CSDL nâng cao" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Môn học</label>
                        <select asp-for="SubjectId" asp-items="ViewBag.SubjectList" class="form-select">
                            <option value="">-- Chọn môn học --</option>
                        </select>
                        <span asp-validation-for="SubjectId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Loại đề</label>
                        <select asp-for="ExamType" class="form-select">
                            <option value="1">Chỉ trắc nghiệm</option>
                            <option value="2">Chỉ tự luận</option>
                            <option value="3">Hỗn hợp trắc nghiệm + tự luận</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Thời gian làm bài</label>
                        <div class="input-group">
                            <input asp-for="DurationMinutes" class="form-control" type="number" min="1" />
                            <span class="input-group-text">phút</span>
                        </div>
                        <span asp-validation-for="DurationMinutes" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Số câu hỏi</label>
                        <input asp-for="TotalQuestions" class="form-control" type="number" min="1" />
                        <span asp-validation-for="TotalQuestions" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Mức độ</label>
                        <select asp-for="Level" class="form-select">
                            <option value="">Hỗn hợp</option>
                            <option value="1">Dễ</option>
                            <option value="2">Trung bình</option>
                            <option value="3">Khó</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Từ chương</label>
                        <input asp-for="ChapterFrom" class="form-control" placeholder="Ví dụ: Chương 1" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Đến chương</label>
                        <input asp-for="ChapterTo" class="form-control" placeholder="Ví dụ: Chương 3" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Ghi chú ngắn về đề thi..."></textarea>
                    </div>

                    <div class="col-md-12">
                        <div class="form-check form-switch">
                            <input asp-for="IsPublished" class="form-check-input" />
                            <label class="form-check-label fw-bold">
                                Công khai đề thi sau khi tạo
                            </label>
                        </div>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4 fw-bold">
                        <i class="fa fa-random me-1"></i> Tạo đề random
                    </button>

                    <a href="/Teacher/Exams" class="btn btn-outline-secondary px-4 fw-bold">
                        <i class="fa fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}