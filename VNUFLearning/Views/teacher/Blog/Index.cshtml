@model List<VNUFLearning.Models.BlogPost>

@{
    Layout = "~/Views/Shared/_LayoutTeacher.cshtml";
    ViewData["Title"] = "Diễn đàn / Blog";

    var pendingPosts = ViewBag.PendingPosts as List<VNUFLearning.Models.BlogPost> ?? new();
    var tab = ViewBag.Tab as string ?? "feed";
    var keyword = ViewBag.Keyword as string ?? "";
    int pendingCount = ViewBag.PendingCount ?? 0;
}

<div class="teacher-blog-page">
    <div class="blog-top">
        <div>
            <h1>Diễn đàn Lớp học</h1>
            <p>Chia sẻ tài liệu, thông báo học tập và duyệt bài viết của sinh viên.</p>
        </div>

        <form method="get" action="/Teacher/Blog" class="blog-search">
            <i class="fa fa-search"></i>
            <input name="keyword" value="@keyword" placeholder="Tìm kiếm bài viết, giảng viên, sinh viên..." />
        </form>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 fw-bold">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 fw-bold">@TempData["Error"]</div>
    }

    <div class="blog-tabs">
        <a href="/Teacher/Blog?tab=feed" class="blog-tab @(tab == "feed" ? "active" : "")">
            <i class="fa fa-newspaper"></i> Bảng tin
        </a>

        <a href="/Teacher/Blog?tab=pending" class="blog-tab @(tab == "pending" ? "active" : "")">
            <i class="fa fa-clipboard-check"></i> Chờ phê duyệt
            <span>@pendingCount</span>
        </a>
    </div>

    @if (tab == "feed")
    {
        <div class="create-post-card">
            <div class="avatar">GV</div>

            <form method="post" action="/Teacher/Blog/Create" enctype="multipart/form-data" class="create-post-form">
                @Html.AntiForgeryToken()

                <input name="Title" class="post-title-input" placeholder="Tiêu đề bài viết..." />

                <textarea name="Content"
                          class="post-content-input"
                          rows="3"
                          placeholder="Thầy/cô muốn chia sẻ điều gì với lớp?"></textarea>

                <div class="create-actions">
                    <div class="upload-row">
                        <label class="upload-btn">
                            <i class="fa fa-image"></i> Ảnh/Video
                            <input type="file" name="imageFile" accept="image/*,video/mp4" hidden />
                        </label>

                        <label class="upload-btn">
                            <i class="fa fa-paperclip"></i> Đính kèm
                            <input type="file" name="attachmentFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" hidden />
                        </label>
                    </div>

                    <button type="submit" class="btn-post">Đăng</button>
                </div>
            </form>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-box">
                <i class="fa fa-newspaper"></i>
                <h3>Chưa có bài viết nào</h3>
                <p>Hãy đăng bài đầu tiên cho lớp học.</p>
            </div>
        }

        @foreach (var item in Model)
        {
            <div class="post-card" id="post-card-@item.PostId">
                <div class="post-header">
                    <div class="avatar">
                        @item.Author.FullName.Substring(0, 1).ToUpper()
                    </div>

                    <div>
                        <h4>@item.Author.FullName</h4>
                        <p>@item.CreatedAt?.ToString("dd/MM/yyyy HH:mm") · <i class="fa fa-earth-asia"></i></p>
                    </div>

                    <div class="post-header-actions ms-auto">
                        @if (item.AuthorId == ViewBag.CurrentTeacherId)
                        {
                            <button type="button"
                                    class="edit-icon-btn"
                                    onclick="openEditPost(@item.PostId)"
                                    title="Sửa bài viết">
                                <i class="fa fa-pen"></i>
                            </button>
                        }

                        <form method="post"
                              action="/Teacher/Blog/Delete/@item.PostId"
                              onsubmit="return confirm('Giảng viên có quyền xóa bài này. Bạn chắc chắn muốn xóa?');">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="delete-btn" title="Xóa bài viết">
                                <i class="fa fa-trash"></i>
                            </button>
                        </form>
                    </div>
                      
                </div>

                <h3 class="post-title" id="post-title-@item.PostId">@item.Title</h3>

                <p class="post-content" id="post-content-@item.PostId">@item.Content</p>

                @if (item.IsEdited)
                {
                    <button type="button"
                            class="edited-label"
                            onclick="showPostHistory(@item.PostId)">
                        Đã chỉnh sửa
                    </button>
                }

                @if (item.AuthorId == ViewBag.CurrentTeacherId)
                {

                    <div class="edit-post-box" id="edit-post-@item.PostId">
                        <input id="edit-title-@item.PostId"
                               value="@item.Title"
                               class="edit-input" />

                        <textarea id="edit-content-@item.PostId"
                                  class="edit-textarea">@item.Content</textarea>

                        <label class="edit-check">
                            <input type="checkbox" id="remove-image-@item.PostId" />
                            Xóa ảnh/video hiện tại
                        </label>

                        <input type="file"
                               id="edit-image-@item.PostId"
                               accept="image/*,video/mp4"
                               class="edit-input" />

                        <label class="edit-check">
                            <input type="checkbox" id="remove-attachment-@item.PostId" />
                            Xóa file đính kèm hiện tại
                        </label>

                        <input type="file"
                               id="edit-attachment-@item.PostId"
                               accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar"
                               class="edit-input" />

                        <div class="edit-actions">
                            <button type="button" onclick="submitEditPost(@item.PostId)">Lưu thay đổi</button>
                            <button type="button" onclick="closeEditPost(@item.PostId)">Hủy</button>
                        </div>
                    </div>
                }

                <div id="post-image-wrap-@item.PostId">
                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                    {
                        if (item.ImageUrl.EndsWith(".mp4"))
                        {
                            <video src="@item.ImageUrl" class="post-image" controls></video>
                        }
                        else
                        {
                            <img src="@item.ImageUrl" class="post-image" />
                        }
                    }
                </div>

                <div id="post-attachment-wrap-@item.PostId">
                    @if (!string.IsNullOrWhiteSpace(item.AttachmentUrl))
                    {
                        <a href="/Teacher/Blog/Download/@item.PostId" class="attachment-box">
                            <div class="file-icon">
                                <i class="fa fa-file"></i>
                            </div>
                            <div>
                                <div class="fw-bold">@item.AttachmentName</div>
                                <div class="text-muted small">
                                    @item.AttachmentType
                                    @if (item.AttachmentSize.HasValue)
                                    {
                                        <span> · @((item.AttachmentSize.Value / 1024.0 / 1024.0).ToString("0.##")) MB</span>
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>

                <div class="post-meta">
                    <span>
                        <i class="fa fa-heart text-danger"></i>
                        <span id="like-count-@item.PostId">@item.BlogLikes.Count</span>
                    </span>

                    <span>
                        <span id="comment-count-@item.PostId">@item.Comments.Count(x => x.ParentCommentId == null)</span>
                        bình luận
                    </span>
                </div>

                <div class="post-action-bar">
                    <button type="button"
                            class="post-action-btn like-btn"
                            data-post-id="@item.PostId"
                            onclick="toggleLikeAjax(@item.PostId)">
                        <i class="fa fa-heart"></i> Thả tim
                    </button>

                    <button type="button"
                            class="post-action-btn"
                            onclick="toggleComment(@item.PostId)">
                        <i class="fa fa-comment"></i> Bình luận
                    </button>
                </div>

                <div id="comment-@item.PostId" class="comment-panel">
                    <div id="comment-list-@item.PostId">
                        @foreach (var c in item.Comments.Where(x => x.ParentCommentId == null).OrderBy(x => x.CreatedAt))
                        {
                            <div class="comment-item" id="comment-item-@c.CommentId">
                                <div class="comment-avatar">
                                    @c.User.FullName.Substring(0, 1).ToUpper()
                                </div>

                                <div class="comment-right">
                                    <div class="comment-bubble">
                                        <div class="comment-name">@c.User.FullName</div>
                                        <div id="comment-content-@c.CommentId">@c.Content</div>

                                        @if (c.IsEdited)
                                        {
                                            <button type="button"
                                                    class="edited-label"
                                                    onclick="showCommentHistory(@c.CommentId)">
                                                Đã chỉnh sửa
                                            </button>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(c.ImageUrl))
                                        {
                                            if (c.ImageUrl.EndsWith(".mp4"))
                                            {
                                                <video src="@c.ImageUrl" class="comment-media" controls></video>
                                            }
                                            else
                                            {
                                                <img src="@c.ImageUrl" class="comment-media" />
                                            }
                                        }

                                        @if (!string.IsNullOrWhiteSpace(c.AttachmentUrl))
                                        {
                                            <a href="/Teacher/Blog/DownloadCommentFile/@c.CommentId" class="comment-attachment">
                                                <i class="fa fa-file"></i>
                                                <span>@c.AttachmentName</span>
                                            </a>
                                        }
                                    </div>

                                    <div class="comment-tools">
                                        <button type="button" onclick="toggleReply(@c.CommentId)">Phản hồi</button>

                                        @if (c.UserId == ViewBag.CurrentTeacherId)
                                        {
                                            <button type="button" onclick="openEditComment(@c.CommentId)">Sửa</button>
                                        }

                                       

                                        <span>@c.CreatedAt?.ToString("HH:mm dd/MM")</span>

                                        <button type="button" onclick="deleteComment(@c.CommentId)">Xóa</button>
                                    </div>

                                    @if (c.UserId == ViewBag.CurrentTeacherId)
                                    {
                                        <div class="edit-comment-box" id="edit-comment-@c.CommentId">
                                            <input id="edit-comment-input-@c.CommentId"
                                                   value="@c.Content"
                                                   class="edit-input"
                                                   placeholder="Sửa nội dung bình luận..." />

                                            <div class="edit-actions">
                                                <button type="button" onclick="submitEditComment(@c.CommentId)">Lưu</button>
                                                <button type="button" onclick="closeEditComment(@c.CommentId)">Hủy</button>
                                            </div>
                                        </div>
                                    }

                                    <form id="reply-@c.CommentId"
                                          class="reply-form"
                                          enctype="multipart/form-data"
                                          onsubmit="return submitReplyAjax(event, @c.CommentId)">
                                        @Html.AntiForgeryToken()

                                        <input name="content" placeholder="Viết phản hồi..." />

                                        <label class="comment-file-btn">
                                            <i class="fa fa-image"></i>
                                            <input type="file" name="imageFile" accept="image/*,video/mp4" hidden />
                                        </label>

                                        <label class="comment-file-btn">
                                            <i class="fa fa-paperclip"></i>
                                            <input type="file" name="attachmentFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" hidden />
                                        </label>

                                        <button type="submit">
                                            <i class="fa fa-paper-plane"></i>
                                        </button>
                                    </form>

                                    <div id="reply-list-@c.CommentId">
                                        @foreach (var r in c.Replies.OrderBy(x => x.CreatedAt))
                                        {
  
                                            <div class="reply-item" id="comment-item-@r.CommentId">
                                                <div class="comment-avatar small">
                                                    @r.User.FullName.Substring(0, 1).ToUpper()
                                                </div>

                                                <div class="comment-bubble">
                                                    <div class="comment-name">@r.User.FullName</div>
                                                    <div id="comment-content-@r.CommentId">@r.Content</div>

                                                    @if (r.IsEdited)
                                                    {
                                                        <button type="button"
                                                                class="edited-label"
                                                                onclick="showCommentHistory(@r.CommentId)">
                                                            Đã chỉnh sửa
                                                        </button>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(r.ImageUrl))
                                                    {
                                                        if (r.ImageUrl.EndsWith(".mp4"))
                                                        {
                                                            <video src="@r.ImageUrl" class="comment-media" controls></video>
                                                        }
                                                        else
                                                        {
                                                            <img src="@r.ImageUrl" class="comment-media" />
                                                        }
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(r.AttachmentUrl))
                                                    {
                                                        <a href="/Teacher/Blog/DownloadCommentFile/@r.CommentId" class="comment-attachment">
                                                            <i class="fa fa-file"></i>
                                                            <span>@r.AttachmentName</span>
                                                        </a>
                                                    }

                                                    <div class="comment-tools">
                                                        @if (r.UserId == ViewBag.CurrentTeacherId)
                                                        {
                                                            <button type="button" onclick="openEditComment(@r.CommentId)">Sửa</button>
                                                        }

                                                        <button type="button" onclick="deleteComment(@r.CommentId)">Xóa</button>
                                                    </div>

                                                    @if (r.UserId == ViewBag.CurrentTeacherId)
                                                    {
                                                        <div class="edit-comment-box" id="edit-comment-@r.CommentId">
                                                            <input id="edit-comment-input-@r.CommentId"
                                                                   value="@r.Content"
                                                                   class="edit-input"
                                                                   placeholder="Sửa nội dung phản hồi..." />

                                                            <div class="edit-actions">
                                                                <button type="button" onclick="submitEditComment(@r.CommentId)">Lưu</button>
                                                                <button type="button" onclick="closeEditComment(@r.CommentId)">Hủy</button>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <form class="comment-compose" enctype="multipart/form-data" onsubmit="return submitCommentAjax(event, @item.PostId)">
                        @Html.AntiForgeryToken()

                        <div class="comment-avatar">GV</div>

                        <input name="content" placeholder="Viết bình luận công khai..." />

                        <label class="comment-file-btn">
                            <i class="fa fa-image"></i>
                            <input type="file" name="imageFile" accept="image/*,video/mp4" hidden />
                        </label>

                        <label class="comment-file-btn">
                            <i class="fa fa-paperclip"></i>
                            <input type="file" name="attachmentFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" hidden />
                        </label>

                        <button type="submit">
                            <i class="fa fa-paper-plane"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <div class="pending-note">
            <i class="fa fa-circle-info"></i>
            Danh sách bài viết do sinh viên gửi lên diễn đàn. Cần phê duyệt để được hiển thị công khai.
        </div>

        @if (!pendingPosts.Any())
        {
            <div class="empty-box">
                <i class="fa fa-check-circle"></i>
                <h3>Không có bài chờ duyệt</h3>
                <p>Tất cả bài viết đã được xử lý.</p>
            </div>
        }

        @foreach (var item in pendingPosts)
        {
            <div class="pending-card">
                <div class="post-header">
                    <div class="avatar orange">
                        @item.Author.FullName.Substring(0, 1).ToUpper()
                    </div>

                    <div>
                        <h4>@item.Author.FullName</h4>
                        <p>Gửi lúc @item.CreatedAt?.ToString("HH:mm dd/MM/yyyy")</p>
                    </div>

                    <form method="post"
                          action="/Teacher/Blog/Delete/@item.PostId"
                          onsubmit="return confirm('Xóa bài chờ duyệt này?');"
                          class="ms-auto">
                        @Html.AntiForgeryToken()

                        <button type="submit" class="delete-btn" title="Xóa bài viết">
                            <i class="fa fa-trash"></i>
                        </button>
                    </form>
                </div>

                <h3 class="post-title">@item.Title</h3>
                <p class="post-content">
                    @(item.Content.Length > 220 ? item.Content.Substring(0, 220) + "..." : item.Content)
                </p>

                <div class="pending-actions">
                    <form method="post" action="/Teacher/Blog/Approve/@item.PostId">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-approve">
                            <i class="fa fa-check"></i> Phê duyệt bài
                        </button>
                    </form>

                    <form method="post"
                          action="/Teacher/Blog/Reject/@item.PostId"
                          onsubmit="return confirm('Từ chối và xóa bài viết này?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-reject">
                            Từ chối
                        </button>
                    </form>
                </div>
            </div>
        }
    }
</div>

<style>

    .post-header-actions {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .post-header-actions form {
            margin: 0;
        }

    .edit-icon-btn {
        border: none;
        background: #ecfdf5;
        color: #059669;
        border-radius: 10px;
        width: 38px;
        height: 38px;
    }

        .edit-icon-btn:hover {
            background: #d1fae5;
        }
    .edit-btn,
    .edited-label {
        border: none;
        background: transparent;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        margin-top: 6px;
    }

        .edit-btn:hover,
        .edited-label:hover {
            color: #059669;
            text-decoration: underline;
        }

    .edit-post-box,
    .edit-comment-box {
        display: none;
        margin-top: 10px;
        padding: 12px;
        background: #f8fafc;
        border: 1px solid #dbe3ef;
        border-radius: 14px;
        gap: 8px;
    }

        .edit-post-box.show,
        .edit-comment-box.show {
            display: grid;
        }

    .edit-input,
    .edit-textarea {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: 10px 12px;
        outline: none;
    }

    .edit-textarea {
        min-height: 90px;
    }
    .teacher-blog-page {
        max-width: 1080px;
        margin: 0 auto;
        padding-bottom: 60px;
    }

    .blog-top {
        display: grid;
        grid-template-columns: 1fr 420px;
        align-items: center;
        gap: 24px;
        margin-bottom: 24px;
    }

        .blog-top h1 {
            font-size: 34px;
            font-weight: 900;
            margin: 0;
            color: #0f172a;
        }

        .blog-top p {
            margin: 6px 0 0;
            color: #64748b;
            font-weight: 600;
        }

    .blog-search {
        background: #f1f5f9;
        border-radius: 999px;
        padding: 13px 18px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .blog-search input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            font-weight: 700;
        }

    .blog-tabs {
        background: white;
        border-radius: 18px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        overflow: hidden;
        margin-bottom: 24px;
        box-shadow: 0 8px 22px rgba(15,23,42,.08);
    }

    .blog-tab {
        text-align: center;
        text-decoration: none;
        color: #64748b;
        font-size: 21px;
        font-weight: 900;
        padding: 22px;
        border-bottom: 4px solid transparent;
    }

        .blog-tab.active {
            color: #059669;
            border-bottom-color: #059669;
        }

        .blog-tab span {
            background: #ef4444;
            color: white;
            border-radius: 999px;
            padding: 4px 12px;
            font-size: 15px;
            margin-left: 8px;
        }

    .create-post-card,
    .post-card,
    .pending-card,
    .empty-box {
        background: white;
        border-radius: 22px;
        padding: 24px;
        margin-bottom: 24px;
        box-shadow: 0 8px 22px rgba(15,23,42,.08);
    }

    .create-post-card {
        display: flex;
        gap: 16px;
    }

    .create-post-form {
        flex: 1;
    }

    .avatar,
    .comment-avatar {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: #059669;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 18px;
        flex-shrink: 0;
    }

        .avatar.orange {
            background: #f59e0b;
        }

    .post-title-input,
    .post-content-input {
        width: 100%;
        border: none;
        outline: none;
        background: #f1f5f9;
        border-radius: 16px;
        padding: 15px 18px;
        font-weight: 700;
    }

    .post-content-input {
        margin-top: 10px;
        resize: vertical;
    }

    .create-actions {
        border-top: 1px solid #e5e7eb;
        margin-top: 16px;
        padding-top: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .upload-row {
        display: flex;
        gap: 18px;
        align-items: center;
    }

    .upload-btn {
        cursor: pointer;
        font-weight: 900;
        color: #64748b;
    }

        .upload-btn i {
            color: #059669;
            margin-right: 5px;
        }

    .btn-post,
    .btn-approve {
        border: none;
        background: #059669;
        color: white;
        font-weight: 900;
        border-radius: 12px;
        padding: 12px 28px;
    }

    .post-header {
        display: flex;
        gap: 14px;
        align-items: center;
        margin-bottom: 16px;
    }

        .post-header h4 {
            margin: 0;
            font-weight: 900;
            color: #0f172a;
        }

        .post-header p {
            margin: 2px 0 0;
            color: #64748b;
            font-weight: 600;
        }

    .delete-btn {
        border: none;
        background: #fff1f2;
        color: #e11d48;
        border-radius: 10px;
        width: 38px;
        height: 38px;
    }

    .post-title {
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .post-content {
        color: #1f2937;
        font-size: 17px;
        line-height: 1.6;
        white-space: pre-line;
    }

    .post-image {
        width: 100%;
        max-height: 460px;
        object-fit: contain;
        border-radius: 18px;
        background: #f8fafc;
        margin-top: 14px;
    }

    .attachment-box {
        margin-top: 14px;
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px;
        border: 1px solid #dbe3ef;
        border-radius: 16px;
        text-decoration: none;
        color: #0f172a;
        background: #f8fafc;
    }

    .file-icon {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        background: #fee2e2;
        color: #ef4444;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .post-meta {
        border-top: 1px solid #e5e7eb;
        padding-top: 14px;
        margin-top: 18px;
        display: flex;
        justify-content: space-between;
        color: #64748b;
        font-weight: 800;
    }

    .post-action-bar {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-top: 1px solid #e5e7eb;
        margin-top: 14px;
    }

    .post-action-btn {
        width: 100%;
        border: none;
        background: white;
        padding: 16px;
        font-weight: 900;
        color: #64748b;
        font-size: 17px;
    }

        .post-action-btn:hover {
            background: #f8fafc;
            color: #059669;
        }

    .like-btn.liked {
        color: #ef4444;
    }

    .comment-panel {
        display: none;
        border-top: 1px solid #e5e7eb;
        padding-top: 18px;
    }

        .comment-panel.show {
            display: block;
            animation: slideDown .18s ease;
        }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .comment-item,
    .reply-item {
        display: flex;
        gap: 10px;
        margin-bottom: 14px;
    }

    .reply-item {
        margin-left: 44px;
        margin-top: 10px;
    }

    .comment-avatar {
        width: 42px;
        height: 42px;
        font-size: 14px;
    }

        .comment-avatar.small {
            width: 34px;
            height: 34px;
            font-size: 12px;
        }

    .comment-right {
        flex: 1;
    }

    .comment-bubble {
        background: #f1f5f9;
        padding: 11px 15px;
        border-radius: 18px;
        display: inline-block;
        max-width: 100%;
    }

    .comment-name {
        font-weight: 900;
        margin-bottom: 3px;
        color: #0f172a;
    }

    .comment-tools {
        display: flex;
        gap: 12px;
        margin-left: 12px;
        margin-top: 4px;
        color: #64748b;
        font-size: 13px;
    }

        .comment-tools button {
            border: none;
            background: transparent;
            color: #64748b;
            font-weight: 800;
            padding: 0;
        }

    .comment-compose {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 18px;
    }

        .comment-compose input,
        .reply-form input {
            flex: 1;
            border: none;
            outline: none;
            background: #f1f5f9;
            border-radius: 999px;
            padding: 12px 16px;
        }

        .comment-compose button,
        .reply-form button {
            width: 42px;
            height: 42px;
            border: none;
            border-radius: 50%;
            background: #059669;
            color: white;
            flex-shrink: 0;
        }

    .reply-form {
        display: none;
        gap: 8px;
        margin-top: 8px;
    }

        .reply-form.show {
            display: flex;
        }

    .pending-note {
        background: #fffbeb;
        border: 1px solid #facc15;
        color: #92400e;
        padding: 18px 22px;
        border-radius: 16px;
        margin-bottom: 22px;
        font-size: 17px;
        font-weight: 800;
    }

    .pending-badge {
        margin-left: auto;
        background: #fef3c7;
        color: #b45309;
        border-radius: 999px;
        padding: 8px 18px;
        font-weight: 900;
    }

    .pending-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        border-top: 1px solid #e5e7eb;
        padding-top: 18px;
    }

    .btn-reject {
        border: 1px solid #cbd5e1;
        background: white;
        border-radius: 12px;
        padding: 12px 26px;
        font-weight: 900;
        color: #475569;
    }

    .empty-box {
        text-align: center;
        color: #64748b;
        padding: 50px;
    }

        .empty-box i {
            font-size: 46px;
            color: #10b981;
            margin-bottom: 16px;
        }

    @@media (max-width: 992px) {
        .blog-top {
            grid-template-columns: 1fr;
        }
    }

    .comment-file-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #eef2f7;
        color: #059669;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

        .comment-file-btn:hover {
            background: #dcfce7;
        }

    .comment-media {
        display: block;
        margin-top: 10px;
        max-width: 280px;
        max-height: 220px;
        border-radius: 14px;
        object-fit: cover;
        background: #fff;
    }

    .comment-attachment {
        margin-top: 10px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #ffffff;
        border: 1px solid #dbe3ef;
        border-radius: 12px;
        padding: 9px 12px;
        text-decoration: none;
        color: #0f172a;
        font-weight: 700;
    }
</style>
<script>
        const blogConnection = new signalR.HubConnectionBuilder()
        .withUrl("/blogHub")
        .withAutomaticReconnect()
        .build();

    blogConnection.start()
        .then(() => console.log("BlogHub connected"))
        .catch(err => console.error(err));

    function getToken() {
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        return tokenInput ? tokenInput.value : "";
    }

    function toggleComment(id) {
        const panel = document.getElementById("comment-" + id);
        if (!panel) return;

        panel.classList.toggle("show");

        if (panel.classList.contains("show")) {
            setTimeout(() => {
                panel.scrollIntoView({ behavior: "smooth", block: "center" });
            }, 150);
        }
    }

    function toggleReply(id) {
        const form = document.getElementById("reply-" + id);
        if (!form) return;

        form.classList.toggle("show");
    }

    async function toggleLikeAjax(postId) {
        const response = await fetch(`/Teacher/Blog/ToggleLikeAjax/${postId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            }
        });

        const data = await response.json();

        if (data.success) {
            document.getElementById(`like-count-${postId}`).innerText = data.count;

            const btn = document.querySelector(`.like-btn[data-post-id="${postId}"]`);
            if (btn) btn.classList.toggle("liked", data.liked);
        }
    }

    async function submitCommentAjax(event, postId) {
        event.preventDefault();

        const form = event.target;
        const input = form.querySelector('input[name="content"]');
        const content = input.value.trim();
        const imageFile = form.querySelector('input[name="imageFile"]').files.length;
        const attachmentFile = form.querySelector('input[name="attachmentFile"]').files.length;

        if (!content && imageFile === 0 && attachmentFile === 0) return false;

        const body = new FormData(form);

        const response = await fetch(`/Teacher/Blog/CommentAjax/${postId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            },
            body
        });

        const data = await response.json();

        if (data.success) {
            const list = document.getElementById(`comment-list-${postId}`);

            list.insertAdjacentHTML("beforeend", `
                    <div class="comment-item" id="comment-item-${data.commentId}">
                        <div class="comment-avatar">${data.avatar}</div>

                        <div class="comment-right">
                            <div class="comment-bubble">
                                <div class="comment-name">${escapeHtml(data.userName)}</div>
                                <div>${escapeHtml(data.content || "")}</div>
                                ${renderCommentFiles(data)}
                            </div>

                            <div class="comment-tools">
                                <button onclick="toggleReply(${data.commentId})" type="button">Phản hồi</button>
                                <span>${data.createdAt || ""}</span>
                                <button onclick="deleteComment(${data.commentId})" type="button">Xóa</button>
                            </div>

                            <form id="reply-${data.commentId}"
                                  class="reply-form"
                                  enctype="multipart/form-data"
                                  onsubmit="return submitReplyAjax(event, ${data.commentId})">
                                <input name="content" placeholder="Viết phản hồi..." />

                                <label class="comment-file-btn">
                                    <i class="fa fa-image"></i>
                                    <input type="file" name="imageFile" accept="image/*,video/mp4" hidden />
                                </label>

                                <label class="comment-file-btn">
                                    <i class="fa fa-paperclip"></i>
                                    <input type="file" name="attachmentFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" hidden />
                                </label>

                                <button type="submit"><i class="fa fa-paper-plane"></i></button>
                            </form>

                            <div id="reply-list-${data.commentId}"></div>
                        </div>
                    </div>
                `);

            form.reset();

            const countEl = document.getElementById(`comment-count-${postId}`);
            countEl.innerText = parseInt(countEl.innerText || "0") + 1;
        }

        return false;
    }

    async function submitReplyAjax(event, commentId) {
        event.preventDefault();

        const form = event.target;
        const input = form.querySelector('input[name="content"]');
        const content = input.value.trim();
        const imageFile = form.querySelector('input[name="imageFile"]')?.files.length || 0;
        const attachmentFile = form.querySelector('input[name="attachmentFile"]')?.files.length || 0;

        if (!content && imageFile === 0 && attachmentFile === 0) return false;

        const body = new FormData(form);

        const response = await fetch(`/Teacher/Blog/ReplyAjax/${commentId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            },
            body
        });

        const data = await response.json();

        if (data.success) {
            const list = document.getElementById(`reply-list-${commentId}`);

            list.insertAdjacentHTML("beforeend", `
                    <div class="reply-item" id="comment-item-${data.commentId}">
                        <div class="comment-avatar small">${data.avatar}</div>

                        <div class="comment-bubble">
                            <div class="comment-name">${escapeHtml(data.userName)}</div>
                            <div>${escapeHtml(data.content || "")}</div>
                            ${renderCommentFiles(data)}

                            <div class="comment-tools">
                                <button type="button" onclick="deleteComment(${data.commentId})">Xóa</button>
                            </div>
                        </div>
                    </div>
                `);

            form.reset();
            form.classList.remove("show");
        }

        return false;
    }

    async function deleteComment(commentId) {
        if (!confirm("Xóa bình luận này?")) return;

        const prefix = location.pathname.toLowerCase().startsWith("/teacher")
            ? "/Teacher/Blog"
            : "/Student/Blog";

        const response = await fetch(`${prefix}/DeleteComment/${commentId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            }
        });

        const data = await response.json();

        if (data.success) {
            const el = document.getElementById(`comment-item-${commentId}`);
            if (el) el.remove();
        } else {
            alert(data.message || "Không xóa được.");
        }
    }

    function renderCommentFiles(data) {
        let html = "";

        if (data.imageUrl) {
            if (data.imageUrl.toLowerCase().endsWith(".mp4")) {
                html += `<video src="${data.imageUrl}" class="comment-media" controls></video>`;
            } else {
                html += `<img src="${data.imageUrl}" class="comment-media" />`;
            }
        }

        if (data.attachmentUrl) {
            const id = data.commentId || data.parentId;

            html += `
                    <a href="/Teacher/Blog/DownloadCommentFile/${id}" class="comment-attachment">
                        <i class="fa fa-file"></i>
                        <span>${escapeHtml(data.attachmentName || "Tệp đính kèm")}</span>
                    </a>`;
        }

        return html;
    }

    function escapeHtml(text) {
        const div = document.createElement("div");
        div.innerText = text || "";
        return div.innerHTML;
    }
    function openEditPost(id) {
        document.getElementById(`edit-post-${id}`).classList.add("show");
    }

    function closeEditPost(id) {
        document.getElementById(`edit-post-${id}`).classList.remove("show");
    }

    async function submitEditPost(id) {
        const title = document.getElementById(`edit-title-${id}`).value.trim();
        const content = document.getElementById(`edit-content-${id}`).value.trim();

        const imageInput = document.getElementById(`edit-image-${id}`);
        const attachmentInput = document.getElementById(`edit-attachment-${id}`);

        const body = new FormData();
        body.append("title", title);
        body.append("content", content);
        body.append("removeImage", document.getElementById(`remove-image-${id}`).checked);
        body.append("removeAttachment", document.getElementById(`remove-attachment-${id}`).checked);

        if (imageInput.files.length > 0) {
            body.append("imageFile", imageInput.files[0]);
        }

        if (attachmentInput.files.length > 0) {
            body.append("attachmentFile", attachmentInput.files[0]);
        }

        const response = await fetch(`/Teacher/Blog/EditPost/${id}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            },
            body
        });

        const data = await response.json();

        if (!data.success) {
            alert(data.message || "Không thể sửa bài viết.");
            return;
        }

        document.getElementById(`post-title-${id}`).innerText = data.title;
        document.getElementById(`post-content-${id}`).innerText = data.content;

        const imageWrap = document.getElementById(`post-image-wrap-${id}`);
        if (imageWrap) {
            if (data.imageUrl) {
                const lower = data.imageUrl.toLowerCase();
                imageWrap.innerHTML = lower.endsWith(".mp4")
                    ? `<video src="${data.imageUrl}" class="post-image" controls></video>`
                    : `<img src="${data.imageUrl}" class="post-image" />`;
            } else {
                imageWrap.innerHTML = "";
            }
        }

        const attachmentWrap = document.getElementById(`post-attachment-wrap-${id}`);
        if (attachmentWrap) {
            if (data.attachmentUrl) {
                attachmentWrap.innerHTML = `
                    <a href="/Teacher/Blog/Download/${id}" class="attachment-box">
                        <div class="file-icon"><i class="fa fa-file"></i></div>
                        <div>
                            <div class="fw-bold">${escapeHtml(data.attachmentName || "Tệp đính kèm")}</div>
                            <div class="text-muted small">${escapeHtml(data.attachmentType || "")} · ${escapeHtml(data.attachmentSize || "")}</div>
                        </div>
                    </a>`;
            } else {
                attachmentWrap.innerHTML = "";
            }
        }

        document.getElementById(`remove-image-${id}`).checked = false;
        document.getElementById(`remove-attachment-${id}`).checked = false;
        imageInput.value = "";
        attachmentInput.value = "";

        closeEditPost(id);
        alert("Đã cập nhật bài viết.");
    }
    function openEditComment(id) {
        document.getElementById(`edit-comment-${id}`).classList.add("show");
    }

    function closeEditComment(id) {
        document.getElementById(`edit-comment-${id}`).classList.remove("show");
    }

    async function submitEditComment(id) {
        const content = document.getElementById(`edit-comment-input-${id}`).value.trim();

        const body = new FormData();
        body.append("content", content);

        const response = await fetch(`/Teacher/Blog/EditComment/${id}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            },
            body
        });

        const data = await response.json();

        if (!data.success) {
            alert(data.message || "Không thể sửa bình luận.");
            return;
        }

        document.getElementById(`comment-content-${id}`).innerText = data.content;

        closeEditComment(id);
        alert("Đã cập nhật bình luận.");
    }

    async function showPostHistory(id) {
        const response = await fetch(`/Teacher/Blog/PostHistory/${id}`);
        const data = await response.json();

        if (!data.length) {
            alert("Chưa có lịch sử chỉnh sửa.");
            return;
        }

        let text = "LỊCH SỬ CHỈNH SỬA BÀI VIẾT\n\n";

        data.forEach((x, index) => {
            text += `Lần ${index + 1} - ${x.editedAt} bởi ${x.editedBy}\n`;
            text += `Tiêu đề cũ: ${x.oldTitle || ""}\n`;
            text += `Nội dung cũ: ${x.oldContent || ""}\n\n`;
        });

        alert(text);
    }

    async function showCommentHistory(id) {
        const response = await fetch(`/Teacher/Blog/CommentHistory/${id}`);
        const data = await response.json();

        if (!data.length) {
            alert("Chưa có lịch sử chỉnh sửa.");
            return;
        }

        let text = "LỊCH SỬ CHỈNH SỬA BÌNH LUẬN\n\n";

        data.forEach((x, index) => {
            text += `Lần ${index + 1} - ${x.editedAt} bởi ${x.editedBy}\n`;
            text += `Nội dung cũ: ${x.oldContent || ""}\n\n`;
        });

        alert(text);
    }
</script>