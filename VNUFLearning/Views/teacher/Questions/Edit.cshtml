@model VNUFLearning.Models.Question

@{
    Layout = "~/Views/Shared/_LayoutTeacher.cshtml";
    ViewData["Title"] = "Chỉnh sửa câu hỏi";
}

<div class="container-fluid">
    <div class="mb-4">
        <h2 class="fw-bold">
            <i class="fa fa-pen-to-square text-success me-2"></i> Chỉnh sửa câu hỏi
        </h2>
        <p class="text-muted">Cập nhật nội dung câu hỏi thuộc môn học bạn phụ trách.</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <form action="/Teacher/Questions/Edit/@Model.QuestionId" method="post">
                @Html.AntiForgeryToken()


                <input asp-for="QuestionId" type="hidden" />
                <input asp-for="CreatedAt" type="hidden" />
                <input asp-for="CreatedByUserId" type="hidden" />
                <input asp-for="IsActive" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Môn học</label>
                        <select asp-for="SubjectId" asp-items="ViewBag.SubjectList" class="form-select">
                            <option value="">-- Chọn môn học --</option>
                        </select>
                        <span asp-validation-for="SubjectId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Loại câu hỏi</label>
                        <select asp-for="QuestionType" class="form-select" id="questionType">
                            <option value="1">Trắc nghiệm</option>
                            <option value="2">Tự luận</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Mức độ</label>
                        <select asp-for="Level" class="form-select">
                            <option value="1">Dễ</option>
                            <option value="2">Trung bình</option>
                            <option value="3">Khó</option>
                        </select>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Nội dung câu hỏi</label>
                        <textarea asp-for="Content" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Chương / Chủ đề</label>
                        <input asp-for="Chapter" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Ảnh minh họa URL</label>
                        <input asp-for="ImageUrl" class="form-control" />
                    </div>

                    <div class="col-md-6 option-field">
                        <label class="form-label fw-bold">Đáp án A</label>
                        <input asp-for="OptionA" class="form-control" />
                    </div>

                    <div class="col-md-6 option-field">
                        <label class="form-label fw-bold">Đáp án B</label>
                        <input asp-for="OptionB" class="form-control" />
                    </div>

                    <div class="col-md-6 option-field">
                        <label class="form-label fw-bold">Đáp án C</label>
                        <input asp-for="OptionC" class="form-control" />
                    </div>

                    <div class="col-md-6 option-field">
                        <label class="form-label fw-bold">Đáp án D</label>
                        <input asp-for="OptionD" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">
                            Đáp án đúng / Đáp án mẫu
                        </label>
                        <input asp-for="CorrectAnswer"
                               class="form-control"
                               placeholder="Trắc nghiệm: A/B/C/D. Tự luận: nhập đáp án mẫu." />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">
                            Giải thích / Rubric chấm điểm cho Gemini
                        </label>
                        <textarea asp-for="Explaination" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="fa fa-save me-1"></i> Lưu thay đổi
                    </button>

                    <a href="/Teacher/Questions" class="btn btn-outline-secondary px-4 fw-bold">
                        <i class="fa fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function toggleOptions() {
            const type = document.getElementById("questionType").value;
            const fields = document.querySelectorAll(".option-field");

            fields.forEach(x => {
                x.style.display = type === "1" ? "block" : "none";
            });
        }

        document.getElementById("questionType").addEventListener("change", toggleOptions);
        toggleOptions();
    </script>
}