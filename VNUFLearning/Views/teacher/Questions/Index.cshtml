@model IEnumerable<VNUFLearning.Models.Question>

@{
    Layout = "~/Views/Shared/_LayoutTeacher.cshtml";
    ViewData["Title"] = "Ngân hàng câu hỏi";

    int questionType = ViewBag.QuestionType ?? 0;
    int level = ViewBag.Level ?? 0;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="fa fa-database text-success me-2"></i> Ngân hàng câu hỏi
            </h2>
            <p class="text-muted mb-0">Quản lý câu hỏi thuộc các môn học bạn được phân công.</p>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary fw-bold px-4"
                    data-bs-toggle="modal"
                    data-bs-target="#importModal">
                <i class="fa fa-file-excel me-1"></i> Import Excel
            </button>

            <a href="/Teacher/Questions/Create" class="btn btn-success fw-bold px-4">
                <i class="fa fa-plus me-1"></i> Thêm câu hỏi
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 fw-bold">
            <i class="fa fa-check-circle me-2"></i>@TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 fw-bold">
            <i class="fa fa-triangle-exclamation me-2"></i>@TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <form method="get" action="/Teacher/Questions">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small text-muted fw-bold">Môn học</label>
                        <select name="subjectId" asp-items="ViewBag.SubjectList" class="form-select">
                            <option value="">Tất cả môn phụ trách</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label small text-muted fw-bold">Loại câu hỏi</label>
                        <select name="questionType" class="form-select">
                            <option value="">Tất cả loại</option>
                            <option value="1" selected="@(questionType == 1)">Trắc nghiệm</option>
                            <option value="2" selected="@(questionType == 2)">Tự luận</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label small text-muted fw-bold">Mức độ</label>
                        <select name="level" class="form-select">
                            <option value="">Tất cả</option>
                            <option value="1" selected="@(level == 1)">Dễ</option>
                            <option value="2" selected="@(level == 2)">Trung bình</option>
                            <option value="3" selected="@(level == 3)">Khó</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label small text-muted fw-bold">Tìm kiếm</label>
                        <input name="keyword"
                               value="@ViewBag.Keyword"
                               class="form-control"
                               placeholder="Nhập nội dung câu hỏi..." />
                    </div>

                    <div class="col-12 d-flex gap-2">
                        <button class="btn btn-success px-4 fw-bold">
                            <i class="fa fa-filter me-1"></i> Lọc
                        </button>

                        <a href="/Teacher/Questions" class="btn btn-outline-secondary px-4 fw-bold">
                            <i class="fa fa-rotate-right me-1"></i> Làm mới
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Môn học</th>
                        <th style="min-width:300px; width:34%;">Nội dung câu hỏi</th>
                        <th>Loại</th>
                        <th>Mức độ</th>
                        <th style="min-width:260px; width:24%;">Đáp án</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                Chưa có câu hỏi nào.
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">#@item.QuestionId</td>

                            <td>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary rounded-pill px-3 py-2">
                                    @item.Subject.SubjectName
                                </span>
                            </td>

                            <td>
                                <div class="fw-bold" style="max-width:380px; white-space:normal; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;" title="@item.Content">
                                    @item.Content
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.Chapter))
                                {
                                    <div class="small text-muted">@item.Chapter</div>
                                }
                            </td>

                            <td>
                                @if (item.QuestionType == 1)
                                {
                                    <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                        <i class="fa fa-circle-check me-1"></i> Trắc nghiệm
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-3 py-2">
                                        <i class="fa fa-pen me-1"></i> Tự luận
                                    </span>
                                }
                            </td>

                            <td>
                                @{
                                    var lvText = item.Level == 1 ? "Dễ" : item.Level == 2 ? "Trung bình" : item.Level == 3 ? "Khó" : "Chưa đặt";
                                    var lvClass = item.Level == 1 ? "success" : item.Level == 2 ? "warning" : item.Level == 3 ? "danger" : "secondary";
                                }

                                <span class="badge bg-@lvClass bg-opacity-10 text-@lvClass border border-@lvClass rounded-pill px-3 py-2">
                                    @lvText
                                </span>
                            </td>

                            <td class="fw-bold text-success" style="min-width:260px;">
                                <div style="max-width:320px; white-space:normal; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;"
                                     title="@item.CorrectAnswer">
                                    @(string.IsNullOrWhiteSpace(item.CorrectAnswer) ? "-" : item.CorrectAnswer)
                                </div>
                            </td>

                            <td class="text-end pe-4">
                                <button type="button"
                                        class="btn btn-sm btn-outline-info"
                                        title="Xem chi tiết"
                                        data-bs-toggle="modal"
                                        data-bs-target="#teacherDetailQuestionModal-@item.QuestionId">
                                    <i class="fa fa-eye"></i>
                                </button>

                                <button type="button"
                                        class="btn btn-sm btn-outline-primary"
                                        title="Sửa"
                                        data-bs-toggle="modal"
                                        data-bs-target="#teacherEditQuestionModal-@item.QuestionId">
                                    <i class="fa fa-pen"></i>
                                </button>

                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        title="Xóa"
                                        data-bs-toggle="modal"
                                        data-bs-target="#teacherDeleteQuestionModal-@item.QuestionId">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </td>
                        </tr>

                        <div class="modal fade" id="teacherDetailQuestionModal-@item.QuestionId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                                <div class="modal-content border-0 rounded-4 shadow">
                                    <div class="modal-header bg-light">
                                        <div>
                                            <h5 class="modal-title fw-bold">Chi tiết câu hỏi #@item.QuestionId</h5>
                                            <div class="text-muted small">@item.Subject.SubjectName</div>
                                        </div>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <dl class="row mb-0">
                                            <dt class="col-sm-3">Nội dung</dt>
                                            <dd class="col-sm-9">@item.Content</dd>

                                            <dt class="col-sm-3">Loại câu hỏi</dt>
                                            <dd class="col-sm-9">@(item.QuestionType == 1 ? "Trắc nghiệm" : "Tự luận")</dd>

                                            <dt class="col-sm-3">Mức độ</dt>
                                            <dd class="col-sm-9">@lvText</dd>

                                            <dt class="col-sm-3">Chương / Chủ đề</dt>
                                            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(item.Chapter) ? "-" : item.Chapter)</dd>

                                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                            {
                                                <dt class="col-sm-3">Ảnh minh họa</dt>
                                                <dd class="col-sm-9">
                                                    <a href="@item.ImageUrl" target="_blank" rel="noopener">Mở ảnh</a>
                                                </dd>
                                            }

                                            @if (item.QuestionType == 1)
                                            {
                                                <dt class="col-sm-3">Đáp án A</dt>
                                                <dd class="col-sm-9">@item.OptionA</dd>
                                                <dt class="col-sm-3">Đáp án B</dt>
                                                <dd class="col-sm-9">@item.OptionB</dd>
                                                <dt class="col-sm-3">Đáp án C</dt>
                                                <dd class="col-sm-9">@item.OptionC</dd>
                                                <dt class="col-sm-3">Đáp án D</dt>
                                                <dd class="col-sm-9">@item.OptionD</dd>
                                            }

                                            <dt class="col-sm-3">Đáp án đúng / mẫu</dt>
                                            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(item.CorrectAnswer) ? "-" : item.CorrectAnswer)</dd>

                                            <dt class="col-sm-3">Giải thích / Rubric</dt>
                                            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(item.Explaination) ? "-" : item.Explaination)</dd>
                                        </dl>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="modal fade" id="teacherEditQuestionModal-@item.QuestionId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                                <div class="modal-content border-0 rounded-4 shadow">
                                    <form action="/Teacher/Questions/Edit/@item.QuestionId" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="QuestionId" value="@item.QuestionId" />
                                        <input type="hidden" name="CreatedAt" value="@item.CreatedAt?.ToString("O")" />
                                        <input type="hidden" name="CreatedByUserId" value="@item.CreatedByUserId" />
                                        <input type="hidden" name="IsActive" value="@item.IsActive.ToString()" />

                                        <div class="modal-header text-white" style="background:#005b33;">
                                            <h5 class="modal-title fw-bold">
                                                <i class="fa fa-pen me-2"></i>Chỉnh sửa câu hỏi #@item.QuestionId
                                            </h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>

                                        <div class="modal-body p-4">
                                            <div class="row g-4">
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Môn học</label>
                                                    <select name="SubjectId" class="form-select" required>
                                                        @foreach (Microsoft.AspNetCore.Mvc.Rendering.SelectListItem subject in ViewBag.SubjectList)
                                                        {
                                                            <option value="@subject.Value" selected="@(subject.Value == item.SubjectId.ToString())">@subject.Text</option>
                                                        }
                                                    </select>
                                                </div>

                                                <div class="col-md-3">
                                                    <label class="form-label fw-bold">Loại câu hỏi</label>
                                                    <select name="QuestionType" class="form-select question-type-select" data-target="#teacherOptions-@item.QuestionId">
                                                        <option value="1" selected="@(item.QuestionType == 1)">Trắc nghiệm</option>
                                                        <option value="2" selected="@(item.QuestionType == 2)">Tự luận</option>
                                                    </select>
                                                </div>

                                                <div class="col-md-3">
                                                    <label class="form-label fw-bold">Mức độ</label>
                                                    <select name="Level" class="form-select">
                                                        <option value="1" selected="@(item.Level == 1)">Dễ</option>
                                                        <option value="2" selected="@(item.Level == 2)">Trung bình</option>
                                                        <option value="3" selected="@(item.Level == 3)">Khó</option>
                                                    </select>
                                                </div>

                                                <div class="col-md-12">
                                                    <label class="form-label fw-bold">Nội dung câu hỏi</label>
                                                    <textarea name="Content" class="form-control" rows="4" required>@item.Content</textarea>
                                                </div>

                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Chương / Chủ đề</label>
                                                    <input name="Chapter" class="form-control" value="@item.Chapter" />
                                                </div>

                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Ảnh minh họa URL</label>
                                                    <input name="ImageUrl" class="form-control" value="@item.ImageUrl" />
                                                </div>

                                                <div id="teacherOptions-@item.QuestionId" class="row g-4 question-options">
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-bold">Đáp án A</label>
                                                        <input name="OptionA" class="form-control" value="@item.OptionA" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-bold">Đáp án B</label>
                                                        <input name="OptionB" class="form-control" value="@item.OptionB" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-bold">Đáp án C</label>
                                                        <input name="OptionC" class="form-control" value="@item.OptionC" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label fw-bold">Đáp án D</label>
                                                        <input name="OptionD" class="form-control" value="@item.OptionD" />
                                                    </div>
                                                </div>

                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">Đáp án đúng / Đáp án mẫu</label>
                                                    <input name="CorrectAnswer" class="form-control" value="@item.CorrectAnswer" />
                                                </div>

                                                <div class="col-md-12">
                                                    <label class="form-label fw-bold">Giải thích / Rubric chấm điểm</label>
                                                    <textarea name="Explaination" class="form-control" rows="3">@item.Explaination</textarea>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="modal-footer bg-light">
                                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                                            <button type="submit" class="btn btn-success fw-bold">
                                                <i class="fa fa-save me-1"></i>Lưu thay đổi
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="modal fade" id="teacherDeleteQuestionModal-@item.QuestionId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-0 rounded-4 shadow">
                                    <div class="modal-header bg-danger text-white">
                                        <h5 class="modal-title fw-bold">
                                            <i class="fa fa-triangle-exclamation me-2"></i>Xác nhận xóa câu hỏi
                                        </h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p class="mb-2">Bạn có chắc chắn muốn xóa câu hỏi <strong>#@item.QuestionId</strong>?</p>
                                        <div class="p-3 rounded-3 bg-light text-muted small" style="max-height:120px; overflow:auto;">
                                            @item.Content
                                        </div>
                                    </div>
                                    <div class="modal-footer bg-light">
                                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                                        <form action="/Teacher/Questions/Delete/@item.QuestionId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger fw-bold">
                                                <i class="fa fa-trash me-1"></i>Xóa câu hỏi
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">
                    <i class="fa fa-file-excel text-success me-2"></i> Import câu hỏi từ Excel
                </h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form action="/Teacher/Questions/ImportExcel" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Môn học</label>
                        <select name="subjectId" asp-items="ViewBag.SubjectList" class="form-select" required>
                            <option value="">-- Chọn môn học --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">File Excel (.xlsx)</label>
                        <input type="file" name="excelFile" class="form-control" accept=".xlsx" required />
                    </div>

                    <div class="alert alert-light border small mb-0">
                        <strong>Cấu trúc cột:</strong><br />
                        Content | QuestionType | OptionA | OptionB | OptionC | OptionD | CorrectAnswer | Level | Chapter | Explaination
                        <br />
                        QuestionType: 1 = Trắc nghiệm, 2 = Tự luận.
                    </div>
                </div>

                <div class="modal-footer">
                    <a href="/Teacher/Questions/DownloadTemplate" class="btn btn-outline-success me-auto">
                        <i class="fa fa-download me-1"></i> Tải mẫu
                    </a>

                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>

                    <button type="submit" class="btn btn-success">
                        <i class="fa fa-upload me-1"></i> Import
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleQuestionOptions(select) {
            const target = document.querySelector(select.dataset.target);
            if (!target) return;

            target.style.display = select.value === "1" ? "flex" : "none";
        }

        document.querySelectorAll(".question-type-select").forEach(select => {
            toggleQuestionOptions(select);
            select.addEventListener("change", () => toggleQuestionOptions(select));
        });
    </script>
}
