@model VNUFLearning.Models.ViewModels.ChangePasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đổi mật khẩu";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đổi mật khẩu - VNUF Learning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-image: url('/images/bgr.png');
            background-size: cover;
            background-position: top center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .pwd-card {
            width: 100%;
            max-width: 460px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 1.5rem;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            overflow: hidden;
            margin: 5vh 1rem;
        }

        .pwd-header {
            text-align: center;
            padding: 2rem 1.5rem 0.5rem;
        }

        .btn-vnuf {
            background-color: #005b33;
            color: white;
            border-radius: 50rem;
            padding: 0.75rem;
            font-weight: 600;
            font-size: 1.05rem;
            transition: all 0.3s;
            border: none;
        }

            .btn-vnuf:hover {
                background-color: #004526;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0,91,51,0.3);
            }

        .form-control {
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            background-color: #f8f9fa;
        }

            .form-control:focus {
                border-color: #005b33;
                box-shadow: 0 0 0 0.25rem rgba(0, 91, 51, 0.25);
                background-color: #fff;
            }

        .input-group-text {
            border-radius: 0.5rem;
            background-color: #f8f9fa;
        }

        .back-link {
            color: #005b33;
            font-weight: 500;
            text-decoration: none;
        }

            .back-link:hover {
                color: #004526;
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <div class="card pwd-card">
        <div class="pwd-header">
            <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                <i class="fa fa-key fa-2x" style="color: #005b33;"></i>
            </div>
            <h4 class="fw-bold text-dark mb-1">Đổi mật khẩu</h4>
            <p class="text-muted small">Vui lòng nhập mật khẩu hiện tại và mật khẩu mới</p>
        </div>
        <div class="card-body p-4 p-md-5 pt-2">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 rounded-3"></div>

            <form asp-action="ChangePassword" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label text-dark small fw-bold">Mật khẩu hiện tại</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text border-end-0"><i class="fa fa-lock text-muted"></i></span>
                        <input asp-for="CurrentPassword" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label text-dark small fw-bold">Mật khẩu mới</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text border-end-0"><i class="fa fa-key text-muted"></i></span>
                        <input asp-for="NewPassword" type="password" class="form-control border-start-0 ps-0" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label text-dark small fw-bold">Xác nhận mật khẩu mới</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text border-end-0"><i class="fa fa-check text-muted"></i></span>
                        <input asp-for="ConfirmPassword" type="password" class="form-control border-start-0 ps-0" placeholder="Nhập lại mật khẩu mới" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-vnuf w-100">
                    <i class="fa fa-save me-1"></i> Lưu thay đổi
                </button>

                <div class="text-center mt-3">
                    <a href="javascript:history.back()" class="back-link small">
                        <i class="fa fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
