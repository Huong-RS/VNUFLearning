@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
    var errorMessage = TempData["ErrorMessage"] as string;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - VNUF Learning</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            min-height: 100vh;
            background-color: #eef2ef;
            background-image: linear-gradient(rgba(255,255,255,0.18), rgba(255,255,255,0.18)), url('/images/bgr.png');
            background-repeat: no-repeat;
            background-size: cover;
            background-position: center top;
        }

        .page-wrap {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 16px;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            border: none;
            border-radius: 22px;
            box-shadow: 0 16px 35px rgba(0, 0, 0, 0.14);
            background: rgba(255, 255, 255, 0.95);
            overflow: hidden;
        }

        .login-header {
            text-align: center;
            padding: 30px 28px 14px 28px;
        }

        .brand-icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(25, 135, 84, 0.12);
            color: #198754;
            margin-bottom: 14px;
        }

        .brand-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 6px;
            color: #1f2937;
        }

        .brand-subtitle {
            color: #6b7280;
            margin-bottom: 0;
            font-size: 0.98rem;
        }

        .login-body {
            padding: 12px 28px 30px 28px;
        }

        .form-label {
            font-weight: 600;
            color: #374151;
            margin-bottom: 8px;
        }

        .form-control {
            height: 48px;
            border-radius: 12px;
            border: 1px solid #ced4da;
            padding: 0 14px;
            font-size: 0.98rem;
        }

            .form-control:focus {
                border-color: #198754;
                box-shadow: 0 0 0 0.18rem rgba(25, 135, 84, 0.15);
            }

        .btn-login {
            width: 100%;
            height: 48px;
            border: none;
            border-radius: 12px;
            background: #1f9254;
            color: white;
            font-weight: 700;
            font-size: 1rem;
            transition: all 0.2s ease;
        }

            .btn-login:hover {
                background: #177847;
            }

        .toast-wrap {
            position: fixed;
            top: 22px;
            right: 22px;
            z-index: 2000;
        }

        .custom-toast {
            min-width: 300px;
            max-width: 380px;
            display: flex;
            gap: 12px;
            align-items: flex-start;
            background: #ffffff;
            border-left: 5px solid #dc3545;
            border-radius: 14px;
            box-shadow: 0 14px 28px rgba(0,0,0,0.15);
            padding: 14px 16px;
            animation: slideIn .25s ease-out;
        }

        .custom-toast-icon {
            color: #dc3545;
            font-size: 1.15rem;
            margin-top: 2px;
        }

        .custom-toast-title {
            font-weight: 700;
            color: #212529;
            margin-bottom: 2px;
        }

        .custom-toast-message {
            color: #495057;
            font-size: 0.94rem;
            line-height: 1.45;
        }

        .toast-close {
            margin-left: auto;
            border: none;
            background: transparent;
            color: #6c757d;
            font-size: 1rem;
            cursor: pointer;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-8px) translateX(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0) translateX(0);
            }
        }

        @@media (max-width: 576px) {
            body {
                background-position: 58% top;
            }

            .login-card {
                max-width: 100%;
                border-radius: 18px;
            }

            .login-header {
                padding: 24px 20px 12px 20px;
            }

            .login-body {
                padding: 12px 20px 24px 20px;
            }

            .brand-title {
                font-size: 1.75rem;
            }
        }
    </style>
</head>
<body>
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="toast-wrap">
            <div class="custom-toast" id="loginErrorToast">
                <div class="custom-toast-icon">
                    <i class="fa-solid fa-circle-exclamation"></i>
                </div>
                <div>
                    <div class="custom-toast-title">Đăng nhập thất bại</div>
                    <div class="custom-toast-message">@errorMessage</div>
                </div>
                <button type="button" class="toast-close" onclick="closeToast()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        </div>
    }

    <div class="page-wrap">
        <div class="login-card">
            <div class="login-header">
                <div class="brand-icon">
                    <i class="fa fa-leaf fa-2x"></i>
                </div>
                <div class="brand-title">VNUF Learning</div>
                <p class="brand-subtitle">Hệ thống học tập và luyện thi thông minh</p>
            </div>

            <div class="login-body">
                <form method="post" action="/Account/Login" autocomplete="off">
                    <div class="mb-3">
                        <label class="form-label">Tài khoản</label>
                        <input type="text"
                               name="username"
                               class="form-control"
                               placeholder="Nhập mã sinh viên / mã giảng viên / adm" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Mật khẩu</label>
                        <input type="password"
                               name="password"
                               class="form-control"
                               placeholder="Nhập mật khẩu" />
                    </div>

                    <button type="submit" class="btn-login">
                        Đăng nhập
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        function closeToast() {
            const toast = document.getElementById('loginErrorToast');
            if (toast) {
                toast.style.display = 'none';
            }
        }

        setTimeout(() => {
            closeToast();
        }, 3500);
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>