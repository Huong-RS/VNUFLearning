@{
    Layout = null; // Tắt Layout mặc định
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - VNUF Learning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-image: url('/images/bgr.png');
            background-size: cover;
            background-position: top center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 1.5rem;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            overflow: hidden;
            margin-top: 15vh;
        }

        .login-header {
            text-align: center;
            padding: 2.5rem 2rem 1rem 2rem;
        }

        .btn-vnuf {
            background-color: #005b33;
            color: white;
            border-radius: 50rem;
            padding: 0.75rem;
            font-weight: 600;
            font-size: 1.05rem;
            transition: all 0.3s;
            border: none;
        }

            .btn-vnuf:hover {
                background-color: #004526;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0,91,51,0.3);
            }

        .form-control {
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            background-color: #f8f9fa;
        }

            .form-control:focus {
                border-color: #005b33;
                box-shadow: 0 0 0 0.25rem rgba(0, 91, 51, 0.25);
                background-color: #fff;
            }

        .input-group-text {
            border-radius: 0.5rem;
            background-color: #f8f9fa;
        }
    </style>
</head>
<body>
    <div class="card login-card">
        <div class="login-header">
            <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                <i class="fa fa-leaf fa-2x" style="color: #005b33;"></i>
            </div>
            <h3 class="fw-bold text-dark mb-0">VNUF Learning</h3>
            <p class="text-muted small mt-1">Hệ thống học tập và luyện thi thông minh</p>
        </div>
        <div class="card-body p-4 p-md-5 pt-0">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger small py-2 rounded-3 text-center">
                    <i class="fa fa-exclamation-triangle me-1"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label text-dark small fw-bold">Tên đăng nhập (MSV/MGV)</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text border-end-0"><i class="fa fa-user text-muted"></i></span>
                        <input type="text" name="username" class="form-control border-start-0 ps-0" required placeholder="Nhập tài khoản...">
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label text-dark small fw-bold">Mật khẩu</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text border-end-0"><i class="fa fa-lock text-muted"></i></span>
                        <input type="password" name="password" class="form-control border-start-0 ps-0" required placeholder="••••••••">
                    </div>
                </div>

                <button type="submit" class="btn btn-vnuf w-100 mt-2">
                    Đăng nhập <i class="fa fa-arrow-right ms-1"></i>
                </button>
            </form>
        </div>
    </div>
</body>
</html>