@model VNUFLearning.Models.ExamResult

@{
    ViewData["Title"] = "Kết quả";
    var duration = Model.FinishedAt.HasValue && Model.StartedAt.HasValue
        ? Model.FinishedAt.Value - Model.StartedAt.Value
        : TimeSpan.Zero;
}

<div class="success-page">
    <header class="success-header">
        <h2>Trung tâm Luyện thi</h2>
        <div class="user-box">
            <b>Đinh Diệu Hương</b>
            <span>HD</span>
        </div>
    </header>

    <main class="success-main">
        <div class="check">✓</div>

        <h1>Đã nộp bài thành công</h1>
        <p>Dưới đây là bảng tổng hợp kết quả của bạn.</p>

        <div class="result-grid">
            <div class="result-card">
                <div>
                    <h3>ĐIỂM TRẮC NGHIỆM</h3>
                    <strong>@(Model.Score.HasValue ? Model.Score.Value.ToString("0.##") : "--")<small>/10</small></strong>
                </div>
                <div class="round-icon">☷</div>
            </div>

            <div class="result-card">
                <div>
                    <h3>THỜI GIAN LÀM BÀI</h3>
                    <strong>@duration.Minutes.ToString("00"):@duration.Seconds.ToString("00")</strong>
                </div>
                <div class="round-icon orange">⏱</div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.AiFeedback))
        {
            <div class="ai-box">
                <b>Nhận xét AI:</b>
                <p>@Model.AiFeedback</p>
            </div>
        }

        <div class="actions">
            <a href="/Student/Practice" class="back-btn">← Trở về</a>
            <a href="/Student/Result/Detail/@Model.ExamResultId" class="detail-btn">👁 Xem chi tiết bài làm</a>
        </div>
    </main>
</div>

<style>
    body {
        margin: 0;
        background: linear-gradient(135deg,#f3fffb 0%,#f7fbff 45%,#ffffff 100%);
        overflow-x: hidden;
        position: relative;
    }

        /* background sticker */
        body::before,
        body::after {
            content: "";
            position: fixed;
            border-radius: 40px;
            transform: rotate(35deg);
            z-index: -1;
            opacity: .18;
        }

        body::before {
            width: 260px;
            height: 520px;
            left: -90px;
            top: 180px;
            background: linear-gradient(180deg,#7be7c7,#baf7e8);
        }

        body::after {
            width: 260px;
            height: 520px;
            right: -90px;
            top: 80px;
            background: linear-gradient(180deg,#9cefd9,#d7fff2);
        }

    .success-header {
        height: 72px;
        background: rgba(255,255,255,.92);
        backdrop-filter: blur(20px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 48px;
        box-shadow: 0 4px 18px rgba(0,0,0,.06);
    }

        .success-header h2 {
            margin: 0;
            font-size: 30px;
            font-weight: 900;
            color: #17233a;
        }

    .user-box {
        display: flex;
        gap: 16px;
        align-items: center;
        font-size: 20px;
    }

        .user-box span {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            background: linear-gradient(135deg,#008f59,#00b36d);
            color: white;
            display: grid;
            place-items: center;
            font-weight: 900;
            box-shadow: 0 8px 20px rgba(0,179,109,.35);
        }

    .success-main {
        max-width: 980px;
        margin: 50px auto;
        text-align: center;
        position: relative;
    }

    .check {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        margin: 0 auto 28px;
        display: grid;
        place-items: center;
        font-size: 56px;
        font-weight: 900;
        color: #00a86b;
        background: radial-gradient(circle,#dffff0,#b8ffd8);
        box-shadow: 0 0 0 12px rgba(0,168,107,.08), 0 0 40px rgba(0,168,107,.22);
    }

    .success-main h1 {
        margin: 0;
        font-size: 54px;
        font-weight: 900;
        color: #17233a;
    }

    .success-main > p {
        margin-top: 14px;
        font-size: 22px;
        color: #66758c;
    }

    .result-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 32px;
        margin: 50px 0;
    }

    .result-card {
        position: relative;
        background: rgba(255,255,255,.95);
        backdrop-filter: blur(20px);
        border: 2px solid #a7e9d0;
        border-radius: 24px;
        padding: 34px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        text-align: left;
        box-shadow: 0 12px 30px rgba(0,0,0,.08), 0 0 25px rgba(0,168,107,.08);
        overflow: hidden;
    }

        .result-card::before {
            content: "";
            position: absolute;
            width: 120px;
            height: 120px;
            right: -25px;
            top: -25px;
            border-radius: 50%;
            background: rgba(0,168,107,.08);
        }

        .result-card h3 {
            margin: 0 0 16px;
            font-size: 22px;
            font-weight: 900;
            color: #8a97ab;
        }

        .result-card strong {
            font-size: 56px;
            font-weight: 900;
            color: #17233a;
        }

        .result-card small {
            font-size: 28px;
            color: #94a3b8;
        }

    .round-icon {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-size: 36px;
        background: linear-gradient(135deg,#dffef1,#baf7db);
        color: #00a86b;
        box-shadow: 0 8px 20px rgba(0,168,107,.15);
    }

    .orange {
        background: linear-gradient(135deg,#fff6db,#ffe2a6);
        color: #dd8b00;
        box-shadow: 0 8px 20px rgba(221,139,0,.15);
    }

    .ai-box {
        background: rgba(255,255,255,.92);
        border: 1px solid #dce5ef;
        border-radius: 20px;
        padding: 24px;
        text-align: left;
        margin-bottom: 28px;
        box-shadow: 0 8px 24px rgba(0,0,0,.05);
    }

    .actions {
        display: flex;
        justify-content: center;
        gap: 22px;
    }

    .back-btn,
    .detail-btn {
        padding: 18px 34px;
        border-radius: 14px;
        font-size: 22px;
        font-weight: 900;
        text-decoration: none;
        transition: .25s;
    }

    .back-btn {
        background: #17233a;
        color: white;
    }

        .back-btn:hover {
            transform: translateY(-2px);
        }

    .detail-btn {
        background: white;
        border: 1px solid #dce5ef;
        color: #17233a;
    }

        .detail-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,.08);
        }
</style>