    .blog-tab {
        padding: 22px;
        text-align: center;
        text-decoration: none;
        color: #64748b;
        font-size: 21px;
        font-weight: 900;
        border-bottom: 4px solid transparent;
    }

        .blog-tab.active {
            color: #059669;
            border-bottom-color: #059669;
        }

        .blog-tab span {
            background: #ef4444;
            color: white;
