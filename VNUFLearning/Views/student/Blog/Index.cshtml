        text-align: center;
        text-decoration: none;
        color: #64748b;
        font-size: 21px;
        font-weight: 900;
        border-bottom: 4px solid transparent;
    }

        .blog-tab.active {
            color: #059669;
            border-bottom-color: #059669;
        }

        .blog-tab span {
            background: #ef4444;
            color: white;
            border-radius: 999px;
            padding: 4px 12px;
            font-size: 15px;
            margin-left: 8px;
        }

    .create-post-card,
    .post-card,
    .pending-card,
    .empty-box {
        background: white;
        border-radius: 22px;
        padding: 24px;
        margin-bottom: 24px;
        box-shadow: 0 8px 22px rgba(15,23,42,.08);
    }

    .create-post-card {
        display: flex;
        gap: 16px;
    }

    .create-post-form {
        flex: 1;
    }

    .avatar,
    .comment-avatar {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: #059669;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        flex-shrink: 0;
    }

        .avatar.orange {
            background: #f59e0b;
        }

    .post-title-input,
    .post-content-input {
        width: 100%;
        border: none;
        outline: none;
        background: #f1f5f9;
        border-radius: 16px;
        padding: 15px 18px;
        font-weight: 700;
    }

    .post-content-input {
        margin-top: 10px;
        resize: vertical;
    }

    .create-actions {
        border-top: 1px solid #e5e7eb;
        margin-top: 16px;
        padding-top: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .upload-row {
        display: flex;
        gap: 18px;
    }

    .upload-btn {
        cursor: pointer;
        font-weight: 900;
        color: #64748b;
    }

        .upload-btn i {
            color: #059669;
            margin-right: 5px;
        }

    .btn-post {
        border: none;
        background: #059669;
        color: white;
        font-weight: 900;
        border-radius: 12px;
        padding: 12px 28px;
    }

    .post-header {
        display: flex;
        gap: 14px;
        align-items: center;
        margin-bottom: 16px;
    }

        .post-header h4 {
            margin: 0;
