            font-size: 34px;
            font-weight: 900;
            color: #0f172a;
            margin: 0;
        }

        .blog-top p {
            color: #64748b;
            font-weight: 600;
            margin: 6px 0 0;
        }

    .blog-search {
        background: #f1f5f9;
        border-radius: 999px;
        padding: 13px 18px;
        display: flex;
        gap: 10px;
        align-items: center;
    }

        .blog-search input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            font-weight: 700;
        }

    .blog-tabs {
        background: white;
        border-radius: 18px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        overflow: hidden;
        margin-bottom: 24px;
        box-shadow: 0 8px 22px rgba(15,23,42,.08);
    }

    .blog-tab {
