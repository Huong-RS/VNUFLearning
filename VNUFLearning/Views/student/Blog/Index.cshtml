            border: none;
            outline: none;
            background: #f1f5f9;
            border-radius: 999px;
            padding: 12px 16px;
        }

        .comment-compose button,
        .reply-form button {
            width: 42px;
            height: 42px;
            border: none;
            border-radius: 50%;
