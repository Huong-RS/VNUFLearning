@model List<VNUFLearning.Models.BlogPost>

@{
    Layout = "~/Views/Shared/_LayoutStudent.cshtml";
    ViewData["Title"] = "Diễn đàn / Blog";

    var myPendingPosts = ViewBag.MyPendingPosts as List<VNUFLearning.Models.BlogPost> ?? new();
    var tab = ViewBag.Tab as string ?? "feed";
    var keyword = ViewBag.Keyword as string ?? "";
    int pendingCount = ViewBag.PendingCount ?? 0;
    int currentStudentId = ViewBag.CurrentStudentId ?? 0;
}

<div class="student-blog-page">
    <div class="blog-top">
        <div>
            <h1>Diễn đàn Lớp học</h1>
            <p>Chia sẻ bài viết học tập, trao đổi tài liệu và thảo luận cùng giảng viên.</p>
        </div>

        <form method="get" action="/Student/Blog" class="blog-search">
            <i class="fa fa-search"></i>
            <input name="keyword" value="@keyword" placeholder="Tìm kiếm bài viết..." />
        </form>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 fw-bold">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 fw-bold">@TempData["Error"]</div>
    }

    <div class="blog-tabs">
        <a href="/Student/Blog?tab=feed" class="blog-tab @(tab == "feed" ? "active" : "")">
            <i class="fa fa-newspaper"></i> Bảng tin
        </a>

        <a href="/Student/Blog?tab=pending" class="blog-tab @(tab == "pending" ? "active" : "")">
            <i class="fa fa-clock"></i> Bài chờ duyệt
            <span>@pendingCount</span>
        </a>
    </div>

    @if (tab == "feed")
    {
        <div class="create-post-card">
            <div class="avatar">SV</div>

            <form method="post" action="/Student/Blog/Create" enctype="multipart/form-data" class="create-post-form">
                @Html.AntiForgeryToken()

                <input name="Title" class="post-title-input" placeholder="Tiêu đề bài viết..." />

                <textarea name="Content"
                          class="post-content-input"
                          rows="3"
                          placeholder="Bạn muốn chia sẻ điều gì với lớp?"></textarea>

                <div class="create-actions">
                    <div class="upload-row">
                        <label class="upload-btn">
                            <i class="fa fa-image"></i> Ảnh/Video
                            <input type="file" name="imageFile" accept="image/*,video/mp4" hidden />
                        </label>

                        <label class="upload-btn">
                            <i class="fa fa-paperclip"></i> Đính kèm
                            <input type="file" name="attachmentFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" hidden />
                        </label>
                    </div>

                    <button type="submit" class="btn-post">Gửi duyệt</button>
                </div>
            </form>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-box">
                <i class="fa fa-newspaper"></i>
                <h3>Chưa có bài viết nào</h3>
                <p>Hãy là người đầu tiên chia sẻ bài viết học tập.</p>
            </div>
        }

        @foreach (var item in Model)
        {
            var canManagePost = item.AuthorId == currentStudentId;

            <div class="post-card">
                <div class="post-header">
                    <div class="avatar">
                        @item.Author.FullName.Substring(0, 1).ToUpper()
                    </div>

                    <div>
                        <h4>@item.Author.FullName</h4>
                        <p>@item.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>

                    @if (canManagePost)
                    {
                        <div class="post-header-actions ms-auto">
                            <button type="button"
                                    class="post-menu-trigger"
                                    onclick="togglePostMenu(@item.PostId, event)"
                                    aria-label="Tùy chọn bài viết"
                                    aria-expanded="false">
                                <i class="fa fa-ellipsis"></i>
                            </button>

                            <div class="post-options-menu" id="post-menu-@item.PostId">
                                <button type="button"
                                        class="post-option-item"
                                        onclick="openEditPost(@item.PostId); closePostMenus();">
                                    <i class="fa fa-pen"></i>
                                    <span>Chỉnh sửa bài viết</span>
                                </button>

                                <form method="post"
                                      action="/Student/Blog/Delete/@item.PostId"
                                      onsubmit="return confirm('Xóa bài viết này?');">
                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="post-option-item danger">
                                        <i class="fa fa-trash"></i>
                                        <span>Xóa bài viết</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                <h3 class="post-title" id="post-title-@item.PostId">@item.Title</h3>
                <p class="post-content" id="post-content-@item.PostId">@item.Content</p>

                @if (item.IsEdited)
                {
                    <button type="button"
                            class="edited-label"
                            onclick="showPostHistory(@item.PostId)">
                        Đã chỉnh sửa
                    </button>
                }

                @if (item.AuthorId == ViewBag.CurrentStudentId)
                {
                    <div class="edit-post-box" id="edit-post-@item.PostId">
                        <input id="edit-title-@item.PostId"
                               value="@item.Title"
                               class="edit-input" />

                        <textarea id="edit-content-@item.PostId"
                                  class="edit-textarea">@item.Content</textarea>

                        <label class="edit-check">
                            <input type="checkbox" id="remove-image-@item.PostId" />
                            Xóa ảnh/video hiện tại
                        </label>

                        <input type="file"
                               id="edit-image-@item.PostId"
                               accept="image/*,video/mp4"
                               class="edit-input" />

                        <label class="edit-check">
                            <input type="checkbox" id="remove-attachment-@item.PostId" />
                            Xóa file đính kèm hiện tại
                        </label>

                        <input type="file"
                               id="edit-attachment-@item.PostId"
                               accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar"
                               class="edit-input" />

                        <div class="edit-actions">
                            <button type="button" onclick="submitEditPost(@item.PostId)">Lưu thay đổi</button>
                            <button type="button" onclick="closeEditPost(@item.PostId)">Hủy</button>
                        </div>
                    </div>
                }


                <div id="post-image-wrap-@item.PostId">
                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                    {
                        if (item.ImageUrl.EndsWith(".mp4"))
                        {
                            <video src="@item.ImageUrl" class="post-image" controls></video>
                        }
                        else
                        {
                            <img src="@item.ImageUrl" class="post-image" />
                        }
                    }
                </div>
                <div id="post-attachment-wrap-@item.PostId">
                    @if (!string.IsNullOrWhiteSpace(item.AttachmentUrl))
                    {
                        <a href="/Student/Blog/Download/@item.PostId" class="attachment-box">
                            <div class="file-icon">
                                <i class="fa fa-file"></i>
                            </div>

                            <div>
                                <div class="fw-bold">@item.AttachmentName</div>
                                <div class="text-muted small">
                                    @item.AttachmentType
                                    @if (item.AttachmentSize.HasValue)
                                    {
                                        <span> · @((item.AttachmentSize.Value / 1024.0 / 1024.0).ToString("0.##")) MB</span>
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
                  

                <div class="post-meta">
                    <span>
                        <i class="fa fa-heart text-danger"></i>
                        <span id="like-count-@item.PostId">@item.BlogLikes.Count</span>
                    </span>

                    <span>
                        <span id="comment-count-@item.PostId">@item.Comments.Count(x => x.ParentCommentId == null)</span>
                        bình luận
                    </span>
                </div>

                <div class="post-action-bar">
                    <button type="button"
                            class="post-action-btn like-btn"
                            data-post-id="@item.PostId"
                            onclick="toggleLikeAjax(@item.PostId)">
                        <i class="fa fa-heart"></i> Thả tim
                    </button>

                    <button type="button"
                            class="post-action-btn"
                            onclick="toggleComment(@item.PostId)">
                        <i class="fa fa-comment"></i> Bình luận
                    </button>
                </div>

                <div id="comment-@item.PostId" class="comment-panel">
                    <div id="comment-list-@item.PostId">
                        @{
                            var commentViewData = new ViewDataDictionary(ViewData)
                            {
                                ["AllComments"] = item.Comments,
                                ["CurrentUserId"] = currentStudentId,
                                ["IsTeacher"] = false,
                                ["BlogPrefix"] = "/Student/Blog"
                            };
                        }

                        @foreach (var c in item.Comments.Where(x => x.ParentCommentId == null).OrderBy(x => x.CreatedAt))
                        {
                            @await Html.PartialAsync("~/Views/Shared/Partials/_BlogCommentTree.cshtml", c, commentViewData)
                        }
                    </div>

                    <form class="comment-compose" enctype="multipart/form-data" onsubmit="return submitCommentAjax(event, @item.PostId)">
                        @Html.AntiForgeryToken()

                        <div class="comment-avatar">SV</div>

                        <input name="content" placeholder="Viết bình luận công khai..." />
                        <label class="comment-file-btn">
                            <i class="fa fa-image"></i>
                            <input type="file" name="imageFile" accept="image/*,video/mp4" hidden />
                        </label>

                        <label class="comment-file-btn">
                            <i class="fa fa-paperclip"></i>
                            <input type="file" name="attachmentFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" hidden />
                        </label>

                        <button type="submit">
                            <i class="fa fa-paper-plane"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <div class="pending-note">
            <i class="fa fa-circle-info"></i>
            Bài viết của bạn sẽ hiển thị công khai sau khi được giảng viên phê duyệt.
        </div>

        @if (!myPendingPosts.Any())
        {
            <div class="empty-box">
                <i class="fa fa-check-circle"></i>
                <h3>Không có bài chờ duyệt</h3>
                <p>Bạn chưa gửi bài viết nào đang chờ phê duyệt.</p>
            </div>
        }

        @foreach (var item in myPendingPosts)
        {
            <div class="pending-card">
                <div class="post-header">
                    <div class="avatar orange">
                        @item.Author.FullName.Substring(0, 1).ToUpper()
                    </div>

                    <div>
                        <h4>@item.Author.FullName</h4>
                        <p>Gửi lúc @item.CreatedAt?.ToString("HH:mm dd/MM/yyyy")</p>
                    </div>

                    <span class="pending-badge">Chờ duyệt</span>
                </div>

                <h3 class="post-title">@item.Title</h3>
                <p class="post-content">@item.Content</p>
            </div>
        }
    }
</div>

<style>

    .post-header-actions {
        position: relative;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .post-header-actions form {
            margin: 0;
        }

    .post-menu-trigger {
        border: none;
        background: #f1f5f9;
        color: #475569;
        border-radius: 50%;
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background .2s ease, color .2s ease;
    }

        .post-menu-trigger:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    .post-options-menu {
        display: none;
        position: absolute;
        top: 44px;
        right: 0;
        z-index: 50;
        width: 220px;
        padding: 6px;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        box-shadow: 0 16px 40px rgba(15, 23, 42, .14);
    }

        .post-options-menu.show {
            display: block;
        }

        .post-options-menu form {
            margin: 0;
        }

    .post-option-item {
        width: 100%;
        border: none;
        background: transparent;
        color: #334155;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 10px;
        font-weight: 700;
        text-align: left;
        transition: background .2s ease, color .2s ease;
    }

        .post-option-item:hover {
            background: #f8fafc;
            color: #059669;
        }

        .post-option-item.danger {
            color: #e11d48;
        }

            .post-option-item.danger:hover {
                background: #fff1f2;
                color: #be123c;
            }

    .edit-icon-btn {
        border: none;
        background: #ecfdf5;
        color: #059669;
        border-radius: 10px;
        width: 38px;
        height: 38px;
    }

        .edit-icon-btn:hover {
            background: #d1fae5;
        }

    .edited-label {
        border: none;
        background: transparent;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        margin-top: 6px;
        padding: 0;
    }

        .edited-label:hover {
            color: #059669;
            text-decoration: underline;
        }

    .delete-btn {
        border: none;
        background: #fff1f2;
        color: #e11d48;
        border-radius: 10px;
        width: 38px;
        height: 38px;
    }

    .edit-post-box,
    .edit-comment-box {
        display: none;
        margin-top: 10px;
        padding: 12px;
        background: #f8fafc;
        border: 1px solid #dbe3ef;
        border-radius: 14px;
        gap: 8px;
    }

        .edit-post-box.show,
        .edit-comment-box.show {
            display: grid;
        }

    .edit-input,
    .edit-textarea {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: 10px 12px;
        outline: none;
    }

    .edit-textarea {
        min-height: 90px;
    }

    .edit-actions {
        display: flex;
        gap: 8px;
        margin-top: 8px;
    }

        .edit-actions button {
            border: none;
            border-radius: 10px;
            padding: 8px 14px;
            font-weight: 800;
        }

            .edit-actions button:first-child {
                background: #059669;
                color: white;
            }

            .edit-actions button:last-child {
                background: #e5e7eb;
                color: #334155;
            }
    .student-blog-page {
        max-width: 1080px;
        margin: 0 auto;
        padding-bottom: 60px;
    }

    .blog-top {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 24px;
        align-items: center;
        margin-bottom: 24px;
    }

