        }

    .pending-note {
        background: #fffbeb;
        border: 1px solid #facc15;
        color: #92400e;
        padding: 18px 22px;
        border-radius: 16px;
        margin-bottom: 22px;
        font-weight: 800;
    }

    .pending-badge {
        margin-left: auto;
        background: #fef3c7;
        color: #b45309;
        border-radius: 999px;
        padding: 8px 18px;
        font-weight: 900;
    }

    .empty-box {
        text-align: center;
        color: #64748b;
        padding: 50px;
    }

        .empty-box i {
            font-size: 46px;
            color: #10b981;
            margin-bottom: 16px;
        }

    .comment-file-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #eef2f7;
        color: #059669;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

        .comment-file-btn:hover {
            background: #dcfce7;
        }

    .comment-media {
        display: block;
        margin-top: 10px;
        max-width: 280px;
        max-height: 220px;
        border-radius: 14px;
        object-fit: cover;
        background: #fff;
    }

    .comment-attachment {
        margin-top: 10px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #ffffff;
        border: 1px solid #dbe3ef;
        border-radius: 12px;
        padding: 9px 12px;
        text-decoration: none;
        color: #0f172a;
        font-weight: 700;
    }
</style>

<script>
    function getToken() {
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        return tokenInput ? tokenInput.value : "";
    }

    function toggleComment(id) {
        const panel = document.getElementById("comment-" + id);
        if (!panel) return;

        panel.classList.toggle("show");

        if (panel.classList.contains("show")) {
            setTimeout(() => {
                panel.scrollIntoView({ behavior: "smooth", block: "center" });
            }, 150);
        }
    }

    function toggleReply(id) {
        const form = document.getElementById("reply-" + id);
        if (!form) return;

        form.classList.toggle("show");
    }

    async function toggleLikeAjax(postId) {
        const response = await fetch(`/Student/Blog/ToggleLikeAjax/${postId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            }
        });

        const data = await response.json();

        if (data.success) {
            document.getElementById(`like-count-${postId}`).innerText = data.count;

            const btn = document.querySelector(`.like-btn[data-post-id="${postId}"]`);
            if (btn) {
                btn.classList.toggle("liked", data.liked);
            }
        }
    }
    async function deleteComment(commentId) {
        if (!confirm("Xóa bình luận này?")) return;

        const response = await fetch(`/Student/Blog/DeleteComment/${commentId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            }
        });

        const data = await response.json();

        if (data.success) {
            const el = document.getElementById(`comment-item-${commentId}`);
            if (el) el.remove();
        }
    }

    async function submitCommentAjax(event, postId) {
        event.preventDefault();

        const form = event.target;
        const input = form.querySelector('input[name="content"]');
        const content = input.value.trim();
        const imageFile = form.querySelector('input[name="imageFile"]').files.length;
        const attachmentFile = form.querySelector('input[name="attachmentFile"]').files.length;

        if (!content && imageFile === 0 && attachmentFile === 0) return false;

        const body = new FormData(form);

        const response = await fetch(`/Student/Blog/CommentAjax/${postId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            },
            body
        });

        const data = await response.json();

        if (data.success) {
            const list = document.getElementById(`comment-list-${postId}`);

            list.insertAdjacentHTML("beforeend", `
                    <div class="comment-item" id="comment-item-${data.commentId}">
                        <div class="comment-avatar">${data.avatar}</div>
                        <div class="comment-right">
                            <div class="comment-bubble">
                                <div class="comment-name">${escapeHtml(data.userName)}</div>
    <div>${escapeHtml(data.content || "")}</div>
    ${renderCommentFiles(data)}
    </div>

                            <div class="comment-tools">
                                <button onclick="toggleReply(${data.commentId})" type="button">Phản hồi</button>
                                <span>${data.createdAt}</span>
                            </div>

                             <form id="reply-${data.commentId}"
          class="reply-form"
          enctype="multipart/form-data"
          onsubmit="return submitReplyAjax(event, ${data.commentId})">
        <input name="content" placeholder="Viết phản hồi..." />

        <label class="comment-file-btn">
            <i class="fa fa-image"></i>
            <input type="file" name="imageFile" accept="image/*,video/mp4" hidden />
        </label>

        <label class="comment-file-btn">
            <i class="fa fa-paperclip"></i>
            <input type="file" name="attachmentFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" hidden />
        </label>

        <button type="submit"><i class="fa fa-paper-plane"></i></button>
    </form>

                            <div id="reply-list-${data.commentId}"></div>
                        </div>
                    </div>
                `);

            input.value = "";
            form.reset();

            const countEl = document.getElementById(`comment-count-${postId}`);
            countEl.innerText = parseInt(countEl.innerText || "0") + 1;
        }

        return false;
    }

    async function submitReplyAjax(event, commentId) {
        event.preventDefault();

        const form = event.target;
        const input = form.querySelector('input[name="content"]');
        const content = input.value.trim();
        const imageFile = form.querySelector('input[name="imageFile"]')?.files.length || 0;
        const attachmentFile = form.querySelector('input[name="attachmentFile"]')?.files.length || 0;

        if (!content && imageFile === 0 && attachmentFile === 0) return false;

        const body = new FormData(form);

        const response = await fetch(`/Student/Blog/ReplyAjax/${commentId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            },
            body
        });

        const data = await response.json();

        if (data.success) {
            const list = document.getElementById(`reply-list-${commentId}`);

            list.insertAdjacentHTML("beforeend", `
                    <div class="reply-item">
                        <div class="comment-avatar small">${data.avatar}</div>
                        <div class="comment-bubble">
                            <div class="comment-name">${escapeHtml(data.userName)}</div>
    <div>${escapeHtml(data.content || "")}</div>
    ${renderCommentFiles(data)}
    </div>
                    </div>
                `);

            input.value = "";
            form.reset();
            form.classList.remove("show");
        }

        return false;
    }

    function escapeHtml(text) {
        const div = document.createElement("div");
        div.innerText = text;
        return div.innerHTML;
    }
    function renderCommentFiles(data) {
        let html = "";

        if (data.imageUrl) {
            if (data.imageUrl.toLowerCase().endsWith(".mp4")) {
                html += `<video src="${data.imageUrl}" class="comment-media" controls></video>`;
            } else {
                html += `<img src="${data.imageUrl}" class="comment-media" />`;
            }
        }

        if (data.attachmentUrl) {
            const prefix = location.pathname.toLowerCase().startsWith("/student")
                ? "/Student/Blog/DownloadCommentFile/"
                : "/Teacher/Blog/DownloadCommentFile/";

            const id = data.commentId || data.parentId;

            html += `
                <a href="${prefix}${id}" class="comment-attachment">
                    <i class="fa fa-file"></i>
                    <span>${escapeHtml(data.attachmentName || "Tệp đính kèm")}</span>
                </a>`;
        }

        return html;
    }
</script>