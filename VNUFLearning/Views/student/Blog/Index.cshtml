    }

    .comment-avatar {
        width: 42px;
        height: 42px;
        font-size: 14px;
    }

        .comment-avatar.small {
            width: 34px;
            height: 34px;
            font-size: 12px;
        }

    .comment-right {
        flex: 1;
    }

    .comment-bubble {
        background: #f1f5f9;
        padding: 11px 15px;
        border-radius: 18px;
        display: inline-block;
