@model List<VNUFLearning.Models.BlogPost>

@{
    Layout = "~/Views/Shared/_LayoutStudent.cshtml";
    ViewData["Title"] = "Diễn đàn / Blog";

    var myPendingPosts = ViewBag.MyPendingPosts as List<VNUFLearning.Models.BlogPost> ?? new();
    var tab = ViewBag.Tab as string ?? "feed";
    var keyword = ViewBag.Keyword as string ?? "";
    int pendingCount = ViewBag.PendingCount ?? 0;
    int currentStudentId = ViewBag.CurrentStudentId ?? 0;
}

<div class="student-blog-page">
    <div class="blog-top">
        <div>
            <h1>Diễn đàn Lớp học</h1>
            <p>Chia sẻ bài viết học tập, trao đổi tài liệu và thảo luận cùng giảng viên.</p>
        </div>

        <form method="get" action="/Student/Blog" class="blog-search">
            <i class="fa fa-search"></i>
            <input name="keyword" value="@keyword" placeholder="Tìm kiếm bài viết..." />
        </form>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 fw-bold">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 fw-bold">@TempData["Error"]</div>
    }

    <div class="blog-tabs">
        <a href="/Student/Blog?tab=feed" class="blog-tab @(tab == "feed" ? "active" : "")">
            <i class="fa fa-newspaper"></i> Bảng tin
        </a>

        <a href="/Student/Blog?tab=pending" class="blog-tab @(tab == "pending" ? "active" : "")">
            <i class="fa fa-clock"></i> Bài chờ duyệt
            <span>@pendingCount</span>
        </a>
    </div>

    @if (tab == "feed")
    {
        <div class="create-post-card">
            <div class="avatar">SV</div>

            <form method="post" action="/Student/Blog/Create" enctype="multipart/form-data" class="create-post-form">
                @Html.AntiForgeryToken()

                <input name="Title" class="post-title-input" placeholder="Tiêu đề bài viết..." />

                <textarea name="Content"
                          class="post-content-input"
                          rows="3"
                          placeholder="Bạn muốn chia sẻ điều gì với lớp?"></textarea>

                <div class="create-actions">
                    <div class="upload-row">
                        <label class="upload-btn">
                            <i class="fa fa-image"></i> Ảnh/Video
                            <input type="file" name="imageFile" accept="image/*,video/mp4" hidden />
                        </label>

                        <label class="upload-btn">
                            <i class="fa fa-paperclip"></i> Đính kèm
                            <input type="file" name="attachmentFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" hidden />
                        </label>
                    </div>

                    <button type="submit" class="btn-post">Gửi duyệt</button>
                </div>
            </form>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-box">
                <i class="fa fa-newspaper"></i>
                <h3>Chưa có bài viết nào</h3>
                <p>Hãy là người đầu tiên chia sẻ bài viết học tập.</p>
            </div>
        }

        @foreach (var item in Model)
        {
            <div class="post-card">
                <div class="post-header">
                    <div class="avatar">
                        @item.Author.FullName.Substring(0, 1).ToUpper()
                    </div>

                    <div>
                        <h4>@item.Author.FullName</h4>
                        <p>@item.CreatedAt?.ToString("dd/MM/yyyy HH:mm") · <i class="fa fa-earth-asia"></i></p>
                    </div>
                    @if (item.AuthorId == currentStudentId)
                    {
                        <form method="post"
                              action="/Student/Blog/Delete/@item.PostId"
                              onsubmit="return confirm('Xóa bài viết này?');"
                              class="ms-auto">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="delete-btn">
                                <i class="fa fa-trash"></i>
                            </button>
                        </form>
                    }
                </div>

                <h3 class="post-title">@item.Title</h3>
                <p class="post-content">@item.Content</p>

                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                {
                    if (item.ImageUrl.EndsWith(".mp4"))
                    {
                        <video src="@item.ImageUrl" class="post-image" controls></video>
                    }
                    else
                    {
                        <img src="@item.ImageUrl" class="post-image" />
                    }
                }

                @if (!string.IsNullOrWhiteSpace(item.AttachmentUrl))
                {
                    <a href="/Student/Blog/Download/@item.PostId" class="attachment-box">
                        <div class="file-icon">
                            <i class="fa fa-file"></i>
                        </div>

                        <div>
                            <div class="fw-bold">@item.AttachmentName</div>
                            <div class="text-muted small">
                                @item.AttachmentType
                                @if (item.AttachmentSize.HasValue)
                                {
                                    <span> · @((item.AttachmentSize.Value / 1024.0 / 1024.0).ToString("0.##")) MB</span>
                                }
                            </div>
                        </div>
                    </a>
                }

                <div class="post-meta">
                    <span>
                        <i class="fa fa-heart text-danger"></i>
                        <span id="like-count-@item.PostId">@item.BlogLikes.Count</span>
                    </span>

                    <span>
                        <span id="comment-count-@item.PostId">@item.Comments.Count(x => x.ParentCommentId == null)</span>
                        bình luận
                    </span>
                </div>

                <div class="post-action-bar">
                    <button type="button"
                            class="post-action-btn like-btn"
                            data-post-id="@item.PostId"
                            onclick="toggleLikeAjax(@item.PostId)">
                        <i class="fa fa-heart"></i> Thả tim
                    </button>

                    <button type="button"
                            class="post-action-btn"
                            onclick="toggleComment(@item.PostId)">
                        <i class="fa fa-comment"></i> Bình luận
                    </button>
                </div>

                <div id="comment-@item.PostId" class="comment-panel">
                    <div id="comment-list-@item.PostId">
                        @foreach (var c in item.Comments.Where(x => x.ParentCommentId == null).OrderBy(x => x.CreatedAt))
                        {
                            <div class="comment-item" id="comment-item-@c.CommentId">
                                <div class="comment-avatar">
                                    @c.User.FullName.Substring(0, 1).ToUpper()
                                </div>

                                <div class="comment-right">
                                    <div class="comment-bubble">
                                        <div class="comment-name">@c.User.FullName</div>
                                        <div>@c.Content</div>
                                        @if (!string.IsNullOrWhiteSpace(c.ImageUrl))
                                        {
                                            if (c.ImageUrl.EndsWith(".mp4"))
                                            {
                                                <video src="@c.ImageUrl" class="comment-media" controls></video>
                                            }
                                            else
                                            {
                                                <img src="@c.ImageUrl" class="comment-media" />
                                            }
                                        }

                                        @if (!string.IsNullOrWhiteSpace(c.AttachmentUrl))
                                        {
                                            var downloadUrl = Context.Request.Path.Value!.StartsWith("/Student")
                                            ? $"/Student/Blog/DownloadCommentFile/{c.CommentId}"
                                            : $"/Teacher/Blog/DownloadCommentFile/{c.CommentId}";

                                            <a href="@downloadUrl" class="comment-attachment">
                                                <i class="fa fa-file"></i>
                                                <span>@c.AttachmentName</span>
                                            </a>
                                        }
                                    </div>

                                    <div class="comment-tools">
                                        <button type="button" onclick="toggleReply(@c.CommentId)">Phản hồi</button>
                                        <span>@c.CreatedAt?.ToString("HH:mm dd/MM")</span>
                                        @if (c.UserId == currentStudentId)
                                        {
                                            <button type="button" onclick="deleteComment(@c.CommentId)">Xóa</button>
                                        }
                                    </div>

                                    <form id="reply-@c.CommentId"
                                          class="reply-form"
                                          enctype="multipart/form-data"
                                          onsubmit="return submitReplyAjax(event, @c.CommentId)">
                                        @Html.AntiForgeryToken()

                                        <input name="content" placeholder="Viết phản hồi..." />

                                        <label class="comment-file-btn">
                                            <i class="fa fa-image"></i>
                                            <input type="file"
                                                   name="imageFile"
                                                   accept="image/*,video/mp4"
                                                   hidden />
                                        </label>

                                        <label class="comment-file-btn">
                                            <i class="fa fa-paperclip"></i>
                                            <input type="file"
                                                   name="attachmentFile"
                                                   accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar"
                                                   hidden />
                                        </label>

                                        <button type="submit">
                                            <i class="fa fa-paper-plane"></i>
                                        </button>
                                    </form>

                                    <div id="reply-list-@c.CommentId">
                                        @foreach (var r in c.Replies.OrderBy(x => x.CreatedAt))
                                        {
                                            <div class="reply-item" id="comment-item-@r.CommentId">
                                                <div class="comment-avatar small">
                                                    @r.User.FullName.Substring(0, 1).ToUpper()
                                                </div>

                                                <div class="comment-bubble">
                                                    <div class="comment-name">@r.User.FullName</div>
                                                    <div>@r.Content</div>
                                                    @if (!string.IsNullOrWhiteSpace(r.ImageUrl))
                                                    {
                                                        if (r.ImageUrl.EndsWith(".mp4"))
                                                        {
                                                            <video src="@r.ImageUrl" class="comment-media" controls></video>
                                                        }
                                                        else
                                                        {
                                                            <img src="@r.ImageUrl" class="comment-media" />
                                                        }
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(r.AttachmentUrl))
                                                    {
                                                        var downloadUrl = Context.Request.Path.Value!.StartsWith("/Student")
                                                        ? $"/Student/Blog/DownloadCommentFile/{r.CommentId}"
                                                        : $"/Teacher/Blog/DownloadCommentFile/{r.CommentId}";

                                                        <a href="@downloadUrl" class="comment-attachment">
                                                            <i class="fa fa-file"></i>
                                                            <span>@r.AttachmentName</span>
                                                        </a>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <form class="comment-compose" enctype="multipart/form-data" onsubmit="return submitCommentAjax(event, @item.PostId)">
                        @Html.AntiForgeryToken()

                        <div class="comment-avatar">SV</div>

                        <input name="content" placeholder="Viết bình luận công khai..." />
                        <label class="comment-file-btn">
                            <i class="fa fa-image"></i>
                            <input type="file" name="imageFile" accept="image/*,video/mp4" hidden />
                        </label>

                        <label class="comment-file-btn">
                            <i class="fa fa-paperclip"></i>
                            <input type="file" name="attachmentFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" hidden />
                        </label>

                        <button type="submit">
                            <i class="fa fa-paper-plane"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <div class="pending-note">
            <i class="fa fa-circle-info"></i>
            Bài viết của bạn sẽ hiển thị công khai sau khi được giảng viên phê duyệt.
        </div>

        @if (!myPendingPosts.Any())
        {
            <div class="empty-box">
                <i class="fa fa-check-circle"></i>
                <h3>Không có bài chờ duyệt</h3>
                <p>Bạn chưa gửi bài viết nào đang chờ phê duyệt.</p>
            </div>
        }

        @foreach (var item in myPendingPosts)
        {
            <div class="pending-card">
                <div class="post-header">
                    <div class="avatar orange">
                        @item.Author.FullName.Substring(0, 1).ToUpper()
                    </div>

                    <div>
                        <h4>@item.Author.FullName</h4>
                        <p>Gửi lúc @item.CreatedAt?.ToString("HH:mm dd/MM/yyyy")</p>
                    </div>

                    <span class="pending-badge">Chờ duyệt</span>
                </div>

                <h3 class="post-title">@item.Title</h3>
                <p class="post-content">@item.Content</p>
            </div>
        }
    }
</div>

<style>
