            height: 42px;
            border: none;
            border-radius: 50%;
            background: #059669;
            color: white;
        }

    .pending-note {
        background: #fffbeb;
        border: 1px solid #facc15;
        color: #92400e;
        padding: 18px 22px;
        border-radius: 16px;
        margin-bottom: 22px;
        font-weight: 800;
    }

    .pending-badge {
        margin-left: auto;
        background: #fef3c7;
        color: #b45309;
        border-radius: 999px;
        padding: 8px 18px;
        font-weight: 900;
    }

    .empty-box {
        text-align: center;
        color: #64748b;
        padding: 50px;
    }

        .empty-box i {
            font-size: 46px;
            color: #10b981;
            margin-bottom: 16px;
        }

    .comment-file-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #eef2f7;
        color: #059669;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

        .comment-file-btn:hover {
            background: #dcfce7;
        }

    .comment-media {
        display: block;
        margin-top: 10px;
        max-width: 280px;
        max-height: 220px;
        border-radius: 14px;
        object-fit: cover;
        background: #fff;
    }

    .comment-attachment {
        margin-top: 10px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #ffffff;
        border: 1px solid #dbe3ef;
        border-radius: 12px;
        padding: 9px 12px;
        text-decoration: none;
        color: #0f172a;
        font-weight: 700;
    }
</style>
<script>
    const blogConnection = new signalR.HubConnectionBuilder()
        .withUrl("/blogHub")
        .withAutomaticReconnect()
        .build();

    blogConnection.start()
        .then(() => console.log("BlogHub connected"))
        .catch(err => console.error(err));

    function getToken() {
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        return tokenInput ? tokenInput.value : "";
    }

    function closePostMenus() {
        document.querySelectorAll(".post-options-menu.show")
            .forEach(menu => menu.classList.remove("show"));
    }

    function togglePostMenu(id, event) {
        event?.stopPropagation();

        const menu = document.getElementById(`post-menu-${id}`);
        if (!menu) return;

        const shouldOpen = !menu.classList.contains("show");
        closePostMenus();

        if (shouldOpen) {
            menu.classList.add("show");
        }
    }

    document.addEventListener("click", (event) => {
        if (!event.target.closest(".post-header-actions")) {
            closePostMenus();
        }
    });

    function escapeHtml(text) {
        const div = document.createElement("div");
        div.innerText = text || "";
        return div.innerHTML;
    }

    function toggleComment(id) {
        const panel = document.getElementById("comment-" + id);
        if (!panel) return;

        panel.classList.toggle("show");

        if (panel.classList.contains("show")) {
            setTimeout(() => {
                panel.scrollIntoView({ behavior: "smooth", block: "center" });
            }, 150);
        }
    }

    function toggleReply(id) {
        const form = document.getElementById("reply-" + id);
        if (!form) return;

        form.classList.toggle("show");
    }

    function openEditPost(id) {
        document.getElementById(`edit-post-${id}`)?.classList.add("show");
    }

    function closeEditPost(id) {
        document.getElementById(`edit-post-${id}`)?.classList.remove("show");
    }

    function openEditComment(id) {
        document.getElementById(`edit-comment-${id}`)?.classList.add("show");
    }

    function closeEditComment(id) {
        document.getElementById(`edit-comment-${id}`)?.classList.remove("show");
    }

    async function toggleLikeAjax(postId) {
        const response = await fetch(`/Student/Blog/ToggleLikeAjax/${postId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            }
        });

        const data = await response.json();

        if (data.success) {
            document.getElementById(`like-count-${postId}`).innerText = data.count;

            const btn = document.querySelector(`.like-btn[data-post-id="${postId}"]`);
            if (btn) btn.classList.toggle("liked", data.liked);
        }
    }

    async function deleteComment(commentId) {
        if (!confirm("Xóa bình luận này?")) return;

        const response = await fetch(`/Student/Blog/DeleteComment/${commentId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            }
        });

        const data = await response.json();

        if (data.success) {
            const el = document.getElementById(`comment-item-${commentId}`);
            if (el) el.remove();
        } else {
            alert(data.message || "Không xóa được bình luận.");
        }
    }

    function renderCommentFiles(data) {
        let html = "";

        if (data.imageUrl) {
            if (data.imageUrl.toLowerCase().endsWith(".mp4")) {
                html += `<video src="${data.imageUrl}" class="comment-media" controls></video>`;
            } else {
                html += `<img src="${data.imageUrl}" class="comment-media" />`;
            }
        }

        if (data.attachmentUrl) {
            const id = data.commentId || data.parentId;

            html += `
                    <a href="/Student/Blog/DownloadCommentFile/${id}" class="comment-attachment">
                        <i class="fa fa-file"></i>
                        <span>${escapeHtml(data.attachmentName || "Tệp đính kèm")}</span>
                    </a>`;
        }

        return html;
    }

    function renderEditCommentBox(id, content, placeholder) {
        return `
                <div class="edit-comment-box" id="edit-comment-${id}">
                    <input id="edit-comment-input-${id}"
                           value="${escapeHtml(content || "")}"
                           class="edit-input"
                           placeholder="${placeholder}" />

                    <div class="edit-actions">
                        <button type="button" onclick="submitEditComment(${id})">Lưu</button>
                        <button type="button" onclick="closeEditComment(${id})">Hủy</button>
                    </div>
                </div>`;
    }

    function renderReplyForm(id) {
        return `
                <form id="reply-${id}"
                      class="reply-form"
                      enctype="multipart/form-data"
                      onsubmit="return submitReplyAjax(event, ${id})">
                    <input name="content" placeholder="Viết phản hồi..." />

                    <label class="comment-file-btn">
                        <i class="fa fa-image"></i>
                        <input type="file" name="imageFile" accept="image/*,video/mp4" hidden />
                    </label>

                    <label class="comment-file-btn">
                        <i class="fa fa-paperclip"></i>
                        <input type="file" name="attachmentFile" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.zip,.rar" hidden />
                    </label>

                    <button type="submit"><i class="fa fa-paper-plane"></i></button>
                </form>`;
    }

    async function submitCommentAjax(event, postId) {
        event.preventDefault();

        const form = event.target;
        const input = form.querySelector('input[name="content"]');
        const content = input.value.trim();
        const imageFile = form.querySelector('input[name="imageFile"]').files.length;
        const attachmentFile = form.querySelector('input[name="attachmentFile"]').files.length;

        if (!content && imageFile === 0 && attachmentFile === 0) return false;

        const body = new FormData(form);

        const response = await fetch(`/Student/Blog/CommentAjax/${postId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            },
            body
        });

        const data = await response.json();

        if (data.success) {
            const list = document.getElementById(`comment-list-${postId}`);

            list.insertAdjacentHTML("beforeend", `
                    <div class="comment-item" id="comment-item-${data.commentId}">
                        <div class="comment-avatar">${data.avatar}</div>

                        <div class="comment-right">
                            <div class="comment-bubble">
                                <div class="comment-name">${escapeHtml(data.userName)}</div>
                                <div id="comment-content-${data.commentId}">${escapeHtml(data.content || "")}</div>
                                ${renderCommentFiles(data)}
                            </div>

                            <div class="comment-tools">
                                <button type="button" onclick="toggleReply(${data.commentId})">Phản hồi</button>
                                <button type="button" onclick="openEditComment(${data.commentId})">Sửa</button>
                                <button type="button" onclick="deleteComment(${data.commentId})">Xóa</button>
                                <span>${data.createdAt || ""}</span>
                            </div>

                            ${renderEditCommentBox(data.commentId, data.content, "Sửa nội dung bình luận...")}

                            ${renderReplyForm(data.commentId)}

                            <div id="reply-list-${data.commentId}" class="reply-list"></div>
                        </div>
                    </div>
                `);

            form.reset();

            const countEl = document.getElementById(`comment-count-${postId}`);
            countEl.innerText = parseInt(countEl.innerText || "0") + 1;
        }

        return false;
    }

    async function submitReplyAjax(event, commentId) {
        event.preventDefault();

        const form = event.target;
        const input = form.querySelector('input[name="content"]');
        const content = input.value.trim();
        const imageFile = form.querySelector('input[name="imageFile"]')?.files.length || 0;
        const attachmentFile = form.querySelector('input[name="attachmentFile"]')?.files.length || 0;

        if (!content && imageFile === 0 && attachmentFile === 0) return false;

        const body = new FormData(form);

        const response = await fetch(`/Student/Blog/ReplyAjax/${commentId}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            },
            body
        });

        const data = await response.json();

        if (data.success) {
            const list = document.getElementById(`reply-list-${commentId}`);

            list.insertAdjacentHTML("beforeend", `
                    <div class="reply-item" id="comment-item-${data.commentId}">
                        <div class="comment-avatar small">${data.avatar}</div>

                        <div>
                            <div class="comment-bubble">
                                <div class="comment-name">${escapeHtml(data.userName)}</div>
                                <div id="comment-content-${data.commentId}">${escapeHtml(data.content || "")}</div>
                                ${renderCommentFiles(data)}
                            </div>

                            <div class="comment-tools">
                                <button type="button" onclick="toggleReply(${data.commentId})">Phản hồi</button>
                                <button type="button" onclick="openEditComment(${data.commentId})">Sửa</button>
                                <button type="button" onclick="deleteComment(${data.commentId})">Xóa</button>
                            </div>

                            ${renderEditCommentBox(data.commentId, data.content, "Sửa nội dung phản hồi...")}
                            ${renderReplyForm(data.commentId)}
                            <div id="reply-list-${data.commentId}" class="reply-list"></div>
                        </div>
                    </div>
                `);

            form.reset();
            form.classList.remove("show");
        }

        return false;
    }

    async function submitEditComment(id) {
        const input = document.getElementById(`edit-comment-input-${id}`);
        if (!input) return;

        const content = input.value.trim();

        const body = new FormData();
        body.append("content", content);

        const response = await fetch(`/Student/Blog/EditComment/${id}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            },
            body
        });

        const data = await response.json();

        if (!data.success) {
            alert(data.message || "Không thể sửa bình luận.");
            return;
        }

        document.getElementById(`comment-content-${id}`).innerText = data.content;

        closeEditComment(id);
        alert("Đã cập nhật bình luận.");
    }

    async function submitEditPost(id) {
        const title = document.getElementById(`edit-title-${id}`).value.trim();
        const content = document.getElementById(`edit-content-${id}`).value.trim();

        const imageInput = document.getElementById(`edit-image-${id}`);
        const attachmentInput = document.getElementById(`edit-attachment-${id}`);

        const body = new FormData();
        body.append("title", title);
        body.append("content", content);
        body.append("removeImage", document.getElementById(`remove-image-${id}`).checked);
        body.append("removeAttachment", document.getElementById(`remove-attachment-${id}`).checked);

        if (imageInput.files.length > 0) body.append("imageFile", imageInput.files[0]);
        if (attachmentInput.files.length > 0) body.append("attachmentFile", attachmentInput.files[0]);

        const response = await fetch(`/Student/Blog/EditPost/${id}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": getToken()
            },
            body
        });

        const data = await response.json();

        if (!data.success) {
            alert(data.message || "Không thể sửa bài viết.");
            return;
        }

        document.getElementById(`post-title-${id}`).innerText = data.title;
        document.getElementById(`post-content-${id}`).innerText = data.content;

        const imageWrap = document.getElementById(`post-image-wrap-${id}`);
        if (imageWrap) {
            if (data.imageUrl) {
                const lower = data.imageUrl.toLowerCase();
                imageWrap.innerHTML = lower.endsWith(".mp4")
                    ? `<video src="${data.imageUrl}" class="post-image" controls></video>`
                    : `<img src="${data.imageUrl}" class="post-image" />`;
            } else {
                imageWrap.innerHTML = "";
            }
        }

        const attachmentWrap = document.getElementById(`post-attachment-wrap-${id}`);
        if (attachmentWrap) {
            if (data.attachmentUrl) {
                attachmentWrap.innerHTML = `
                        <a href="/Student/Blog/Download/${id}" class="attachment-box">
                            <div class="file-icon"><i class="fa fa-file"></i></div>
                            <div>
                                <div class="fw-bold">${escapeHtml(data.attachmentName || "Tệp đính kèm")}</div>
                                <div class="text-muted small">${escapeHtml(data.attachmentType || "")} · ${escapeHtml(data.attachmentSize || "")}</div>
                            </div>
                        </a>`;
            } else {
                attachmentWrap.innerHTML = "";
            }
        }

        document.getElementById(`remove-image-${id}`).checked = false;
        document.getElementById(`remove-attachment-${id}`).checked = false;
        imageInput.value = "";
        attachmentInput.value = "";

        closeEditPost(id);
        alert("Đã cập nhật bài viết.");
    }

    async function showPostHistory(id) {
        const response = await fetch(`/Student/Blog/PostHistory/${id}`);
        const data = await response.json();

        if (!data.length) {
            alert("Chưa có lịch sử chỉnh sửa.");
            return;
        }

        let text = "LỊCH SỬ CHỈNH SỬA BÀI VIẾT\n\n";

        data.forEach((x, index) => {
            text += `Lần ${index + 1} - ${x.editedAt} bởi ${x.editedBy}\n`;
            text += `Tiêu đề cũ: ${x.oldTitle || ""}\n`;
            text += `Nội dung cũ: ${x.oldContent || ""}\n\n`;
        });

        alert(text);
    }

    async function showCommentHistory(id) {
        const response = await fetch(`/Student/Blog/CommentHistory/${id}`);
        const data = await response.json();

        if (!data.length) {
            alert("Chưa có lịch sử chỉnh sửa.");
            return;
        }

        let text = "LỊCH SỬ CHỈNH SỬA BÌNH LUẬN\n\n";

        data.forEach((x, index) => {
            text += `Lần ${index + 1} - ${x.editedAt} bởi ${x.editedBy}\n`;
            text += `Nội dung cũ: ${x.oldContent || ""}\n\n`;
        });

        alert(text);
    }
</script>
