    }

    .post-action-bar {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-top: 1px solid #e5e7eb;
        margin-top: 14px;
    }

    .post-action-btn {
        width: 100%;
        border: none;
        background: white;
