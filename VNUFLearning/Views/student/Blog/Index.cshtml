    }

    .comment-name {
        font-weight: 900;
        margin-bottom: 3px;
    }

    .comment-tools {
        display: flex;
        gap: 12px;
        margin-left: 12px;
        margin-top: 4px;
        color: #64748b;
        font-size: 13px;
    }

        .comment-tools button {
