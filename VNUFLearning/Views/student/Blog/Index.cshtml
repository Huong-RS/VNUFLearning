    }

    .comment-compose {
        margin-top: 18px;
    }

    .reply-form {
        display: none;
        margin-top: 8px;
    }

        .comment-compose input,
        .reply-form input {
            flex: 1;
            border: none;
            outline: none;
            background: #f1f5f9;
            border-radius: 999px;
