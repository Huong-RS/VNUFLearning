@model VNUFLearning.Models.Subject

@{
    ViewData["Title"] = "Thêm Môn học";
}

<div class="container mt-4">
    <h1>Thêm Môn Học Mới</h1>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold">Tên Môn Học</label>
                    <input asp-for="SubjectName" class="form-control" placeholder="Ví dụ: Lập trình Web" required />
                    <span asp-validation-for="SubjectName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold">Mô Tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input type="submit" value="Lưu lại" class="btn btn-success" />
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>