@model IEnumerable<VNUFLearning.Models.Subject>

@{
    ViewData["Title"] = "Quản lý Môn học";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold text-primary">📚 Quản lý Môn học</h3>

        <a asp-action="Create" class="btn btn-success">
            <i class="fa fa-plus"></i> Thêm môn học
        </a>
    </div>

    <!-- 🔎 SEARCH -->
    <form method="get" class="row mb-3">
        <div class="col-md-4">
            <input name="keyword" class="form-control"
                   placeholder="Tìm môn học..." value="@Context.Request.Query["keyword"]" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100">Tìm</button>
        </div>
    </form>

    <div class="card shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark text-center">
                <tr>
                    <th style="width:60px">#</th>
                    <th class="text-start">Tên môn</th>
                    <th>Mô tả</th>
                    <th>Số câu hỏi</th>
                    <th style="width:150px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int stt = 1;
                }

                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">@stt</td>

                        <td class="fw-semibold text-primary">
                            @item.SubjectName
                        </td>

                        <td>@item.Description</td>

                        <td class="text-center">
                            <span class="badge bg-info">
                                @item.Questions.Count
                            </span>
                        </td>

                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.SubjectId"
                               class="btn btn-sm btn-warning">
                                <i class="fa fa-edit"></i>
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.SubjectId"
                               class="btn btn-sm btn-danger"
                               onclick="return confirm('Xóa môn này?')">
                                <i class="fa fa-trash"></i>
                            </a>
                        </td>
                    </tr>

                    stt++;
                }
            </tbody>
        </table>
    </div>
</div>
