@model VNUFLearning.Models.Question

@{
    ViewData["Title"] = "Chỉnh sửa câu hỏi";
}

<!-- Select2 CSS (nếu bạn đã đưa vào _Layout.cshtml thì có thể xóa dòng này) -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    .select2-container .select2-selection--single {
        height: 38px !important;
        border: 1px solid #ced4da;
        border-radius: .375rem;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 36px !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 36px !important;
    }
</style>

<div class="container mt-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0"><i class="fa fa-edit"></i> Chỉnh sửa câu hỏi</h5>
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <!-- Giữ ID câu hỏi -->
                <input type="hidden" asp-for="QuestionId" />

                <div class="row mb-3">
                    <div class="col-md-7">
                        <label class="form-label fw-bold">Môn học <span class="text-danger">*</span></label>
                        <select asp-for="SubjectId"
                                class="form-select select2-dropdown"
                                asp-items="ViewBag.SubjectId">
                        </select>
                    </div>

                    <div class="col-md-5">
                        <label class="form-label fw-bold">Loại câu hỏi</label>
                        <select asp-for="QuestionType" class="form-select" id="questionType" onchange="toggleOptions()">
                            <option value="1">🔵 Trắc nghiệm</option>
                            <option value="2">🟠 Tự luận</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Nội dung câu hỏi <span class="text-danger">*</span></label>
                    <textarea asp-for="Content" class="form-control" rows="4" required></textarea>
                </div>

                <!-- KHU VỰC TRẮC NGHIỆM -->
                <div id="multipleChoiceArea" class="bg-light p-3 rounded border">
                    <label class="fw-bold mb-2 text-primary">Các phương án lựa chọn:</label>

                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <div class="input-group">
                                <span class="input-group-text">A</span>
                                <input asp-for="OptionA" class="form-control" id="optA" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="input-group">
                                <span class="input-group-text">B</span>
                                <input asp-for="OptionB" class="form-control" id="optB" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="input-group">
                                <span class="input-group-text">C</span>
                                <input asp-for="OptionC" class="form-control" id="optC" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="input-group">
                                <span class="input-group-text">D</span>
                                <input asp-for="OptionD" class="form-control" id="optD" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-1">
                        <label class="fw-bold text-success">Đáp án đúng:</label>
                        <select asp-for="CorrectAnswer"
                                class="form-select w-auto d-inline-block ms-2"
                                id="mcCorrect">
                            <option value="A">A</option>
                            <option value="B">B</option>
                            <option value="C">C</option>
                            <option value="D">D</option>
                        </select>
                    </div>
                </div>

                <!-- KHU VỰC TỰ LUẬN -->
                <div id="essayArea" class="d-none bg-warning bg-opacity-10 p-3 rounded border border-warning mt-3">
                    <label class="fw-bold text-dark">💡 Gợi ý trả lời / Từ khóa chấm điểm:</label>

                    <!-- KHÔNG DISABLED để còn submit lên server -->
                    <textarea asp-for="CorrectAnswer"
                              class="form-control mt-2"
                              rows="3"
                              id="essayCorrect"></textarea>
                </div>

                <div class="text-end mt-4">
                    <a asp-action="Index" class="btn btn-secondary me-2">Hủy bỏ</a>
                    <button type="submit" class="btn btn-warning px-4 fw-bold">
                        <i class="fa fa-save"></i> Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- jQuery + Select2 JS (nếu đã đưa vào _Layout.cshtml thì xóa 2 dòng này) -->


<script>
    $(document).ready(function () {
        // Kích hoạt Select2
        $('.select2-dropdown').select2({
            placeholder: "Tìm kiếm môn học...",
            allowClear: true,
            width: '100%'
        });

        // Load trang xong là ẩn/hiện đúng theo loại câu hỏi hiện tại
        toggleOptions();
    });

    function toggleOptions() {
        var type = document.getElementById("questionType").value;
        var mcArea = document.getElementById("multipleChoiceArea");
        var essayArea = document.getElementById("essayArea");

        // Các input thuộc trắc nghiệm
        var inputsTN = document.querySelectorAll('#optA, #optB, #optC, #optD, #mcCorrect');

        if (type === "1") { // Trắc nghiệm
            mcArea.classList.remove("d-none");
            essayArea.classList.add("d-none");

            // bật nhóm trắc nghiệm
            inputsTN.forEach(el => el.removeAttribute("disabled"));
        } else { // Tự luận
            mcArea.classList.add("d-none");
            essayArea.classList.remove("d-none");

            // tắt nhóm trắc nghiệm (tránh gửi rác)
            inputsTN.forEach(el => el.setAttribute("disabled", "disabled"));
        }
    }
</script>
