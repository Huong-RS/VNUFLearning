@model IEnumerable<VNUFLearning.Models.Question>
@{
    ViewData["Title"] = "Danh mục câu hỏi";
}

<div class="container-fluid mt-4">

    <!-- ===== HEADER ===== -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold text-primary">Ngân hàng câu hỏi</h4>

        <div>

            <!-- NÚT EXPORT ĐÃ SỬA -->
            <a id="btnExport"
               class="btn btn-outline-secondary">
                Xuất danh sách
            </a>


            <button class="btn btn-success me-2"
                    data-bs-toggle="modal"
                    data-bs-target="#importModal">
                <i class="fa fa-upload"></i> Import
            </button>

            <a asp-action="Create" class="btn btn-primary">
                <i class="fa fa-plus"></i> Thêm mới
            </a>
        </div>
    </div>


    <!-- ===== ĐIỀU KIỆN TRA CỨU ===== -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light fw-semibold">
            Điều kiện tra cứu
        </div>

        <div class="card-body">
            <form method="get" class="row g-3">

                <div class="col-md-4">
                    <label class="form-label">Nội dung</label>
                    <input name="keyword"
                           class="form-control"
                           placeholder="Nhập nội dung câu hỏi..."
                           value="@Context.Request.Query["keyword"]" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Môn học</label>
                    <select id="subjectId"
                            name="subjectId"
                            asp-items="ViewBag.SubjectList"
                            class="form-select">
                        <option value="">-- Chọn môn học --</option>
                    </select>
                </div>

                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-primary me-2">
                        <i class="fa fa-search"></i> Tìm kiếm
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fa fa-rotate"></i> Làm mới
                    </a>
                </div>

            </form>
        </div>
    </div>


    <!-- ===== DANH SÁCH ===== -->
    <div class="card shadow-sm">
        <div class="card-header bg-light fw-semibold">
            Danh sách câu hỏi
        </div>

        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-primary text-center">
                    <tr>
                        <th style="width:5%">STT</th>
                        <th style="width:40%">Nội dung</th>
                        <th style="width:15%">Môn học</th>
                        <th style="width:15%">Loại</th>
                        <th style="width:10%">Đáp án</th>
                        <th style="width:15%">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        int stt = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@stt</td>

                            <td>
                                <div class="fw-semibold">@item.Content</div>
                            </td>

                            <td>@item.Subject.SubjectName</td>

                            <td class="text-center">
                                @if (item.QuestionType == 1)
                                {
                                    <span class="badge bg-info">Trắc nghiệm</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Tự luận</span>
                                }
                            </td>

                            <td class="text-center fw-bold text-success">
                                @item.CorrectAnswer
                            </td>

                            <td class="text-center">
                                <a asp-action="Edit"
                                   asp-route-id="@item.QuestionId"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fa fa-edit"></i>
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.QuestionId"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </td>
                        </tr>

                        stt++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


<!-- ===== MODAL IMPORT ===== -->
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form asp-action="Import"
                  method="post"
                  enctype="multipart/form-data">

                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        Import ngân hàng câu hỏi
                    </h5>
                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Chọn tệp tin</label>
                        <input type="file"
                               name="fileExcel"
                               class="form-control"
                               required />
                    </div>
                </div>

                <div class="modal-footer d-flex justify-content-between">

                    <a asp-action="DownloadTemplate"
                       class="btn btn-success">
                        <i class="bi bi-download"></i> Tải file mẫu
                    </a>

                    <div>
                        <button type="submit"
                                class="btn btn-primary">
                            Xác nhận import
                        </button>

                        <button type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Hủy
                        </button>
                    </div>

                </div>

            </form>

        </div>
    </div>
</div>


<!-- ===== SCRIPT EXPORT THEO MÔN ===== -->
<script>
    document.getElementById("btnExport").addEventListener("click", function () {

        var subjectDropdown = document.getElementById("subjectId");

        var subjectId = subjectDropdown ? subjectDropdown.value : "";

        var url = "/Questions/Export";

        if (subjectId && subjectId !== "") {
            url += "?subjectId=" + subjectId;
        }

        window.location.href = url;
    });
</script>
