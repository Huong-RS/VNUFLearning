@model IEnumerable<VNUFLearning.Models.Question>
@{
    // Tự động chọn Layout dựa trên người đang đăng nhập
    Layout = User.IsInRole("Admin") ? "~/Views/Shared/_LayoutAdmin.cshtml" : "~/Views/Shared/_LayoutTeacher.cshtml";
    ViewData["Title"] = "Danh mục câu hỏi";
}

<div class="container-fluid mt-2">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1" style="color: #005b33;"><i class="fa fa-database me-2"></i>Ngân hàng Câu hỏi</h3>
            <p class="text-muted small">Quản lý kho lưu trữ câu hỏi trắc nghiệm và tự luận.</p>
        </div>
        <div>
            <a id="btnExport" class="btn btn-outline-success bg-opacity-10 fw-bold rounded-pill px-3 me-2" style="cursor: pointer;">
                <i class="fa fa-download me-1"></i> Xuất Excel
            </a>
            <button class="btn btn-success fw-bold rounded-pill px-3 me-2" style="background-color: #005b33;" data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="fa fa-upload me-1"></i> Import
            </button>
            <a asp-action="Create" class="btn btn-success fw-bold rounded-pill px-3" style="background-color: #005b33;">
                <i class="fa fa-plus me-1"></i> Thêm mới
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4 rounded-4 bg-white">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold">Nội dung câu hỏi</label>
                    <input name="keyword" class="form-control bg-light" placeholder="Nhập từ khóa..." value="@Context.Request.Query["keyword"]" />
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold">Môn học</label>
                    <select id="subjectId" name="subjectId" asp-items="ViewBag.SubjectList" class="form-select bg-light">
                        <option value="">-- Tất cả môn học --</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-success fw-bold px-4 me-2" style="background-color: #005b33;">
                        <i class="fa fa-search me-1"></i> Tìm kiếm
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary fw-bold px-4">
                        <i class="fa fa-rotate me-1"></i> Làm mới
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light text-muted">
                <tr>
                    <th class="ps-4" style="width:5%">STT</th>
                    <th style="width:35%">Nội dung</th>
                    <th style="width:20%">Môn học</th>
                    <th class="text-center" style="width:15%">Loại</th>
                    <th class="text-center" style="width:10%">Đáp án</th>
                    <th class="text-end pe-4" style="width:15%">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{ int stt = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-muted">@stt</td>
                        <td>
                            <div class="fw-semibold text-dark text-truncate" style="max-width: 300px;" title="@item.Content">@item.Content</div>
                        </td>
                        <td class="text-muted small">@item.Subject.SubjectName</td>
                        <td class="text-center">
                            @if (item.QuestionType == 1)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 rounded-pill">Trắc nghiệm</span>
                            }
                            else
                            {
                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-3 rounded-pill text-dark">Tự luận</span>
                            }
                        </td>
                        <td class="text-center fw-bold text-success">
                            @(string.IsNullOrEmpty(item.CorrectAnswer) ? "-" : item.CorrectAnswer)
                        </td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.QuestionId" class="btn btn-sm btn-outline-warning">
                                <i class="fa fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.QuestionId" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa câu hỏi này?');">
                                <i class="fa fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                    stt++;
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <form asp-action="Import" method="post" enctype="multipart/form-data">
                <div class="modal-header text-white" style="background-color: #005b33; border-radius: 1rem 1rem 0 0;">
                    <h5 class="modal-title fw-bold"><i class="fa fa-file-excel me-2"></i> Import ngân hàng câu hỏi</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Chọn tệp tin Excel (.xlsx)</label>
                        <input type="file" name="fileExcel" class="form-control bg-light" required />
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between bg-light border-top-0 rounded-bottom-4">
                    <a asp-action="DownloadTemplate" class="btn btn-outline-success fw-bold">
                        <i class="fa fa-download"></i> Tải file mẫu
                    </a>
                    <div>
                        <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success fw-bold" style="background-color: #005b33;">Xác nhận Import</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.getElementById("btnExport").addEventListener("click", function () {
        var subjectDropdown = document.getElementById("subjectId");
        var subjectId = subjectDropdown ? subjectDropdown.value : "";
        var url = "/Questions/Export";

        if (subjectId && subjectId !== "") {
            url += "?subjectId=" + subjectId;
        }

        window.location.href = url;
    });

</script>