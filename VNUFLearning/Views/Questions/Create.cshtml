@model VNUFLearning.Models.Question
@{
    ViewData["Title"] = "Tạo câu hỏi mới";
}

<style>
    .select2-container .select2-selection--single {
        height: 38px !important;
        border: 1px solid #ced4da;
        border-radius: .375rem;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 36px !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 36px !important;
    }
</style>

<div class="container mt-4">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="row">
        <!-- NHẬP THỦ CÔNG -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">📝 Nhập thủ công</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                        <div class="row mb-3">
                            <div class="col-md-7">
                                <label class="fw-bold">Môn học <span class="text-danger">*</span></label>
                                <select asp-for="SubjectId"
                                        class="form-select select2-dropdown"
                                        asp-items="ViewBag.SubjectId">
                                </select>
                            </div>

                            <div class="col-md-5">
                                <label class="fw-bold">Loại câu hỏi</label>
                                <select asp-for="QuestionType"
                                        class="form-select"
                                        id="questionType"
                                        onchange="toggleOptions()">
                                    <option value="1">🔵 Trắc nghiệm</option>
                                    <option value="2">🟠 Tự luận</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Nội dung <span class="text-danger">*</span></label>
                            <textarea asp-for="Content" class="form-control" rows="4" required></textarea>
                        </div>

                        <!-- KHU VỰC TRẮC NGHIỆM -->
                        <div id="multipleChoiceArea" class="bg-light p-3 rounded border">
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="input-group">
                                        <span class="input-group-text">A</span>
                                        <input asp-for="OptionA" class="form-control" id="optA" />
                                    </div>
                                </div>

                                <div class="col-6">
                                    <div class="input-group">
                                        <span class="input-group-text">B</span>
                                        <input asp-for="OptionB" class="form-control" id="optB" />
                                    </div>
                                </div>

                                <div class="col-6">
                                    <div class="input-group">
                                        <span class="input-group-text">C</span>
                                        <input asp-for="OptionC" class="form-control" id="optC" />
                                    </div>
                                </div>

                                <div class="col-6">
                                    <div class="input-group">
                                        <span class="input-group-text">D</span>
                                        <input asp-for="OptionD" class="form-control" id="optD" />
                                    </div>
                                </div>
                            </div>

                            <label class="fw-bold text-success">Đáp án đúng:</label>
                            <select asp-for="CorrectAnswer"
                                    class="form-select w-auto d-inline-block ms-2"
                                    id="mcCorrect">
                                <option value="A">A</option>
                                <option value="B">B</option>
                                <option value="C">C</option>
                                <option value="D">D</option>
                            </select>
                        </div>

                        <!-- KHU VỰC TỰ LUẬN -->
                        <div id="essayArea" class="d-none bg-warning bg-opacity-10 p-3 rounded border border-warning mt-3">
                            <label class="fw-bold text-dark">💡 Gợi ý trả lời / Từ khóa:</label>

                            <!-- KHÔNG DISABLED để còn submit lên server -->
                            <textarea asp-for="CorrectAnswer"
                                      class="form-control mt-2"
                                      rows="3"
                                      id="essayCorrect"></textarea>
                        </div>

                        <div class="text-end mt-3">
                            <button type="submit" class="btn btn-primary px-4">Lưu câu hỏi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- IMPORT EXCEL -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">📂 Nhập từ Excel</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Import" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label>Chọn file .xlsx</label>
                            <input type="file" name="fileExcel" class="form-control" accept=".xlsx" required />
                        </div>

                        <button type="submit" class="btn btn-success w-100">Tải lên ngay</button>
                    </form>

                    <div class="alert alert-light border mt-3 small">
                        <strong>Cấu trúc cột:</strong><br />
                        1.Nội dung | 2.Loại (1=TN, 2=TL)<br />
                        3-6.Đáp án | 7.Đáp án đúng/Gợi ý<br />
                        8.ID Môn
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Select2 đã được load trong _Layout.cshtml
            $('.select2-dropdown').select2({
                placeholder: "Tìm kiếm môn học...",
                allowClear: true,
                width: '100%'
            });

            // Quan trọng: gọi ngay khi load trang để UI đúng
            toggleOptions();
        });

        function toggleOptions() {
            const type = document.getElementById("questionType").value;
            const mcArea = document.getElementById("multipleChoiceArea");
            const essayArea = document.getElementById("essayArea");

            const inputsTN = document.querySelectorAll('#optA, #optB, #optC, #optD, #mcCorrect');

            if (type === "1") { // Trắc nghiệm
                mcArea.classList.remove("d-none");
                essayArea.classList.add("d-none");

                inputsTN.forEach(el => el.removeAttribute("disabled"));
            } else { // Tự luận
                mcArea.classList.add("d-none");
                essayArea.classList.remove("d-none");

                inputsTN.forEach(el => el.setAttribute("disabled", "disabled"));
            }
        }
    </script>
}
